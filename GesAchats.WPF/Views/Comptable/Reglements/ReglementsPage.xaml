<Page x:Class="GesAchats.WPF.Views.Comptable.Reglements.ReglementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Reglements"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Suivi des Règlements">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,15">
            <TextBlock Text="💳 Suivi des Règlements &amp; Historique" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1A3A52"/>
        </Border>

        <!-- Dashboard KPIs -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="6" Margin="20,10">
            <ctrls:KpiCard Title="Total payé (Mois)" 
                           Value="{Binding TotalPaidMonth}" 
                           Unit="MAD"
                           Icon="MoneyBillWave" 
                           IconColor="#4CAF50" 
                           Margin="0,0,8,0"/>

            <ctrls:KpiCard Title="Factures Attente" 
                           Value="{Binding PendingInvoicesCount}" 
                           Unit="factures"
                           Icon="Clock" 
                           IconColor="#FFC107" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Retards Paiement" 
                           Value="{Binding LatePaymentsCount}" 
                           Unit="retards"
                           Icon="TriangleExclamation" 
                           IconColor="#F44336" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Total Réglé" 
                           Value="{Binding TotalAmountRegle}" 
                           Unit="MAD"
                           Icon="Wallet" 
                           IconColor="#2196F3" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Fourn. Payés" 
                           Value="{Binding FournisseursPayesCount}" 
                           Unit="fournisseurs"
                           Icon="Users" 
                           IconColor="#9C27B0" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Total Opérations" 
                           Value="{Binding TotalOperationsReglementCount}" 
                           Unit="règlements"
                           Icon="ListCheck" 
                           IconColor="#607D8B" 
                           Margin="8,0,0,0"/>
        </UniformGrid>

        <!-- Filters -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="20,15,20,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Fournisseur" Foreground="#757575" FontSize="12"/>
                        <ComboBox Width="160" ItemsSource="{Binding Suppliers}" DisplayMemberPath="CompanyName" SelectedItem="{Binding SelectedSupplier}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Date" Foreground="#757575" FontSize="12"/>
                        <DatePicker Width="140" SelectedDate="{Binding SelectedDate}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Mode de paiement" Foreground="#757575" FontSize="12"/>
                        <ComboBox Width="140" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Recherche" Foreground="#757575" FontSize="12"/>
                        <TextBox Width="140" Text="{Binding SearchInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="26"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Ajouter un règlement" 
                            Command="{Binding AddPaymentCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="{StaticResource SuccessBrush}"
                            Padding="10,4" Margin="0,0,10,0"/>
                    <Button Command="{Binding ToggleChartsCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Padding="10,4" Margin="0,0,10,0"
                            BorderBrush="#1A3A52" Foreground="#1A3A52">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ShowCharts, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='Masquer les graphes|Afficher les graphes'}" />
                        </StackPanel>
                    </Button>
                    <Button Content="🔄 Réinitialiser" Command="{Binding ResetFiltersCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Padding="10,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Charts Section -->
        <Border Grid.Row="3" Margin="20,15,20,0" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15"
                Visibility="{Binding ShowCharts, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Distribution Fournisseur -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="📊 Distribution par fournisseur" Foreground="#1A3A52" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:PieChart Series="{Binding SupplierDistribution}" Height="220" LegendPosition="Bottom" />
                </StackPanel>

                <!-- Modes de Paiement -->
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="💳 Modes de paiement" Foreground="#1A3A52" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:CartesianChart Series="{Binding PaymentMethodsDistribution}" XAxes="{Binding XAxesMethods}" Height="220" />
                </StackPanel>

                <!-- Évolution par date -->
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="📈 Évolution des paiements" Foreground="#1A3A52" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:CartesianChart Series="{Binding PaymentsByDate}" XAxes="{Binding XAxesPayments}" Height="220" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- History Table -->
        <Border Grid.Row="4" Background="White" Margin="20,15,20,20" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="15,10" Background="#FAFAFA" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="HISTORIQUE DES RÈGLEMENTS" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Payments}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Supplier.CompanyName}" Width="*"/>
                        <DataGridTextColumn Header="Numéro de facture" Binding="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Width="150"/>
                        <DataGridTextColumn Header="Montant" Binding="{Binding AmountPaid, StringFormat={}{0:N2} MAD}" Width="120"/>
                        <DataGridTextColumn Header="Mode" Binding="{Binding PaymentMethod}" Width="120"/>
                        <DataGridTextColumn Header="Référence" Binding="{Binding ReferenceNumber}" Width="150"/>
                        <DataGridTemplateColumn Header="Justificatif" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📄" 
                                            Command="{Binding DataContext.ViewProofCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" 
                                            Visibility="{Binding ProofFilePath, Converter={StaticResource StringToVisibilityConverter}}"
                                            Padding="8,4"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
