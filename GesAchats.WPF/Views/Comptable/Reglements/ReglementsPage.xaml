<Page x:Class="GesAchats.WPF.Views.Comptable.Reglements.ReglementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Reglements"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Suivi des Règlements">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
                <ResourceDictionary Source="../../../Resources/Shared/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <conv:SkiaColorToBrushConverter x:Key="SkiaColorToBrushConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,15">
            <TextBlock Text="💳 Suivi des Règlements &amp; Historique" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1A3A52"/>
        </Border>

        <!-- Dashboard KPIs -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="20,10">
            <ctrls:KpiCard Title="Total payé (Mois)" 
                           Value="{Binding TotalPaidMonth}" 
                           TrendText="{Binding TotalPaidMonthTrendText}"
                           Unit="MAD"
                           Icon="MoneyBillWave" 
                           IconColor="#4CAF50" 
                           Margin="0,0,8,0"/>

            <ctrls:KpiCard Title="Factures Attente" 
                           Value="{Binding PendingInvoicesCount}" 
                           TrendText="{Binding PendingInvoicesCountTrendText}"
                           Unit="factures"
                           Icon="Clock" 
                           IconColor="#FFC107" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Total Réglé" 
                           Value="{Binding TotalAmountRegle}" 
                           TrendText="{Binding TotalAmountRegleTrendText}"
                           Unit="MAD"
                           Icon="Wallet" 
                           IconColor="#2196F3" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Fourn. Payés" 
                           Value="{Binding FournisseursPayesCount}" 
                           TrendText="{Binding FournisseursPayesCountTrendText}"
                           Unit="fournisseurs"
                           Icon="Users" 
                           IconColor="#9C27B0" 
                           Margin="4,0,4,0"/>

            <ctrls:KpiCard Title="Total Opérations" 
                           Value="{Binding TotalOperationsReglementCount}" 
                           TrendText="{Binding TotalOperationsReglementCountTrendText}"
                           Unit="règlements"
                           Icon="ListCheck" 
                           IconColor="#607D8B" 
                           Margin="8,0,0,0"/>
        </UniformGrid>

        <!-- Filters -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="20,15,20,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Fournisseur" Foreground="#757575" FontSize="12"/>
                        <ComboBox Width="160" ItemsSource="{Binding Suppliers}" DisplayMemberPath="CompanyName" SelectedItem="{Binding SelectedSupplier}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Date" Foreground="#757575" FontSize="12"/>
                        <DatePicker Width="140" SelectedDate="{Binding SelectedDate}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Mode de paiement" Foreground="#757575" FontSize="12"/>
                        <ComboBox Width="140" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Recherche" Foreground="#757575" FontSize="12"/>
                        <TextBox Width="140" Text="{Binding SearchInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="26"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+ Ajouter un règlement" 
                            Command="{Binding AddPaymentCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="{StaticResource SuccessBrush}"
                            Padding="10,4" Margin="0,0,10,0"
                            Visibility="{Binding CanAddReglement, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Command="{Binding ToggleChartsCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Padding="10,4" Margin="0,0,10,0"
                            BorderBrush="#1A3A52" Foreground="#1A3A52">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ShowCharts, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='Masquer les graphes|Afficher les graphes'}" />
                        </StackPanel>
                    </Button>
                    <Button Content="🔄 Réinitialiser" Command="{Binding ResetFiltersCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Padding="10,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Charts Section -->
        <Border Grid.Row="3" Margin="20,15,20,0" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15"
                Visibility="{Binding ShowCharts, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Répartition par mode de paiement (Doughnut Chart) -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="💳 Répartition par mode de paiement" Foreground="#1A3A52" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <lvc:PieChart Series="{Binding PaymentMethodSeries}" LegendPosition="Hidden" InitialRotation="-90" Height="180" />
                            <StackPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="{Binding TotalPaymentMethodAmount, StringFormat={}{0:N2} MAD}" FontSize="16" FontWeight="ExtraBold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                <TextBlock Text="Total" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center" FontWeight="Medium"/>
                            </StackPanel>
                        </StackPanel>
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding PaymentMethodSeries}" VerticalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <Border Width="14" Height="14" CornerRadius="7" Background="{Binding Fill, Converter={StaticResource SkiaColorToBrushConverter}}"/>
                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#1E293B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>

                <!-- Évolution des paiements (Line Chart) -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="📈 Évolution des paiements" Foreground="#1A3A52" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                    <lvc:CartesianChart Series="{Binding PaymentsByDate}" XAxes="{Binding XAxesPayments}" Height="220" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- History Table -->
        <Border Grid.Row="4" Style="{StaticResource ModernCard}" Margin="20,15,20,20" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="24,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <TextBlock Text="HISTORIQUE DES RÈGLEMENTS" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                </Border>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding Payments}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          Background="Transparent" 
                          BorderThickness="0" 
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          MinWidth="1300"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4F46E5"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DATE" Binding="{Binding PaymentDate, StringFormat=dd/MM/yyyy}" Width="Auto" MinWidth="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding Supplier.CompanyName}" Width="Auto" MinWidth="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NUMÉRO DE FACTURE" Binding="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Width="Auto" MinWidth="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="MONTANT" Binding="{Binding AmountPaid, StringFormat={}{0:N2} MAD}" Width="Auto" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="MODE" Binding="{Binding PaymentMethod}" Width="Auto" MinWidth="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="RÉFÉRENCE" Binding="{Binding ReferenceNumber}" Width="Auto" MinWidth="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="JUSTIFICATIF" Width="Auto" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📄" 
                                            Command="{Binding DataContext.ViewProofCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" 
                                            Visibility="{Binding ProofFilePath, Converter={StaticResource StringToVisibilityConverter}}"
                                            Margin="12,8"
                                            Padding="10,4"
                                            FontSize="14">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
