<Page x:Class="GesAchats.WPF.Views.Comptable.Reglements.ReglementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Reglements"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Suivi des Règlements">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,15">
            <TextBlock Text="💳 Suivi des Règlements &amp; Historique" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1A3A52"/>
        </Border>

        <!-- Dashboard KPIs -->
        <Grid Grid.Row="1" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💰 Total payé ce mois" Foreground="#757575" FontSize="12"/>
                    <TextBlock Text="{Binding TotalPaidMonth, StringFormat={}{0:N2} €}" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,0,10,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⏳ Factures en attente" Foreground="#757575" FontSize="12"/>
                    <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="#FFC107"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🔴 Retards de paiement" Foreground="#757575" FontSize="12"/>
                    <TextBlock Text="1" FontSize="24" FontWeight="Bold" Foreground="#F44336"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- History Table -->
        <Border Grid.Row="2" Background="White" Margin="20,0,20,20" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="15,10" Background="#FAFAFA" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="HISTORIQUE DES RÈGLEMENTS" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="📊 Export Excel" Command="{Binding ExportExcelCommand}" HorizontalAlignment="Right" Style="{StaticResource MaterialDesignOutlinedButton}" Padding="10,4"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Payments}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Supplier.Name}" Width="*"/>
                        <DataGridTextColumn Header="Facture" Binding="{Binding Invoice.InvoiceNumber}" Width="120"/>
                        <DataGridTextColumn Header="Montant" Binding="{Binding AmountPaid, StringFormat={}{0:N2} €}" Width="100"/>
                        <DataGridTextColumn Header="Mode" Binding="{Binding PaymentMethod}" Width="100"/>
                        <DataGridTextColumn Header="Référence" Binding="{Binding ReferenceNumber}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
