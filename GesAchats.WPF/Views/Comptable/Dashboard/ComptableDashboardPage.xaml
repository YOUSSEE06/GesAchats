<Page x:Class="GesAchats.WPF.Views.Comptable.Dashboard.ComptableDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Dashboard"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Tableau de bord Comptable">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <StackPanel Margin="30">
            <TextBlock Text="Tableau de bord Comptable" FontSize="28" FontWeight="Bold" Foreground="#1A3A52" Margin="0,0,0,30"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#4CAF50" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Total Payé (Mois)" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="12 450,00 €" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFC107" CornerRadius="8" Padding="20" Margin="10,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Factures en Attente" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="3" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#F44336" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Factures en Retard" Foreground="White" Opacity="0.8"/>
                        <TextBlock Text="1" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <TextBlock Text="Actions Rapides" FontSize="18" FontWeight="SemiBold" Margin="0,40,0,20"/>
            
            <WrapPanel>
                <Button Content="Saisir une Facture" Width="200" Height="100" Margin="0,0,20,20" Style="{StaticResource MaterialDesignRaisedButton}" Background="White" Foreground="#1A3A52"/>
                <Button Content="Vérifier Conformité" Width="200" Height="100" Margin="0,0,20,20" Style="{StaticResource MaterialDesignRaisedButton}" Background="White" Foreground="#1A3A52"/>
                <Button Content="Historique Paiements" Width="200" Height="100" Margin="0,0,20,20" Style="{StaticResource MaterialDesignRaisedButton}" Background="White" Foreground="#1A3A52"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Page>
