<Page x:Class="GesAchats.WPF.Views.Comptable.Dashboard.ComptableDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Dashboard"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="1200" d:DesignWidth="1200"
      Title="Tableau de bord Comptable">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
                <ResourceDictionary Source="../../../Resources/Shared/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <conv:IsPositiveConverter x:Key="IsPositiveConverter"/>
            
            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Resources>
                    <DropShadowEffect x:Key="Shadow" BlurRadius="10" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                </Style.Resources>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                
                <!-- Header with Date Filters -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tableau de bord Comptable" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Vue d'ensemble de la comptabilité fournisseur" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <DatePicker SelectedDate="{Binding StartDate}" 
                                    Width="160" Margin="0,0,12,0"
                                    VerticalContentAlignment="Center"
                                    Height="35"/>
                        <DatePicker SelectedDate="{Binding EndDate}" 
                                    Width="160" Margin="0,0,12,0"
                                    VerticalContentAlignment="Center"
                                    Height="35"/>
                        <Button Command="{Binding RefreshCommand}" 
                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                Background="{StaticResource PrimaryBrush}" 
                                BorderBrush="{StaticResource PrimaryBrush}"
                                Height="35">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Sync" Width="14" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Actualiser"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 1. SECTION KPI PRINCIPALE -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <controls:KpiCard Grid.Column="0" Margin="0,0,8,0" Title="Total Factures" Value="{Binding Data.TotalInvoices.Value}" Icon="FileInvoice" IconColor="#2563EB" TrendText="{Binding Data.TotalInvoices.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.TotalInvoices.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                    <controls:KpiCard Grid.Column="1" Margin="4,0,8,0" Title="Factures en attente" Value="{Binding Data.PendingInvoices.Value}" Icon="Clock" IconColor="#F59E0B" TrendText="{Binding Data.PendingInvoices.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.PendingInvoices.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                    <controls:KpiCard Grid.Column="2" Margin="4,0,8,0" Title="Factures validées" Value="{Binding Data.ValidatedInvoices.Value}" Icon="CheckCircle" IconColor="#22C55E" TrendText="{Binding Data.ValidatedInvoices.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.ValidatedInvoices.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                    <controls:KpiCard Grid.Column="3" Margin="4,0,8,0" Title="Factures part. payées" Value="{Binding Data.PartiallyPaidInvoices.Value}" Icon="CreditCard" IconColor="#8B5CF6" TrendText="{Binding Data.PartiallyPaidInvoices.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.PartiallyPaidInvoices.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                    <controls:KpiCard Grid.Column="4" Margin="4,0,8,0" Title="Total BL" Value="{Binding Data.TotalBl.Value}" Icon="Truck" IconColor="#64748B" TrendText="{Binding Data.TotalBl.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.TotalBl.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                    <controls:KpiCard Grid.Column="5" Margin="4,0,8,0" Title="BL validés" Value="{Binding Data.ValidatedBl.Value}" Icon="FileContract" IconColor="#10B981" TrendText="{Binding Data.ValidatedBl.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.ValidatedBl.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                    <controls:KpiCard Grid.Column="6" Margin="4,0,0,0" Title="BL en attente" Value="{Binding Data.PendingBl.Value}" Icon="HourglassHalf" IconColor="#F59E0B" TrendText="{Binding Data.PendingBl.VariationPercentage, StringFormat={}{0:N1}%}" IsPositiveTrend="{Binding Data.PendingBl.VariationPercentage, Converter={StaticResource IsPositiveConverter}}"/>
                </Grid>

                <!-- 3. BLOC SOLDES & RÈGLEMENTS TTC -->
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total des règlements" Foreground="#64748B" FontSize="13"/>
                            <TextBlock Text="{Binding Data.TotalPayments, StringFormat={}{0:N2} €}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <Separator Grid.Column="1" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,0"/>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Total des soldes" Foreground="#64748B" FontSize="13"/>
                            <TextBlock Text="{Binding Data.TotalBalances, StringFormat={}{0:N2} €}" FontSize="24" FontWeight="Bold" Foreground="#EF4444" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <Separator Grid.Column="3" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,0"/>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Soldes restants TTC" Foreground="#64748B" FontSize="13"/>
                            <TextBlock Text="{Binding Data.RemainingTtcBalance, StringFormat={}{0:N2} €}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <Separator Grid.Column="5" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,0"/>
                        
                        <StackPanel Grid.Column="6">
                            <Grid>
                                <TextBlock Text="Taux de paiement" Foreground="#64748B" FontSize="13"/>
                                <TextBlock Text="{Binding Data.PaymentRatePercentage, StringFormat={}{0:N1}%}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                            <ProgressBar Value="{Binding Data.PaymentRatePercentage}" Height="10" Margin="0,8,0,0" Foreground="{StaticResource PrimaryBrush}" Background="#E2E8F0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 4. GRAPHIQUES CENTRAUX -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <controls:ChartCard Grid.Column="0" Margin="0,0,12,0" Title="Répartition par fournisseur">
                        <lvc:PieChart Series="{Binding SupplierDistributionSeries}" Height="250" LegendPosition="Bottom"/>
                    </controls:ChartCard>
                    
                    <controls:ChartCard Grid.Column="1" Margin="6,0,12,0" Title="Statut des factures">
                        <lvc:PieChart Series="{Binding InvoiceStatusSeries}" Height="250" LegendPosition="Bottom"/>
                    </controls:ChartCard>
                    
                    <controls:ChartCard Grid.Column="2" Margin="6,0,0,0" Title="Statut des BL">
                        <lvc:PieChart Series="{Binding BlStatusSeries}" Height="250" LegendPosition="Bottom"/>
                    </controls:ChartCard>
                </Grid>

                <!-- 5 & 6. EVOLUTION & MODES -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <controls:ChartCard Grid.Column="0" Margin="0,0,12,0" Title="Évolution des paiements et soldes">
                        <lvc:CartesianChart Series="{Binding PaymentEvolutionSeries}" XAxes="{Binding XAxes}" Height="300" LegendPosition="Bottom"/>
                    </controls:ChartCard>
                    
                    <controls:ChartCard Grid.Column="1" Margin="6,0,0,0" Title="Modes de paiement">
                        <lvc:CartesianChart Series="{Binding PaymentModeSeries}" Height="300"/>
                    </controls:ChartCard>
                </Grid>

                <!-- 7. DERNIÈRES OPÉRATIONS -->
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Dernières Opérations" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding Data.RecentOperations}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Background="Transparent" 
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9"
                                  RowHeight="45">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                <DataGridTemplateColumn Header="MODULE" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,4" Background="#F1F5F9" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Module}" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding Supplier}" Width="*"/>
                                <DataGridTextColumn Header="RÉFÉRENCE" Binding="{Binding Reference}" Width="Auto"/>
                                <DataGridTextColumn Header="MONTANT TTC" Binding="{Binding AmountTtc, StringFormat={}{0:N2} €}" Width="Auto">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="STATUT" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Payee">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Payée">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Valide">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="EnAttente">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="En attente">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="PartiellementPayee">
                                                                <Setter Property="Background" Value="#F3E8FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#475569"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Payee">
                                                                    <Setter Property="Foreground" Value="#15803D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Payée">
                                                                    <Setter Property="Foreground" Value="#15803D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                    <Setter Property="Foreground" Value="#15803D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Valide">
                                                                    <Setter Property="Foreground" Value="#15803D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="EnAttente">
                                                                    <Setter Property="Foreground" Value="#B45309"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="En attente">
                                                                    <Setter Property="Foreground" Value="#B45309"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="PartiellementPayee">
                                                                    <Setter Property="Foreground" Value="#7E22CE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
        
        <!-- Loading Overlay -->
        <Grid Background="#40FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="True" Width="24" Height="24"/>
                    <TextBlock Text="Chargement des données..." Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
