<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.ConformityCheckPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="ConformityCheckPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <Button Content="⬅" Command="{Binding BackCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0"/>
                <TextBlock Text="Vérification de Conformité - " FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1A3A52"/>
                <TextBlock Text="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2196F3"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <!-- Info Header -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Fournisseur" Foreground="#757575" FontSize="12"/>
                            <TextBlock Text="{Binding Invoice.Supplier.Name}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Bon de Commande" Foreground="#757575" FontSize="12"/>
                            <TextBlock Text="{Binding Invoice.PurchaseOrder.OrderNumber}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Bon de Livraison" Foreground="#757575" FontSize="12"/>
                            <TextBlock Text="{Binding Invoice.DeliveryNote.DeliveryNumber}" FontWeight="SemiBold" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Comparison Table -->
                <GroupBox Header="COMPARAISON ARTICLE PAR ARTICLE" Style="{StaticResource MaterialDesignCardGroupBox}" Margin="0,0,0,20">
                    <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Article" Binding="{Binding ArticleName}" Width="*"/>
                            <DataGridTextColumn Header="BC Qté" Binding="{Binding QuantityOrdered}" Width="80"/>
                            <DataGridTextColumn Header="BC PU" Binding="{Binding PriceOrdered, StringFormat={}{0:N2} MAD}" Width="100"/>
                            <DataGridTextColumn Header="BL Qté" Binding="{Binding QuantityReceived}" Width="80"/>
                            <DataGridTextColumn Header="Fact. Qté" Binding="{Binding QuantityInvoiced}" Width="80"/>
                            <DataGridTextColumn Header="Fact. PU" Binding="{Binding PriceInvoiced, StringFormat={}{0:N2} MAD}" Width="100"/>
                            <DataGridTemplateColumn Header="Statut" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" CornerRadius="4" Padding="5,2">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- Decision Section -->
                <GroupBox Header="DÉCISION DU COMPTABLE" Style="{StaticResource MaterialDesignCardGroupBox}">
                    <StackPanel Margin="10">
                        <TextBlock Text="Justification / Observations (obligatoire si écart)" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Justification, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="✅ Valider la facture" Command="{Binding ValidateCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="#4CAF50" Foreground="White" Width="200" Margin="0,0,20,0"/>
                            <Button Content="❌ Rejeter la facture" Command="{Binding RejectCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="#F44336" Foreground="White" Width="200"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
