<Window x:Class="GesAchats.WPF.Views.Comptable.Factures.FactureDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
        mc:Ignorable="d"
        Title="Détails de la Facture" Height="800" Width="750"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">
    <Grid Margin="20">
        <Grid.Resources>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,20">
            <Button Content="← Retour" DockPanel.Dock="Left" Padding="10,5" Background="Transparent" BorderThickness="0" Foreground="#566573" Command="{Binding CloseCommand}"/>
            <TextBlock Text="{Binding Invoice.ExternalInvoiceNumber, StringFormat='Détails Facture: {0}', TargetNullValue='Détails Facture'}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Informations Générales -->
                <GroupBox Header="INFORMATIONS GÉNÉRALES" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="N° Facture" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Fournisseur:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.Supplier.CompanyName}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Date Facture:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.InvoiceDate, StringFormat=dd/MM/yyyy}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Statut:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.Status}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Montant TTC:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.AmountTTC, StringFormat={}{0:N2} MAD}" FontSize="16" FontWeight="Bold" Foreground="#1A3A52" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Conformité:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.ConformityStatus}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Références -->
                <GroupBox Header="RÉFÉRENCES" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Bon de Commande:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.PurchaseOrder.OrderNumber, TargetNullValue='Aucun'}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Bon de Livraison:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Invoice.DeliveryNote.DeliveryNumber, TargetNullValue='Aucun'}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Articles Facturés -->
                <GroupBox Header="ARTICLES FACTURÉS" Margin="0,0,0,15" Padding="10">
                    <DataGrid ItemsSource="{Binding Details}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Désignation" Binding="{Binding Product.Designation}" Width="*"/>
                            <DataGridTextColumn Header="Quantité" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Prix Unitaire HT" Binding="{Binding UnitPriceHT, StringFormat={}{0:N2} MAD}" Width="130"/>
                            <DataGridTextColumn Header="Total HT" Binding="{Binding TotalHT, StringFormat={}{0:N2} MAD}" Width="120"/>
                            <DataGridTextColumn Header="Total TTC" Binding="{Binding TotalTTC, StringFormat={}{0:N2} MAD}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- Justificatif -->
                <GroupBox Header="JUSTIFICATIF" Margin="0,0,0,15" Padding="10">
                    <Button Content="📎 Ouvrir le Justificatif" 
                            Command="{Binding ViewJustificatifCommand}"
                            Padding="15,10" 
                            Background="#2196F3" 
                            Foreground="White" 
                            BorderThickness="0"
                            Visibility="{Binding Invoice.FilePath, Converter={StaticResource StringToVisibilityConverter}}"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Fermer" Command="{Binding CloseCommand}" Padding="25,10" Background="#1B2631" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
