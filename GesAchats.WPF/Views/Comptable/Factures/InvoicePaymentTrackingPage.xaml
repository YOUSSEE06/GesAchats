<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.InvoicePaymentTrackingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:vm="clr-namespace:GesAchats.WPF.ViewModels.Comptable"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="PV Comptable - Suivi des Factures et Règlements">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Stats -->
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total TTC -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50" CornerRadius="8" Background="#E3F2FD">
                            <TextBlock Text="💶" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="Montant Total TTC" Foreground="#616161" FontSize="12"/>
                            <TextBlock Text="{Binding TotalTTC, StringFormat='{}{0:N2} MAD'}" FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Total Payments -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50" CornerRadius="8" Background="#E8F5E9">
                            <TextBlock Text="✅" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="Total Règlements" Foreground="#616161" FontSize="12"/>
                            <TextBlock Text="{Binding TotalPayments, StringFormat='{}{0:N2} MAD'}" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Total Balance -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50" CornerRadius="8" Background="#FFF3E0">
                            <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="Solde Total" Foreground="#616161" FontSize="12"/>
                            <TextBlock Text="{Binding TotalBalance, StringFormat='{}{0:N2} MAD'}" FontSize="24" FontWeight="Bold" Foreground="#FF9800"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,20,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Fournisseur" FontSize="12" Foreground="#616161"/>
                    <ComboBox ItemsSource="{Binding Suppliers}" 
                              DisplayMemberPath="CompanyName"
                              SelectedItem="{Binding SelectedSupplier}"
                              Padding="8,5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0">
                    <TextBlock Text="Statut" FontSize="12" Foreground="#616161"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" 
                              SelectedItem="{Binding SelectedStatus}"
                              Padding="8,5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0">
                    <TextBlock Text="Date" FontSize="12" Foreground="#616161"/>
                    <DatePicker SelectedDate="{Binding SelectedDate}" Padding="8,5"/>
                </StackPanel>

                <Button Grid.Column="3" Content="🔄 Réinitialiser" Command="{Binding ResetFiltersCommand}" Padding="15,8" Background="#1A3A52" Foreground="White" FontSize="14" FontWeight="SemiBold" Height="40" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Main DataGrid -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Margin="0,20,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="15,10" Background="#FAFAFA" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <TextBlock Text="📋 Historique des Factures" FontSize="16" FontWeight="SemiBold" Foreground="#1A3A52"/>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredInvoices}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Invoice.InvoiceDate, StringFormat='dd/MM/yyyy'}" Width="*"/>
                        <DataGridTextColumn Header="N° Facture" Binding="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Width="*"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Invoice.Supplier.CompanyName}" Width="2*"/>
                        <DataGridTextColumn Header="Montant HT" Binding="{Binding Invoice.AmountHT, StringFormat='{}{0:N2} MAD'}" Width="*"/>
                        <DataGridTextColumn Header="TVA" Binding="{Binding Invoice.TaxAmount, StringFormat='{}{0:N2} MAD'}" Width="*"/>
                        <DataGridTextColumn Header="Montant TTC" Binding="{Binding Invoice.AmountTTC, StringFormat='{}{0:N2} MAD'}" Width="*"/>
                        <DataGridTextColumn Header="Règlement TTC" Binding="{Binding TotalPayments, StringFormat='{}{0:N2} MAD'}" Width="*"/>
                        <DataGridTextColumn Header="Solde" Binding="{Binding Balance, StringFormat='{}{0:N2} MAD'}" Width="*"/>
                        <DataGridTemplateColumn Header="Statut" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusCalculated}" 
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="👁️ Voir" Command="{Binding DataContext.ViewInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Padding="8,4"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
