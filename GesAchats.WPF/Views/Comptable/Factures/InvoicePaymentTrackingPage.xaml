<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.InvoicePaymentTrackingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:vm="clr-namespace:GesAchats.WPF.ViewModels.Comptable"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="PV Comptable - Suivi des Factures et Règlements">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="BtnPrimaryStyle" TargetType="Button">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#6C5CE7"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Foreground" Value="#6C5CE7"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnResetStyle" TargetType="Button">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="Background" Value="#6C5CE7"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontSize" Value="13.5"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" 
                                    Background="{TemplateBinding Background}" 
                                    BorderThickness="0" 
                                    CornerRadius="19" 
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" 
                                            Property="Background" 
                                            Value="#5A4BD1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" 
                                            Property="Background" 
                                            Value="#4A3BBF"/>
                                    <Setter TargetName="Bd" 
                                            Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Focusable="False" 
                                              HorizontalScrollBarVisibility="Hidden" 
                                              VerticalScrollBarVisibility="Hidden"
                                              VerticalAlignment="Center"
                                              Margin="12,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton" 
                                                  Grid.Column="2" 
                                                  Focusable="False" 
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite" 
                                                      IsHitTestVisible="False" 
                                                      Margin="12,0,30,0" 
                                                      VerticalAlignment="Center" 
                                                      Content="{TemplateBinding SelectionBoxItem}" 
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                    <TextBox x:Name="PART_EditableTextBox" 
                                              Style="{x:Null}" 
                                              BorderThickness="0" 
                                              Background="Transparent" 
                                              Padding="12,0" 
                                              VerticalAlignment="Center" 
                                              Focusable="True" 
                                              IsReadOnly="{TemplateBinding IsReadOnly}" 
                                              Visibility="Hidden"/>
                                    <Path x:Name="Arrow" 
                                          Grid.Column="2" 
                                          Data="M0,0 L4,4 L8,0 Z" 
                                          Fill="#6C5CE7" 
                                          HorizontalAlignment="Right" 
                                          Margin="10,0" 
                                          VerticalAlignment="Center"/>
                                    <Popup x:Name="Popup" 
                                           AllowsTransparency="True" 
                                           Placement="Bottom" 
                                           StaysOpen="False" 
                                           Focusable="False" 
                                           IsOpen="{TemplateBinding IsDropDownOpen}" 
                                           PopupAnimation="Slide">
                                        <Border x:Name="DropDownBorder" 
                                                Background="White" 
                                                BorderBrush="#D0CDE8" 
                                                BorderThickness="1" 
                                                CornerRadius="8" 
                                                Padding="0">
                                            <ScrollViewer Margin="0" 
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                                KeyboardNavigation.DirectionalNavigation="Continue"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterDateStyle" TargetType="DatePicker">
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePickerTextBox 
                                        x:Name="PART_TextBox" 
                                        Grid.Column="0" 
                                        Foreground="{TemplateBinding Foreground}" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        VerticalContentAlignment="Center" 
                                        Padding="12,0" 
                                        FontSize="{TemplateBinding FontSize}"/>
                                    <Button x:Name="PART_Button" 
                                            Grid.Column="1" 
                                            Width="32" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Cursor="Hand" 
                                            Focusable="False">
                                        <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                              Stroke="#6C5CE7" StrokeThickness="1.5" 
                                              StrokeLineJoin="Round" 
                                              StrokeStartLineCap="Round" 
                                              StrokeEndLineCap="Round" 
                                              Width="16" Height="16" 
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Popup x:Name="PART_Popup" 
                                           AllowsTransparency="True" 
                                           Placement="Bottom" 
                                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Calendar x:Name="PART_Calendar"/>
                                    </Popup>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="StatutCellTemplate">
                <Border x:Name="BadgeBorder"
                        CornerRadius="12"
                        Padding="10,3"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="Dot"
                                 Width="6" Height="6"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="BadgeText"
                                   Text="{Binding StatusCalculated}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding StatusCalculated}" Value="En attente">
                        <Setter TargetName="BadgeBorder"
                                Property="Background" Value="#FEE2E2"/>
                        <Setter TargetName="BadgeText"
                                Property="Foreground" Value="#B91C1C"/>
                        <Setter TargetName="Dot"
                                Property="Fill" Value="#EF4444"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusCalculated}"
                                 Value="Partiellement payée">
                        <Setter TargetName="BadgeBorder"
                                Property="Background" Value="#E9D5FF"/>
                        <Setter TargetName="BadgeText"
                                Property="Foreground" Value="#7E22CE"/>
                        <Setter TargetName="Dot"
                                Property="Fill" Value="#A855F7"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusCalculated}" Value="Payée">
                        <Setter TargetName="BadgeBorder"
                                Property="Background" Value="#DCFCE7"/>
                        <Setter TargetName="BadgeText"
                                Property="Foreground" Value="#166534"/>
                        <Setter TargetName="Dot"
                                Property="Fill" Value="#22C55E"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <Style x:Key="BtnVoirStyle" TargetType="Button">
                <Setter Property="Height" Value="30"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Foreground" Value="#6C5CE7"/>
                <Setter Property="BorderBrush" Value="#6C5CE7"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd"
                                            Property="Background" Value="#6C5CE7"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd"
                                            Property="Background" Value="#5A4BD1"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="Bd"
                                            Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Stats -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="6" Margin="0,0,0,10">
            <!-- 1. Montant Total TTC -->
            <ctrls:KpiCard Title="Montant Total TTC" 
                           Value="{Binding TotalTTC}" 
                           TrendText="{Binding TotalTTCTrendText}"
                           Unit="MAD"
                           Icon="FileInvoiceDollar" 
                           IconColor="#2563EB" 
                           Margin="0,0,10,0"/>

            <!-- 2. Total Règlements -->
            <ctrls:KpiCard Title="Total Règlements" 
                           Value="{Binding TotalPayments}" 
                           TrendText="{Binding TotalPaymentsTrendText}"
                           Unit="MAD"
                           Icon="HandHoldingDollar" 
                           IconColor="#10B981" 
                           Margin="0,0,10,0"/>

            <!-- 3. Solde Total -->
            <ctrls:KpiCard Title="Solde Total" 
                           Value="{Binding TotalBalance}" 
                           TrendText="{Binding TotalBalanceTrendText}"
                           Unit="MAD"
                           Icon="ScaleUnbalanced" 
                           IconColor="#F59E0B" 
                           Margin="0,0,10,0"/>

            <!-- 4. Factures Payées -->
            <ctrls:KpiCard Title="Factures Payées" 
                           Value="{Binding PaidInvoicesCount}" 
                           TrendText="{Binding PaidInvoicesCountTrendText}"
                           Icon="CheckDouble" 
                           IconColor="#059669" 
                           Margin="0,0,10,0"/>

            <!-- 5. Factures Partiellement Payées -->
            <ctrls:KpiCard Title="Factures Part. Payées" 
                           Value="{Binding PartialInvoicesCount}" 
                           TrendText="{Binding PartialInvoicesCountTrendText}"
                           Icon="HourglassHalf" 
                           IconColor="#8B5CF6" 
                           Margin="0,0,10,0"/>

            <!-- 6. Fournisseurs Facturés -->
            <ctrls:KpiCard Title="Fournisseurs Facturés" 
                           Value="{Binding BilledSuppliersCount}" 
                           TrendText="{Binding BilledSuppliersCountTrendText}"
                           Icon="Users" 
                           IconColor="#4F46E5" 
                           Margin="0,0,0,0"/>
        </UniformGrid>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,20,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🏢" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Fournisseur" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Suppliers}" 
                              DisplayMemberPath="CompanyName"
                              SelectedItem="{Binding SelectedSupplier}"
                              Style="{StaticResource FilterComboStyle}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🔍" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="N° Facture" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding SearchInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FilterInputStyle}"
                             HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🎛️" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding StatusOptions}" 
                              SelectedItem="{Binding SelectedStatus}"
                              Style="{StaticResource FilterComboStyle}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Date" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DatePicker SelectedDate="{Binding SelectedDate}" 
                                Style="{StaticResource FilterDateStyle}"
                                HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Button Grid.Column="4" Command="{Binding ResetFiltersCommand}" 
                        Style="{StaticResource BtnResetStyle}"
                        VerticalAlignment="Bottom">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Réinitialiser"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>

        <!-- Main DataGrid -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Margin="0,20,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="15,10" Background="#FAFAFA" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <TextBlock Text="📋 Historique des Factures" FontSize="16" FontWeight="SemiBold" Foreground="#1A3A52"/>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredInvoices}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4F46E5"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Invoice.InvoiceDate, StringFormat='dd/MM/yyyy'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="N° Facture" Binding="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Invoice.Supplier.CompanyName}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Montant HT" Binding="{Binding Invoice.AmountHT, StringFormat='{}{0:N2} MAD'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TVA" Binding="{Binding Invoice.TaxAmount, StringFormat='{}{0:N2} MAD'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Montant TTC" Binding="{Binding Invoice.AmountTTC, StringFormat='{}{0:N2} MAD'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Règlement TTC" Binding="{Binding TotalPayments, StringFormat='{}{0:N2} MAD'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Solde" Binding="{Binding Balance, StringFormat='{}{0:N2} MAD'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Statut" Width="*" CellTemplate="{StaticResource StatutCellTemplate}"/>
                        <DataGridTemplateColumn Header="Actions" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="👁️ Voir" Command="{Binding DataContext.ViewInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource BtnVoirStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
