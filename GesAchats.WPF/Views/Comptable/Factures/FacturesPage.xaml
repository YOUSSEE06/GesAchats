<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.FacturesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Factures Fournisseurs">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:ConformityToVisibilityConverter x:Key="ConformityToVisibilityConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🧾" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Espace Comptable - Factures Fournisseurs" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1A3A52"/>
            </StackPanel>
        </Border>

        <!-- Toolbar & Filters -->
        <StackPanel Grid.Row="1" Margin="20,15">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="➕ Nouvelle Facture" Command="{Binding AddFactureCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="#2196F3" Foreground="White" Padding="15,8" Margin="0,0,10,0"/>
                <Button Content="🔄 Actualiser" Command="{Binding LoadFacturesCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Padding="15,8" Margin="0,0,10,0"/>
                <Button Content="📊 Statistiques" Style="{StaticResource MaterialDesignOutlinedButton}" Padding="15,8"/>
            </StackPanel>

            <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Fournisseur" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
                        <ComboBox Width="180" ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedSupplier}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Statut" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
                        <ComboBox Width="150" SelectedItem="{Binding SelectedStatus}">
                            <ComboBoxItem Content="Tous"/>
                            <ComboBoxItem Content="En attente"/>
                            <ComboBoxItem Content="Vérifiée"/>
                            <ComboBoxItem Content="Payée"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Période" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker Width="120" SelectedDate="{Binding StartDate}"/>
                            <TextBlock Text=" au " VerticalAlignment="Center" Margin="5,0"/>
                            <DatePicker Width="120" SelectedDate="{Binding EndDate}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="White" Margin="20,0,20,20" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding Factures}" SelectedItem="{Binding SelectedFacture}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0" RowHeight="45"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Facture" Binding="{Binding InvoiceNumber}" Width="120"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Supplier.Name}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="TTC" Binding="{Binding AmountTTC, StringFormat={}{0:N2} €}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Conformité" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="✅" Visibility="{Binding ConformityStatus, Converter={StaticResource ConformityToVisibilityConverter}, ConverterParameter=Conforme}"/>
                                        <TextBlock Text="⚠️" Visibility="{Binding ConformityStatus, Converter={StaticResource ConformityToVisibilityConverter}, ConverterParameter=EcartMineur}"/>
                                        <TextBlock Text="❌" Visibility="{Binding ConformityStatus, Converter={StaticResource ConformityToVisibilityConverter}, ConverterParameter=NonConforme}"/>
                                        <TextBlock Text="❓" Visibility="{Binding ConformityStatus, Converter={StaticResource ConformityToVisibilityConverter}, ConverterParameter=NonVerifiee}"/>
                                        <TextBlock Text="{Binding ConformityStatus}" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Statut" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" CornerRadius="12" Padding="8,2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Medium"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"/>
            </Grid>
        </Border>

        <!-- Footer / Actions -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="👁️ Voir détails" Command="{Binding ViewDetailsCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="✅ Vérifier conformité" Command="{Binding VerifyConformityCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"/>
                    <Button Content="💳 Enregistrer paiement" Command="{Binding RegisterPaymentCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Total en attente: " Foreground="#757575"/>
                    <TextBlock Text="{Binding PendingCount}" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="Montant: " Foreground="#757575"/>
                    <TextBlock Text="{Binding TotalPendingAmount, StringFormat={}{0:N2} €}" FontWeight="Bold" Foreground="#F44336"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
