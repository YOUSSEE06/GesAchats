<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.FacturesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:shared="clr-namespace:GesAchats.WPF.Resources.Shared"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Factures Fournisseurs">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <shared:EnhancedBooleanToVisibilityConverter x:Key="EnhancedBooleanToVisibilityConverter"/>
            <converters:ConformityToVisibilityConverter x:Key="ConformityToVisibilityConverter"/>
            <converters:StatusVisibilityMultiConverter x:Key="StatusVisibilityMultiConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:StatusVisibilityConverter x:Key="StatusVisibilityConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Zone des statistiques -->
        <UniformGrid Grid.Row="0" Columns="6" Margin="20,20,20,10">
            <!-- Total Factures -->
            <ctrls:KpiCard Title="Total Factures" 
                           Value="{Binding TotalFacturesCount}" 
                           TrendText="{Binding TotalFacturesCountTrendText}"
                           Icon="FileInvoice" 
                           IconColor="#2196F3" 
                           Margin="0,0,10,0"/>

            <!-- Montant Total TTC -->
            <ctrls:KpiCard Title="Montant Total TTC" 
                           Value="{Binding TotalAmount}" 
                           TrendText="{Binding TotalAmountTrendText}"
                           Unit="MAD"
                           Icon="FileInvoiceDollar" 
                           IconColor="#4CAF50" 
                           Margin="0,0,10,0"/>

            <!-- Factures Payées -->
            <ctrls:KpiCard Title="Factures Payées" 
                           Value="{Binding PaidInvoicesCount}" 
                           TrendText="{Binding PaidInvoicesCountTrendText}"
                           Icon="CheckDouble" 
                           IconColor="#2E7D32" 
                           Margin="0,0,10,0"/>

            <!-- Factures Partiellement Payées -->
            <ctrls:KpiCard Title="Factures Part. Payées" 
                           Value="{Binding PartialInvoicesCount}" 
                           TrendText="{Binding PartialInvoicesCountTrendText}"
                           Icon="HourglassHalf" 
                           IconColor="#FF9800" 
                           Margin="0,0,10,0"/>

            <!-- Factures En Attente -->
            <ctrls:KpiCard Title="Factures En Attente" 
                           Value="{Binding WaitingInvoicesCount}" 
                           TrendText="{Binding WaitingInvoicesCountTrendText}"
                           Icon="Clock" 
                           IconColor="#F44336" 
                           Margin="0,0,10,0"/>

            <!-- Solde Total -->
            <ctrls:KpiCard Title="Solde Total" 
                           Value="{Binding PendingAmount}" 
                           TrendText="{Binding PendingAmountTrendText}"
                           Unit="MAD"
                           Icon="ScaleUnbalanced" 
                           IconColor="#673AB7" 
                           Margin="0,0,0,0"/>
        </UniformGrid>

        <!-- Zone des filtres et boutons d'action -->
        <Grid Grid.Row="1" Margin="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filtres -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Fournisseur" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Width="160" ItemsSource="{Binding Suppliers}" DisplayMemberPath="CompanyName" SelectedItem="{Binding SelectedSupplier}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Statut" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Width="140" SelectedValue="{Binding SelectedStatus}" SelectedValuePath="Content">
                                <ComboBoxItem Content="Tous"/>
                                <ComboBoxItem Content="En attente"/>
                                <ComboBoxItem Content="Partiellement payée"/>
                                <ComboBoxItem Content="Payée"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Date" Style="{StaticResource LabelStyle}"/>
                            <DatePicker Width="110" SelectedDate="{Binding SelectedDate}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Recherche" Style="{StaticResource LabelStyle}"/>
                            <TextBox Width="180" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="26"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Réinitialiser" Command="{Binding ResetFiltersCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Grid.Column="1" Margin="15,0,0,0"/>
                </Grid>
            </Border>

            <!-- Boutons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="15,0,0,0"
                        Visibility="{Binding IsAdmin, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter='Inverse'}">
                <Button Content="Nouvelle Facture" Command="{Binding AddFactureCommand}" Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="20,10,20,20" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="24,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <TextBlock Text="Gestion des Factures" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                </Border>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding Factures}" 
                          SelectedItem="{Binding SelectedFacture}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          Background="Transparent" 
                          BorderThickness="0" 
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          MinWidth="1400"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4F46E5"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° FACTURE" Binding="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Width="Auto" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding Invoice.Supplier.CompanyName}" Width="Auto" MinWidth="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="BC" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="BcTextBlock" Margin="12,8">
                                        <Hyperlink Command="{Binding DataContext.ViewBCCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                   CommandParameter="{Binding Invoice.PurchaseOrderId}"
                                                   Foreground="#3B82F6">
                                            <Run Text="{Binding Invoice.PurchaseOrder.OrderNumber, TargetNullValue=''}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Invoice.PurchaseOrderId}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" TargetName="BcTextBlock"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BL" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="BlTextBlock" Margin="12,8">
                                        <Hyperlink Command="{Binding DataContext.ViewBLCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                   CommandParameter="{Binding Invoice.DeliveryNoteId}"
                                                   Foreground="#3B82F6">
                                            <Run Text="{Binding Invoice.DeliveryNote.DeliveryNumber, TargetNullValue=''}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Invoice.DeliveryNoteId}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" TargetName="BlTextBlock"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="JUSTIFICATIF" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📎" 
                                            Command="{Binding DataContext.ViewFileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Invoice.FilePath}"
                                            Visibility="{Binding Invoice.FilePath, Converter={StaticResource StringToVisibilityConverter}}"
                                            Margin="12,8"
                                            Padding="10,4"
                                            FontSize="14">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="DATE" Binding="{Binding Invoice.InvoiceDate, StringFormat=dd/MM/yyyy}" Width="Auto" MinWidth="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="TTC" Binding="{Binding Invoice.AmountTTC, StringFormat={}{0:N2} MAD}" Width="Auto" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="STATUT" Width="Auto" MinWidth="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10,4" CornerRadius="20" HorizontalAlignment="Left" Margin="12,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCalculated}" Value="En attente">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCalculated}" Value="Payée">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCalculated}" Value="Partiellement payée">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusCalculated}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusCalculated}" Value="En attente">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusCalculated}" Value="Payée">
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusCalculated}" Value="Partiellement payée">
                                                            <Setter Property="Foreground" Value="#F57C00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ACTION" Width="Auto" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="12,8">
                                        <Button Content="Voir" 
                                                Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Padding="10,4"
                                                Margin="0,0,6,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" 
                                                                        CornerRadius="20"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Payer" 
                                                Command="{Binding DataContext.RegisterPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Padding="10,4">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource StatusVisibilityMultiConverter}">
                                                    <Binding Path="StatusCalculated"/>
                                                    <Binding Path="DataContext.IsAdmin" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                    <Setter Property="Foreground" Value="#059669"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" 
                                                                        CornerRadius="20"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#A7F3D0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</Page>
