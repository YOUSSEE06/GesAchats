<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.FacturesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:shared="clr-namespace:GesAchats.WPF.Resources.Shared"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Factures Fournisseurs">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <shared:EnhancedBooleanToVisibilityConverter x:Key="EnhancedBooleanToVisibilityConverter"/>
            <converters:ConformityToVisibilityConverter x:Key="ConformityToVisibilityConverter"/>
            <converters:StatusVisibilityMultiConverter x:Key="StatusVisibilityMultiConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:StatusVisibilityConverter x:Key="StatusVisibilityConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Zone des statistiques -->
        <UniformGrid Grid.Row="0" Columns="6" Margin="20,20,20,10">
            <!-- Total Factures -->
            <ctrls:KpiCard Title="Total Factures" 
                           Value="{Binding TotalFacturesCount}" 
                           TrendText="{Binding TotalFacturesCountTrendText}"
                           Icon="FileInvoice" 
                           IconColor="#2196F3" 
                           Margin="0,0,10,0"/>

            <!-- Montant Total TTC -->
            <ctrls:KpiCard Title="Montant Total TTC" 
                           Value="{Binding TotalAmount}" 
                           TrendText="{Binding TotalAmountTrendText}"
                           Unit="MAD"
                           Icon="FileInvoiceDollar" 
                           IconColor="#4CAF50" 
                           Margin="0,0,10,0"/>

            <!-- Factures Payées -->
            <ctrls:KpiCard Title="Factures Payées" 
                           Value="{Binding PaidInvoicesCount}" 
                           TrendText="{Binding PaidInvoicesCountTrendText}"
                           Icon="CheckDouble" 
                           IconColor="#2E7D32" 
                           Margin="0,0,10,0"/>

            <!-- Factures Partiellement Payées -->
            <ctrls:KpiCard Title="Factures Part. Payées" 
                           Value="{Binding PartialInvoicesCount}" 
                           TrendText="{Binding PartialInvoicesCountTrendText}"
                           Icon="HourglassHalf" 
                           IconColor="#FF9800" 
                           Margin="0,0,10,0"/>

            <!-- Factures En Attente -->
            <ctrls:KpiCard Title="Factures En Attente" 
                           Value="{Binding WaitingInvoicesCount}" 
                           TrendText="{Binding WaitingInvoicesCountTrendText}"
                           Icon="Clock" 
                           IconColor="#F44336" 
                           Margin="0,0,10,0"/>

            <!-- Solde Total -->
            <ctrls:KpiCard Title="Solde Total" 
                           Value="{Binding PendingAmount}" 
                           TrendText="{Binding PendingAmountTrendText}"
                           Unit="MAD"
                           Icon="ScaleUnbalanced" 
                           IconColor="#673AB7" 
                           Margin="0,0,0,0"/>
        </UniformGrid>

        <!-- Zone des filtres et boutons d'action -->
        <Grid Grid.Row="1" Margin="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filtres -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Fournisseur" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Width="160" ItemsSource="{Binding Suppliers}" DisplayMemberPath="CompanyName" SelectedItem="{Binding SelectedSupplier}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Statut" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Width="140" SelectedValue="{Binding SelectedStatus}" SelectedValuePath="Content">
                                <ComboBoxItem Content="Tous"/>
                                <ComboBoxItem Content="En attente"/>
                                <ComboBoxItem Content="Partiellement payée"/>
                                <ComboBoxItem Content="Payée"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Date" Style="{StaticResource LabelStyle}"/>
                            <DatePicker Width="110" SelectedDate="{Binding SelectedDate}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Recherche" Style="{StaticResource LabelStyle}"/>
                            <TextBox Width="180" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="26"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Réinitialiser" Command="{Binding ResetFiltersCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Grid.Column="1" Margin="15,0,0,0"/>
                </Grid>
            </Border>

            <!-- Boutons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="15,0,0,0"
                        Visibility="{Binding IsAdmin, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter='Inverse'}">
                <Button Content="Nouvelle Facture" Command="{Binding AddFactureCommand}" Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="3" Background="White" Margin="20,10,20,20" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding Factures}" SelectedItem="{Binding SelectedFacture}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0" RowHeight="45"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Facture" Binding="{Binding Invoice.ExternalInvoiceNumber, TargetNullValue='-'}" Width="150"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Invoice.Supplier.CompanyName}" Width="*"/>
                        
                        <DataGridTemplateColumn Header="BC" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="BcTextBlock" Margin="5,0">
                                        <Hyperlink Command="{Binding DataContext.ViewBCCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                   CommandParameter="{Binding Invoice.PurchaseOrderId}">
                                            <Run Text="{Binding Invoice.PurchaseOrder.OrderNumber, TargetNullValue=''}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Invoice.PurchaseOrderId}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" TargetName="BcTextBlock"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BL" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="BlTextBlock" Margin="5,0">
                                        <Hyperlink Command="{Binding DataContext.ViewBLCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                   CommandParameter="{Binding Invoice.DeliveryNoteId}">
                                            <Run Text="{Binding Invoice.DeliveryNote.DeliveryNumber, TargetNullValue=''}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Invoice.DeliveryNoteId}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" TargetName="BlTextBlock"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Justificatif" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📎" Style="{StaticResource MaterialDesignFlatButton}" 
                                            Command="{Binding DataContext.ViewFileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Invoice.FilePath}"
                                            Visibility="{Binding Invoice.FilePath, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Date" Binding="{Binding Invoice.InvoiceDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        
                        <DataGridTextColumn Header="TTC" Binding="{Binding Invoice.AmountTTC, StringFormat={}{0:N2} MAD}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Statut" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="8,2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatusCalculated}" Foreground="White" FontSize="11" FontWeight="Medium"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Action" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Voir" Style="{StaticResource MaterialDesignFlatButton}" 
                                                Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                        <Button Content="Payer" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#2196F3"
                                                Command="{Binding DataContext.RegisterPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource StatusVisibilityMultiConverter}">
                                                    <Binding Path="StatusCalculated"/>
                                                    <Binding Path="DataContext.IsAdmin" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"/>
            </Grid>
        </Border>
    </Grid>
</Page>
