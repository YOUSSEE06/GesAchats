<Page x:Class="GesAchats.WPF.Views.Comptable.Factures.FacturesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Comptable.Factures"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:shared="clr-namespace:GesAchats.WPF.Resources.Shared"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Factures Fournisseurs">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <shared:EnhancedBooleanToVisibilityConverter x:Key="EnhancedBooleanToVisibilityConverter"/>
            <converters:ConformityToVisibilityConverter x:Key="ConformityToVisibilityConverter"/>
            <converters:StatusVisibilityMultiConverter x:Key="StatusVisibilityMultiConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:StatusVisibilityConverter x:Key="StatusVisibilityConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <Style x:Key="BtnResetStyle" TargetType="Button">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="Background" Value="#6C5CE7"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontSize" Value="13.5"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" 
                                    Background="{TemplateBinding Background}" 
                                    BorderThickness="0" 
                                    CornerRadius="19" 
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" 
                                            Property="Background" 
                                            Value="#5A4BD1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" 
                                            Property="Background" 
                                            Value="#4A3BBF"/>
                                    <Setter TargetName="Bd" 
                                            Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnPrimaryStyle" TargetType="Button">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#6C5CE7"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Foreground" Value="#6C5CE7"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnPrimaryGreenStyle" TargetType="Button" BasedOn="{StaticResource BtnPrimaryStyle}">
                <Setter Property="BorderBrush" Value="#10B981"/>
                <Setter Property="Foreground" Value="#10B981"/>
            </Style>

            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Focusable="False" 
                                              HorizontalScrollBarVisibility="Hidden" 
                                              VerticalScrollBarVisibility="Hidden"
                                              VerticalAlignment="Center"
                                              Margin="12,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton" 
                                                  Grid.Column="2" 
                                                  Focusable="False" 
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite" 
                                                      IsHitTestVisible="False" 
                                                      Margin="12,0,30,0" 
                                                      VerticalAlignment="Center" 
                                                      Content="{TemplateBinding SelectionBoxItem}" 
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                    <TextBox x:Name="PART_EditableTextBox" 
                                              Style="{x:Null}" 
                                              BorderThickness="0" 
                                              Background="Transparent" 
                                              Padding="12,0" 
                                              VerticalAlignment="Center" 
                                              Focusable="True" 
                                              IsReadOnly="{TemplateBinding IsReadOnly}" 
                                              Visibility="Hidden"/>
                                    <Path x:Name="Arrow" 
                                          Grid.Column="2" 
                                          Data="M0,0 L4,4 L8,0 Z" 
                                          Fill="#6C5CE7" 
                                          HorizontalAlignment="Right" 
                                          Margin="10,0" 
                                          VerticalAlignment="Center"/>
                                    <Popup x:Name="Popup" 
                                           AllowsTransparency="True" 
                                           Placement="Bottom" 
                                           StaysOpen="False" 
                                           Focusable="False" 
                                           IsOpen="{TemplateBinding IsDropDownOpen}" 
                                           PopupAnimation="Slide">
                                        <Border x:Name="DropDownBorder" 
                                                Background="White" 
                                                BorderBrush="#D0CDE8" 
                                                BorderThickness="1" 
                                                CornerRadius="8" 
                                                Padding="0">
                                            <ScrollViewer Margin="0" 
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                                KeyboardNavigation.DirectionalNavigation="Continue"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterDateStyle" TargetType="DatePicker">
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePickerTextBox 
                                        x:Name="PART_TextBox" 
                                        Grid.Column="0" 
                                        Foreground="{TemplateBinding Foreground}" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        VerticalContentAlignment="Center" 
                                        Padding="12,0" 
                                        FontSize="{TemplateBinding FontSize}"/>
                                    <Button x:Name="PART_Button" 
                                            Grid.Column="1" 
                                            Width="32" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Cursor="Hand" 
                                            Focusable="False">
                                        <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                              Stroke="#6C5CE7" StrokeThickness="1.5" 
                                              StrokeLineJoin="Round" 
                                              StrokeStartLineCap="Round" 
                                              StrokeEndLineCap="Round" 
                                              Width="16" Height="16" 
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Popup x:Name="PART_Popup" 
                                           AllowsTransparency="True" 
                                           Placement="Bottom" 
                                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Calendar x:Name="PART_Calendar"/>
                                    </Popup>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <Style x:Key="PaginationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="#64748B"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Width" Value="36"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#6C5CE7"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#6C5CE7"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zone des statistiques -->
        <UniformGrid Grid.Row="0" Columns="6" Margin="20,20,20,10">
            <!-- Total Factures -->
            <ctrls:KpiCard Title="Total Factures" 
                           Value="{Binding TotalFacturesCount}" 
                           TrendText="{Binding TotalFacturesCountTrendText}"
                           Icon="FileInvoice" 
                           IconColor="#2196F3" 
                           Margin="0,0,10,0"/>

            <!-- Montant Total TTC -->
            <ctrls:KpiCard Title="Montant Total TTC" 
                           Value="{Binding TotalAmount}" 
                           TrendText="{Binding TotalAmountTrendText}"
                           Unit="MAD"
                           Icon="FileInvoiceDollar" 
                           IconColor="#4CAF50" 
                           Margin="0,0,10,0"/>

            <!-- Factures Payées -->
            <ctrls:KpiCard Title="Factures Payées" 
                           Value="{Binding PaidInvoicesCount}" 
                           TrendText="{Binding PaidInvoicesCountTrendText}"
                           Icon="CheckDouble" 
                           IconColor="#2E7D32" 
                           Margin="0,0,10,0"/>

            <!-- Factures Partiellement Payées -->
            <ctrls:KpiCard Title="Factures Part. Payées" 
                           Value="{Binding PartialInvoicesCount}" 
                           TrendText="{Binding PartialInvoicesCountTrendText}"
                           Icon="HourglassHalf" 
                           IconColor="#8B5CF6" 
                           Margin="0,0,10,0"/>

            <!-- Factures En Attente -->
            <ctrls:KpiCard Title="Factures En Attente" 
                           Value="{Binding WaitingInvoicesCount}" 
                           TrendText="{Binding WaitingInvoicesCountTrendText}"
                           Icon="Clock" 
                           IconColor="#F44336" 
                           Margin="0,0,10,0"/>

            <!-- Solde Total -->
            <ctrls:KpiCard Title="Solde Total" 
                           Value="{Binding PendingAmount}" 
                           TrendText="{Binding PendingAmountTrendText}"
                           Unit="MAD"
                           Icon="ScaleUnbalanced" 
                           IconColor="#673AB7" 
                           Margin="0,0,0,0"/>
        </UniformGrid>

        <!-- Zone des filtres et boutons d'action -->
        <Grid Grid.Row="1" Margin="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filtres -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="🏢" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Fournisseur" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding Suppliers}" 
                                  DisplayMemberPath="CompanyName" 
                                  SelectedItem="{Binding SelectedSupplier}"
                                  Style="{StaticResource FilterComboStyle}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="🎛️" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox SelectedValue="{Binding SelectedStatus}" 
                                  SelectedValuePath="Content"
                                  Style="{StaticResource FilterComboStyle}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Tous"/>
                            <ComboBoxItem Content="En attente"/>
                            <ComboBoxItem Content="Partiellement payée"/>
                            <ComboBoxItem Content="Payée"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Date" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DatePicker SelectedDate="{Binding SelectedDate}" 
                                    Style="{StaticResource FilterDateStyle}"
                                    HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="🔍" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Recherche" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource FilterInputStyle}"
                                 HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="4" Command="{Binding ResetFiltersCommand}" 
                            Style="{StaticResource BtnResetStyle}"
                            VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Réinitialiser"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Boutons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="15,0,0,0"
                        Visibility="{Binding IsAdmin, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter='Inverse'}">
                <Button Content="Nouvelle Facture" Command="{Binding AddFactureCommand}" Style="{StaticResource BtnPrimaryGreenStyle}"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="20,10,20,10" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="24,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <TextBlock Text="Gestion des Factures" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                </Border>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding Factures}" 
                          SelectedItem="{Binding SelectedFacture}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          Background="Transparent" 
                          BorderThickness="0" 
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          MinWidth="1400"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4F46E5"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° FACTURE" Binding="{Binding ExternalInvoiceNumber, TargetNullValue='-'}" Width="Auto" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding SupplierName}" Width="Auto" MinWidth="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTemplateColumn Header="BC" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="BcTextBlock" Margin="12,8">
                                        <Hyperlink Command="{Binding DataContext.ViewBCCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                   CommandParameter="{Binding PurchaseOrderId, Mode=OneWay}"
                                                   Foreground="#3B82F6">
                                            <Run Text="{Binding PurchaseOrderNumber, Mode=OneWay, TargetNullValue=''}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding PurchaseOrderId, Mode=OneWay}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" TargetName="BcTextBlock"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BL" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="BlTextBlock" Margin="12,8">
                                        <Hyperlink Command="{Binding DataContext.ViewBLCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                   CommandParameter="{Binding DeliveryNoteId, Mode=OneWay}"
                                                   Foreground="#3B82F6">
                                            <Run Text="{Binding DeliveryNoteNumber, Mode=OneWay, TargetNullValue=''}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding DeliveryNoteId, Mode=OneWay}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" TargetName="BlTextBlock"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="JUSTIFICATIF" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📎" 
                                            Command="{Binding DataContext.ViewFileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding FilePath}"
                                            Visibility="{Binding FilePath, Converter={StaticResource StringToVisibilityConverter}}"
                                            Margin="12,8"
                                            Padding="10,4"
                                            FontSize="14">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="DATE" Binding="{Binding InvoiceDate, StringFormat=dd/MM/yyyy}" Width="Auto" MinWidth="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="TTC" Binding="{Binding AmountTTC, StringFormat={}{0:N2} MAD}" Width="Auto" MinWidth="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="STATUT" Width="Auto" MinWidth="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10,4" CornerRadius="20" HorizontalAlignment="Left" Margin="12,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCalculated}" Value="En attente">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCalculated}" Value="Payée">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCalculated}" Value="Partiellement payée">
                                                        <Setter Property="Background" Value="#E9D5FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusCalculated}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusCalculated}" Value="En attente">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusCalculated}" Value="Payée">
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusCalculated}" Value="Partiellement payée">
                                                            <Setter Property="Foreground" Value="#7E22CE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ACTION" Width="Auto" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="12,8">
                                        <Button Content="Voir" 
                                                Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Padding="10,4"
                                                Margin="0,0,6,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" 
                                                                        CornerRadius="20"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Payer" 
                                                Command="{Binding DataContext.RegisterPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Padding="10,4">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource StatusVisibilityMultiConverter}">
                                                    <Binding Path="StatusCalculated"/>
                                                    <Binding Path="DataContext.IsAdmin" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                    <Setter Property="Foreground" Value="#059669"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" 
                                                                        CornerRadius="20"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#A7F3D0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Grid.Row="1"/>
            </Grid>
        </Border>

        <!-- Pagination -->
        <Border Grid.Row="4" Style="{StaticResource ModernCard}" Margin="20,0,20,20" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding PaginationInfo}"
                           Foreground="#64748B"
                           FontSize="14"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding FirstPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding CanGoToFirstPage}">
                        <TextBlock Text="«" FontSize="16" FontWeight="Bold"/>
                    </Button>
                    <Button Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding CanGoToPreviousPage}">
                        <TextBlock Text="‹" FontSize="16" FontWeight="Bold"/>
                    </Button>
                    <Button Command="{Binding NextPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            Margin="6,0,6,0"
                            IsEnabled="{Binding CanGoToNextPage}">
                        <TextBlock Text="›" FontSize="16" FontWeight="Bold"/>
                    </Button>
                    <Button Command="{Binding LastPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            IsEnabled="{Binding CanGoToLastPage}">
                        <TextBlock Text="»" FontSize="16" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
