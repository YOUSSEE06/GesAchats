<Window x:Class="GesAchats.WPF.Views.Comptable.ComptableShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GesAchats - Espace Comptable" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Comptable/ComptableStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2C4E68"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LogoutButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#F44336"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#F44336"/>
                <Setter Property="Padding" Value="20,10"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F44336"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A3A52">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,40">
                    <TextBlock Text="ESPACE" Foreground="#2196F3" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="COMPTABLE" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Separator Margin="0,30,0,0" Background="#2C4E68"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="10,0">
                    <Button Content="🧾 Factures" Click="NavigateToFactures" Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="🏢 Fournisseurs" Click="NavigateToFournisseurs" Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="📊 Dashboard" Click="NavigateToDashboard" Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="💳 Suivi Règlements" Click="NavigateToReglements" Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="📈 Suivi Comptable" Click="NavigateToInvoicePaymentTracking" Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="10,20">
                    <Separator Margin="0,0,0,15" Background="#2C4E68"/>
                    <Button Content="Déconnexion" Click="Logout" Style="{StaticResource LogoutButtonStyle}"/>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="#F5F6F7">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
