<Window x:Class="GesAchats.WPF.Views.Components.AlertModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Alerte"
        Height="240"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Shared/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- Modal Card -->
        <Border Width="380"
                Height="200"
                Background="White"
                CornerRadius="10"
                Padding="28"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header with Icon -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <!-- Success Icon -->
                    <Border x:Name="SuccessIconBorder"
                            Width="48"
                            Height="48"
                            Background="#E8F5E9"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <TextBlock Text="✓"
                                   FontSize="26"
                                   Foreground="#4CAF50"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Warning Icon -->
                    <Border x:Name="WarningIconBorder"
                            Width="48"
                            Height="48"
                            Background="#FFF3E0"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <TextBlock Text="⚠"
                                   FontSize="26"
                                   Foreground="#FF9800"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Error Icon -->
                    <Border x:Name="ErrorIconBorder"
                            Width="48"
                            Height="48"
                            Background="#FFEBEE"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <TextBlock Text="✕"
                                   FontSize="26"
                                   Foreground="#F44336"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Message -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="14"
                           Foreground="#4B5563"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>

                <!-- OK Button -->
                <Button Grid.Row="2"
                        Content="OK"
                        Padding="32,10"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="14"
                        BorderThickness="0"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AlertType, RelativeSource={RelativeSource AncestorType=Window}}" Value="Success">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#4F46E5" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AlertType, RelativeSource={RelativeSource AncestorType=Window}}" Value="Warning">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF9800" Offset="0"/>
                                                <GradientStop Color="#F57C00" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AlertType, RelativeSource={RelativeSource AncestorType=Window}}" Value="Error">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F44336" Offset="0"/>
                                                <GradientStop Color="#D32F2F" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
