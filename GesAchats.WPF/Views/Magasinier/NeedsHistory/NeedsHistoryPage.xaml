<Page x:Class="GesAchats.WPF.Views.Magasinier.NeedsHistory.NeedsHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Magasinier.NeedsHistory"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      Title="Historique des Besoins"
      d:DesignHeight="700" d:DesignWidth="1200">
    
    <Page.Resources>
        <Style x:Key="TextCenterStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- Base Action Button Style -->
        <Style x:Key="ActionButtonBase" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinWidth" Value="80"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>
        
        <!-- Details Button Style -->
        <Style x:Key="DetailsButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBase}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Annuler Button Style -->
        <Style x:Key="AnnulerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBase}">
            <Setter Property="Background" Value="#FF5722"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E64A19"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Reactiver Button Style -->
        <Style x:Key="ReactiverButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBase}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Supprimer Button Style -->
        <Style x:Key="SupprimerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBase}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Boolean to Visibility Converter (using existing one) -->
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="HISTORIQUE DES BESOINS" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Statistics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:KpiCard Grid.Column="0"
                Title="Total des Besoins"
                Value="{Binding TotalNeeds}"
                TrendText="{Binding TotalNeedsTrendText}"
                Icon="Box"
                IconColor="#3B82F6"
                Margin="0,0,10,0"/>

            <controls:KpiCard Grid.Column="1"
                Title="Besoins Transmis"
                Value="{Binding TransmittedNeeds}"
                TrendText="{Binding TransmittedNeedsTrendText}"
                Icon="PaperPlane"
                IconColor="#2196F3"
                Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="2"
                Title="Besoins En cours"
                Value="{Binding InProgressNeeds}"
                TrendText="{Binding InProgressNeedsTrendText}"
                Icon="Clock"
                IconColor="#FFC107"
                Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="3"
                Title="Besoins Annulés"
                Value="{Binding CancelledNeeds}"
                TrendText="{Binding CancelledNeedsTrendText}"
                Icon="TimesCircle"
                IconColor="#F44336"
                Margin="10,0,0,0"/>
        </Grid>

        <!-- Filtres Rapides -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,20">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Padding="5" Margin="0,0,10,0" Tag="N° Besoin..."/>
            <ComboBox ItemsSource="{Binding StatusFilterOptions}" SelectedItem="{Binding SelectedStatus}" Width="150" Padding="5" Margin="0,0,10,0"/>
            <DatePicker SelectedDate="{Binding ExactDate}" Width="150" Padding="5"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Needs}" AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                  RowHeight="70" GridLinesVisibility="None" HeadersVisibility="Column"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N° Demande" Binding="{Binding Need.NumeroBesoin}" Width="150" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Need.RequestedAt, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Nb Articles" Binding="{Binding ArticleCount}" Width="120" ElementStyle="{StaticResource TextCenterStyle}"/>
                <DataGridTemplateColumn Header="Statut" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="400">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Details Button (Always Visible) -->
                                <Button Content="Détails" 
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource DetailsButtonStyle}"/>
                                
                                <!-- Annuler Button (Visible for En Cours) -->
                                <Button Content="Annuler" 
                                        Command="{Binding DataContext.AnnulerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource AnnulerButtonStyle}"
                                        Visibility="{Binding IsStatusEnCours, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                
                                <!-- Reactiver Button (Visible for Annulé) -->
                                <Button Content="Réactiver" 
                                        Command="{Binding DataContext.ReactiverCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource ReactiverButtonStyle}"
                                        Visibility="{Binding IsStatusAnnule, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                
                                <!-- Supprimer Button (Visible for not Transmis) -->
                                <Button Content="Supprimer" 
                                        Command="{Binding DataContext.SupprimerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource SupprimerButtonStyle}"
                                        Visibility="{Binding IsNotTransmis, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" d:Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Chargement de l'historique..." Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
