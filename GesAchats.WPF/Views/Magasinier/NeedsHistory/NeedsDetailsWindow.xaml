<Window x:Class="GesAchats.WPF.Views.Magasinier.NeedsHistory.NeedsDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Détails du Besoin" Height="800" Width="700"
        WindowStartupLocation="CenterOwner" Background="#F4F6F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,20">
            <Button Content="← Retour" Click="Close_Click" DockPanel.Dock="Left" Padding="10,5" Background="Transparent" BorderThickness="0" Foreground="#566573"/>
            <TextBlock Text="{Binding Need.NumeroBesoin, StringFormat='Détails Besoin: {0}'}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Informations Générales -->
                <GroupBox Header="INFORMATIONS GÉNÉRALES" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="N°Besoin:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Need.NumeroBesoin}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Date création:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Need.RequestedAt, StringFormat=dd/MM/yyyy HH:mm}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Créé par:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Need.RequestedBy.FullName}" Margin="0,0,0,10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Statut:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Need.Status}" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Date transmission:" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Need.DateTransmission, StringFormat=dd/MM/yyyy HH:mm}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Articles Demandés -->
                <GroupBox Header="ARTICLES DEMANDÉS" Margin="0,0,0,15" Padding="10">
                    <DataGrid ItemsSource="{Binding Details}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Désignation" Binding="{Binding Product.Designation}" Width="*"/>
                            <DataGridTextColumn Header="Qty Demandée" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Unité" Binding="{Binding Product.Unit}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="📥 Exporter PDF" Command="{Binding ExportPdfCommand}" Padding="15,8" Margin="0,0,10,0" Background="#1ABC9C" Foreground="White" BorderThickness="0"/>
            <Button Content="Supprimer le Besoin" Command="{Binding CancelNeedCommand}" Padding="15,8" Background="#F44336" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
