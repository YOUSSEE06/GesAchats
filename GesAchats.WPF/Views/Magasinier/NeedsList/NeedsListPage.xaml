<Page x:Class="GesAchats.WPF.Views.Magasinier.NeedsList.NeedsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Créer une Liste de Besoins">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Liste des Articles -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock Text="SÉLECTION DES ARTICLES" DockPanel.Dock="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8" Tag="🔍 Recherche article..."/>
                    <Button Content="➕ Ajouter un produit" Command="{Binding AddProductCommand}" 
                            HorizontalAlignment="Right" Padding="10,5" Margin="0,0,5,0"
                            Background="{StaticResource NewProductBrush}" Foreground="White" BorderThickness="0"/>
                </Grid>

                <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0" RowHeight="40" GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Sel." Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                        <DataGridTextColumn Header="Désignation" Binding="{Binding Product.Designation}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding Product.CurrentStock}" Width="60" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Qté à Cmd" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding QuantityToOrder, UpdateSourceTrigger=PropertyChanged}" 
                                             Padding="5,2" HorizontalContentAlignment="Right"
                                             IsEnabled="{Binding IsSelected}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Unité" Binding="{Binding Product.Unit}" Width="60" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Récapitulatif à droite -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <DockPanel>
                <TextBlock Text="RÉCAPITULATIF" DockPanel.Dock="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <StackPanel DockPanel.Dock="Bottom">
                    <Button Content="✓ Transmettre au Resp. Achats" Command="{Binding TransmitCommand}" 
                            Padding="15" Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="Annuler" Command="{Binding CancelCommand}" 
                            Padding="10" Background="Transparent" BorderThickness="1" BorderBrush="#DDD"/>
                </StackPanel>

                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Articles sélectionnés :" Foreground="Gray"/>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Margin="0,5">
                                            <Run Text="• "/>
                                            <Run Text="{Binding Product.Designation}"/>
                                            <Run Text=" : "/>
                                            <Run Text="{Binding QuantityToOrder}" FontWeight="Bold"/>
                                            <Run Text="{Binding Product.Unit}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>
