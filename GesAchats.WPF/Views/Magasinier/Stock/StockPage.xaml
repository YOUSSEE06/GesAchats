<Page x:Class="GesAchats.WPF.Views.Magasinier.Stock.StockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d"
      Title="Gestion du Stock">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Actions -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="250" Padding="8" Margin="0,0,10,0"
                         Tag="🔍 Recherche article..."/>
                
                <ComboBox ItemsSource="{Binding Filters}" 
                          SelectedItem="{Binding SelectedFilter}"
                          Width="150" Padding="8"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="➕ Nouveau Produit" Command="{Binding AddProductCommand}" 
                        Padding="15,8" Margin="0,0,10,0" Background="{StaticResource NewProductBrush}" Foreground="White" FontWeight="Bold"/>
                <Button Content="➕ Créer un Besoin" Command="{Binding CreateNeedCommand}" 
                        Padding="15,8" Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </DockPanel>

        <!-- Statistics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:KpiCard Grid.Column="0" 
                              Title="Total des Articles" 
                              Value="{Binding TotalArticles}"
                              TrendText="{Binding TotalArticlesTrendText}"
                              Icon="Box"
                              IconColor="#3B82F6"
                              Margin="0,0,10,0"/>

            <controls:KpiCard Grid.Column="1" 
                              Title="Articles Normaux" 
                              Value="{Binding NormalArticles}"
                              TrendText="{Binding NormalArticlesTrendText}"
                              Icon="CheckCircle"
                              IconColor="#4CAF50"
                              Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="2" 
                              Title="Articles Sous Minimum" 
                              Value="{Binding LowStockArticles}"
                              TrendText="{Binding LowStockArticlesTrendText}"
                              Icon="ExclamationTriangle"
                              IconColor="#FFC107"
                              Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="3" 
                              Title="Articles en Rupture de Stock" 
                              Value="{Binding OutOfStockArticles}"
                              TrendText="{Binding OutOfStockArticlesTrendText}"
                              Icon="TimesCircle"
                              IconColor="#F44336"
                              Margin="10,0,0,0"/>
        </Grid>

        <!-- Stock Table -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="24,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <TextBlock Text="Gestion du Stock" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                </Border>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding Products}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          Background="Transparent" 
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          MinWidth="1100"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4F46E5"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N°" Binding="{Binding Product.Id}" Width="50" MinWidth="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DÉSIGNATION" Binding="{Binding Product.Designation}" Width="*" MinWidth="250" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="STOCK ACTUEL" Binding="{Binding Product.CurrentStock}" Width="100" MinWidth="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SEUIL MIN" Binding="{Binding Product.MinimumStock}" Width="100" MinWidth="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="UNITÉ" Binding="{Binding Product.Unit}" Width="80" MinWidth="90" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="ÉTAT" Width="80" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatusIcon}" 
                                                   Foreground="{Binding StatusColor}" 
                                                   FontSize="20" 
                                                   VerticalAlignment="Center" 
                                                   ToolTip="{Binding StatusColor}"
                                                   Padding="12,8"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer Info -->
        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total: "/>
                    <TextBlock Text="{Binding Products.Count}" FontWeight="Bold"/>
                    <TextBlock Text=" articles affichés" Margin="0,0,20,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Page>
