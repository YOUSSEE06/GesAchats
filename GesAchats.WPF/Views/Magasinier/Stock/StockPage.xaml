<Page x:Class="GesAchats.WPF.Views.Magasinier.Stock.StockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d"
      Title="Gestion du Stock">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Actions -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="250" Padding="8" Margin="0,0,10,0"
                         Tag="🔍 Recherche article..."/>
                
                <ComboBox ItemsSource="{Binding Filters}" 
                          SelectedItem="{Binding SelectedFilter}"
                          Width="150" Padding="8"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="➕ Nouveau Produit" Command="{Binding AddProductCommand}" 
                        Padding="15,8" Margin="0,0,10,0" Background="{StaticResource NewProductBrush}" Foreground="White" FontWeight="Bold"/>
                <Button Content="➕ Créer un Besoin" Command="{Binding CreateNeedCommand}" 
                        Padding="15,8" Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </DockPanel>

        <!-- Statistics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:KpiCard Grid.Column="0" 
                              Title="Total des Articles" 
                              Value="{Binding TotalArticles}"
                              Icon="Box"
                              IconColor="#3B82F6"
                              Margin="0,0,10,0"/>

            <controls:KpiCard Grid.Column="1" 
                              Title="Articles Normaux" 
                              Value="{Binding NormalArticles}"
                              Icon="CheckCircle"
                              IconColor="#4CAF50"
                              Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="2" 
                              Title="Articles Sous Minimum" 
                              Value="{Binding LowStockArticles}"
                              Icon="ExclamationTriangle"
                              IconColor="#FFC107"
                              Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="3" 
                              Title="Articles en Rupture de Stock" 
                              Value="{Binding OutOfStockArticles}"
                              Icon="TimesCircle"
                              IconColor="#F44336"
                              Margin="10,0,0,0"/>
        </Grid>

        <!-- Stock Table -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" 
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                  RowHeight="40" SelectionMode="Single" GridLinesVisibility="None"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N°" Binding="{Binding Product.Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Désignation" Binding="{Binding Product.Designation}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stock Actuel" Binding="{Binding Product.CurrentStock}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Seuil Min" Binding="{Binding Product.MinimumStock}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Unité" Binding="{Binding Product.Unit}" Width="80" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="État" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatusIcon}" Foreground="{Binding StatusColor}" 
                                           FontSize="16" VerticalAlignment="Center" ToolTip="{Binding StatusColor}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer Info -->
        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total: "/>
                    <TextBlock Text="{Binding Products.Count}" FontWeight="Bold"/>
                    <TextBlock Text=" articles affichés" Margin="0,0,20,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Page>
