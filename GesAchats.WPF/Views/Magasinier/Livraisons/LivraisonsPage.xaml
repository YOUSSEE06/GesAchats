<Page x:Class="GesAchats.WPF.Views.Magasinier.Livraisons.LivraisonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Magasinier.Livraisons"
      xmlns:shared="clr-namespace:GesAchats.WPF.Resources.Shared"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Réception des Bons de Livraison">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
                <ResourceDictionary Source="../../../Resources/Shared/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <shared:BindingProxy x:Key="Proxy" Data="{Binding}" />
            
            <Style x:Key="BtnResetStyle" TargetType="Button">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="Background" Value="#6C5CE7"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontSize" Value="13.5"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" 
                                    Background="{TemplateBinding Background}" 
                                    BorderThickness="0" 
                                    CornerRadius="19" 
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" 
                                            Property="Background" 
                                            Value="#5A4BD1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" 
                                            Property="Background" 
                                            Value="#4A3BBF"/>
                                    <Setter TargetName="Bd" 
                                            Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Focusable="False" 
                                              HorizontalScrollBarVisibility="Hidden" 
                                              VerticalScrollBarVisibility="Hidden"
                                              VerticalAlignment="Center"
                                              Margin="12,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton" 
                                                  Grid.Column="2" 
                                                  Focusable="False" 
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite" 
                                                      IsHitTestVisible="False" 
                                                      Margin="12,0,30,0" 
                                                      VerticalAlignment="Center" 
                                                      Content="{TemplateBinding SelectionBoxItem}" 
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                    <TextBox x:Name="PART_EditableTextBox" 
                                              Style="{x:Null}" 
                                              BorderThickness="0" 
                                              Background="Transparent" 
                                              Padding="12,0" 
                                              VerticalAlignment="Center" 
                                              Focusable="True" 
                                              IsReadOnly="{TemplateBinding IsReadOnly}" 
                                              Visibility="Hidden"/>
                                    <Path x:Name="Arrow" 
                                          Grid.Column="2" 
                                          Data="M0,0 L4,4 L8,0 Z" 
                                          Fill="#6C5CE7" 
                                          HorizontalAlignment="Right" 
                                          Margin="10,0" 
                                          VerticalAlignment="Center"/>
                                    <Popup x:Name="Popup" 
                                           AllowsTransparency="True" 
                                           Placement="Bottom" 
                                           StaysOpen="False" 
                                           Focusable="False" 
                                           IsOpen="{TemplateBinding IsDropDownOpen}" 
                                           PopupAnimation="Slide">
                                        <Border x:Name="DropDownBorder" 
                                                Background="White" 
                                                BorderBrush="#D0CDE8" 
                                                BorderThickness="1" 
                                                CornerRadius="8" 
                                                Padding="0">
                                            <ScrollViewer Margin="0" 
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                                KeyboardNavigation.DirectionalNavigation="Continue"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterDateStyle" TargetType="DatePicker">
                <Setter Property="Height" Value="38"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePickerTextBox 
                                        x:Name="PART_TextBox" 
                                        Grid.Column="0" 
                                        Foreground="{TemplateBinding Foreground}" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        VerticalContentAlignment="Center" 
                                        Padding="12,0" 
                                        FontSize="{TemplateBinding FontSize}"/>
                                    <Button x:Name="PART_Button" 
                                            Grid.Column="1" 
                                            Width="32" 
                                            Background="Transparent" 
                                            BorderThickness="0" 
                                            Cursor="Hand" 
                                            Focusable="False">
                                        <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                              Stroke="#6C5CE7" StrokeThickness="1.5" 
                                              StrokeLineJoin="Round" 
                                              StrokeStartLineCap="Round" 
                                              StrokeEndLineCap="Round" 
                                              Width="16" Height="16" 
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Popup x:Name="PART_Popup" 
                                           AllowsTransparency="True" 
                                           Placement="Bottom" 
                                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                        <Calendar x:Name="PART_Calendar"/>
                                    </Popup>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F5F5">
<Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1f6e2; Réception des Bons de Livraison (BL)" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ShowAddFormCommand}" Content="&#x2795; Ajouter un Bon de Livraison" 
                            Padding="15,8" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"
                            Visibility="{Binding CanAddBL, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Command="{Binding BackToListCommand}" Content="&#x2b05; Retour à la liste" 
                            Padding="15,8" Background="#757575" Foreground="White" FontWeight="Bold" BorderThickness="0"
                            Visibility="{Binding IsHistoryView, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            
            <!-- 1. HISTORY VIEW (Liste des BL) -->
            <Grid Visibility="{Binding IsHistoryView, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Statistics Cards -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <controls:KpiCard Grid.Column="0"
                Title="Total des Bons de Livraison"
                Value="{Binding TotalDeliveries}"
                TrendText="{Binding TotalDeliveriesTrendText}"
                Icon="Box"
                IconColor="#3B82F6"
                Margin="0,0,10,0"/>

            <controls:KpiCard Grid.Column="1"
                Title="Bons de Livraison En attente"
                Value="{Binding PendingDeliveries}"
                TrendText="{Binding PendingDeliveriesTrendText}"
                Icon="Clock"
                IconColor="#FFC107"
                Margin="5,0,5,0"/>

            <controls:KpiCard Grid.Column="2"
                Title="Bons de Livraison Validés"
                Value="{Binding ValidatedDeliveries}"
                TrendText="{Binding ValidatedDeliveriesTrendText}"
                Icon="CheckCircle"
                IconColor="#4CAF50"
                Margin="10,0,0,0"/>
                </Grid>

                <!-- Filters -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="🔍" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Recherche" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource FilterInputStyle}"
                                     HorizontalAlignment="Stretch"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="🏢" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Fournisseur" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding SupplierOptions}" 
                                      SelectedItem="{Binding SelectedSupplier}"
                                      Style="{StaticResource FilterComboStyle}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="📊" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding StatusOptions}" 
                                      SelectedItem="{Binding SelectedStatus}"
                                      Style="{StaticResource FilterComboStyle}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Date de réception" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DatePicker SelectedDate="{Binding SearchDate}" 
                                        Style="{StaticResource FilterDateStyle}"
                                        HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Command="{Binding ResetFiltersCommand}" 
                                    Style="{StaticResource BtnResetStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Réinitialiser"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BL History Table -->
                <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="24,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                            <TextBlock Text="Réception des Bons de Livraison" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DeliveriesHistory}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  MinWidth="1300"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE DE RÉCEPTION" Binding="{Binding DeliveryNote.ReceptionDate, StringFormat=d}" Width="Auto" MinWidth="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="N° BON DE LIVRAISON" Binding="{Binding DeliveryNote.DeliveryNumber}" Width="*" MinWidth="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="Foreground" Value="#4F46E5"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding DeliveryNote.Supplier.CompanyName}" Width="1.5*" MinWidth="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="BC CORRESPONDANT" Binding="{Binding DeliveryNote.PurchaseOrder.OrderNumber}" Width="*" MinWidth="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="N° FACTURE FOURNISSEUR" Binding="{Binding InvoiceNumber}" Width="*" MinWidth="160"
                                                    Visibility="{Binding Data.IsComptable, Source={StaticResource Proxy}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="STATUT" Width="130" MinWidth="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,4" CornerRadius="20" HorizontalAlignment="Left" Margin="12,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFE0B2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DeliveryNote.Status}" Value="EnAttente">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DeliveryNote.Status}" Value="Valide">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="En attente"/>
                                                            <Setter Property="Foreground" Value="#F57C00"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DeliveryNote.Status}" Value="EnAttente">
                                                                    <Setter Property="Text" Value="En attente"/>
                                                                    <Setter Property="Foreground" Value="#F57C00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DeliveryNote.Status}" Value="Valide">
                                                                    <Setter Property="Text" Value="Validé"/>
                                                                    <Setter Property="Foreground" Value="#059669"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="ACTIONS" Width="Auto" MinWidth="320">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12,8">
                                                <Button Command="{Binding Data.InspectCommand, Source={StaticResource Proxy}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Détails"
                                                        Padding="10,4"
                                                        Margin="0,0,6,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                            <Setter Property="Foreground" Value="#F57C00"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FFE0B2"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔍" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Détails" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding Data.PrintPdfCommand, Source={StaticResource Proxy}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="PDF"
                                                        Padding="10,4"
                                                        Margin="0,0,6,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                            <Setter Property="Foreground" Value="#3B82F6"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📄" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="PDF" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                                
                                                <!-- Bouton Ajouter Facture (Comptable uniquement + pas de facture) -->
                                                <Button Command="{Binding Data.AddInvoiceCommand, Source={StaticResource Proxy}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Ajouter Facture"
                                                        Padding="10,4"
                                                        Margin="0,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#D1FAE5"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#A7F3D0"/>
                                                                </Trigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Data.IsComptable, Source={StaticResource Proxy}}" Value="True"/>
                                                                        <Condition Binding="{Binding HasInvoice}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="➕" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Facture" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. ADD/INSPECT VIEW -->
            <Grid Visibility="{Binding IsHistoryView, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Form Left -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0" BorderBrush="#E0E0E0" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInspectView}" Value="True">
                                            <Setter Property="Text" Value="DÉTAIL DU BON DE LIVRAISON"/>
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditView}" Value="True">
                                            <Setter Property="Text" Value="NOUVELLE RÉCEPTION (BL)"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Form fields for New BL -->
                        <StackPanel DockPanel.Dock="Top" Visibility="{Binding IsEditView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Date de réception *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding ReceptionDate}" Padding="8"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,10">
                                    <TextBlock Text="BC correspondant *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding PurchaseOrders}" SelectedItem="{Binding SelectedPurchaseOrder}" 
                                              DisplayMemberPath="OrderNumber" Padding="8"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="N° Bon de Livraison *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding DeliveryNoteNumber, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Fournisseur (Automatique)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding SupplierName, Mode=OneWay}" IsReadOnly="True" Padding="8" Background="#F0F0F0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Info for Inspection -->
                        <StackPanel DockPanel.Dock="Top" Visibility="{Binding IsInspectView, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="N° BL:" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedDeliveryNote.DeliveryNumber}" Foreground="#2196F3" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="Date de réception:" FontWeight="Bold" Margin="20,0,10,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding SelectedDeliveryNote.ReceptionDate, StringFormat=d}"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fournisseur:" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedDeliveryNote.Supplier.CompanyName}"/>
                                <TextBlock Grid.Column="2" Text="BC correspondant:" FontWeight="Bold" Margin="20,0,10,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding SelectedDeliveryNote.PurchaseOrder.OrderNumber}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Items Grid -->
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,10">
                            <DataGrid ItemsSource="{Binding DeliveryItems}" AutoGenerateColumns="False" CanUserAddRows="False" 
                                      Background="Transparent" BorderThickness="0" RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produit" Binding="{Binding ProductName}" IsReadOnly="True" Width="*"/>
                                    <DataGridTextColumn Header="P.U HT" Binding="{Binding UnitPriceHT, StringFormat={}{0:N2} MAD}" IsReadOnly="True" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="P.U TTC" Binding="{Binding UnitPriceTTC, StringFormat={}{0:N2} MAD}" IsReadOnly="True" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Qté commandée" Binding="{Binding QuantityOrdered}" IsReadOnly="True" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Qté livrée" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding QuantityReceived, UpdateSourceTrigger=PropertyChanged}" 
                                                         IsReadOnly="{Binding DataContext.IsInspectView, RelativeSource={RelativeSource AncestorType=Page}}"
                                                         HorizontalContentAlignment="Right">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Error, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                                    <Setter Property="ToolTip" Value="{Binding Error}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:N2} MAD}" IsReadOnly="True" Width="Auto">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridCheckBoxColumn Header="Validé" Binding="{Binding IsValidated}" IsReadOnly="True" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- Sidebar Right -->
                <StackPanel Grid.Column="1">
                    <!-- PDF Section -->
                    <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="DOCUMENT PDF" FontWeight="Bold" Margin="0,0,0,10" Foreground="#666"/>
                            <StackPanel Visibility="{Binding IsEditView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <DockPanel>
                                    <Button Content="📁 Parcourir" Command="{Binding SelectFileCommand}" 
                                            DockPanel.Dock="Right" Padding="15,8" Margin="10,0,0,0"/>
                                    <TextBox Text="{Binding AttachedFilePath}" IsReadOnly="True" Padding="8" Background="#F9F9F9"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Visibility="{Binding IsInspectView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="📄 Ouvrir le document original" 
                                        Command="{Binding PrintPdfCommand}" 
                                        CommandParameter="{Binding SelectedDeliveryNote}"
                                        Padding="15,10" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Observations Section -->
                    <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="OBSERVATIONS" FontWeight="Bold" Margin="0,0,0,10" Foreground="#666"/>
                            <TextBox Text="{Binding Observations, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="100" 
                                     VerticalContentAlignment="Top" Padding="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Actions -->
                    <StackPanel>
                        <Button Command="{Binding ValidateCommand}" 
                                Visibility="{Binding IsEditView, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Content="✓ Valider la Réception" 
                                Padding="20,15" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        
                        <Button Command="{Binding ValidateCommand}" 
                                Visibility="{Binding IsInspectView, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Content="💾 Enregistrer les modifications" 
                                Padding="20,15" Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>