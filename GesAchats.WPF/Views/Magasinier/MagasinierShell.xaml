<Window x:Class="GesAchats.WPF.Views.Magasinier.MagasinierShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Magasinier/MagasinierStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#333333">
            <DockPanel>
                <!-- Logo/Header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30">
                    <TextBlock Text="MAGASIN" Foreground="{StaticResource WarningBrush}" 
                               FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="GesAchats" Foreground="White" FontSize="22" 
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Separator Margin="0,20,0,0" Background="#444444"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="10,0">
                    <Button Content="Tableau de bord" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Dashboard"/>
                    
                    <Button Content="Gestion du Stock" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Stock"/>
                    
                    <Button Content="Réception (BL)" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Livraisons"/>

                    <Button Content="Historique Besoins" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="NeedsHistory"/>

                    <Button Content="Sortie des besoins" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="StockExits"/>
                </StackPanel>

                <!-- Footer (User info & Logout) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,20">
                    <Separator Margin="0,0,0,15" Background="#444444"/>
                    <TextBlock Text="{Binding UserName}" Foreground="White" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Button Content="Déconnexion" 
                            Style="{StaticResource LogoutButtonStyle}"
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>

                <Grid/> <!-- Spacer -->
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Direction="-90" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid Margin="20,0">
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" 
                               FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
