<Page x:Class="GesAchats.WPF.Views.Magasinier.Dashboard.MagasinierDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:vm="clr-namespace:GesAchats.WPF.ViewModels.Magasinier"
             xmlns:components="clr-namespace:GesAchats.WPF.Views.Components"
             xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
             mc:Ignorable="d" d:DesignHeight="1080" d:DesignWidth="1640"
             d:DataContext="{d:DesignInstance Type=vm:MagasinierDashboardViewModel}"
             Title="Tableau de bord - Espace Magasinier"
             Background="#F5F7FA">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Magasinier/MagasinierStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:EqualityConverter x:Key="EqualityConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel>
            <!-- Header Section -->
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="GesAchats - Espace Magasinier" Foreground="#94A3B8" FontSize="14" FontWeight="Medium" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="8" Background="White" Margin="0,0,12,0">
                            <fa:IconImage Icon="Gauge" Width="18" Height="18" Foreground="#071B3A"/>
                        </Border>
                        <TextBlock Text="TABLEAU DE BORD" Foreground="#071B3A" FontSize="28" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Vue d'ensemble des statistiques du magasin" Foreground="#64748B" FontSize="14" Margin="44,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Border Background="White" CornerRadius="8" Padding="2" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Aujourd'hui" Style="{StaticResource DateFilterButtonStyle}" 
                                         IsChecked="{Binding SelectedPeriod, Converter={StaticResource EqualityConverter}, ConverterParameter=1}"
                                         Command="{Binding ChangePeriodCommand}" CommandParameter="1"/>
                            <RadioButton Content="7 jours" Style="{StaticResource DateFilterButtonStyle}"
                                         IsChecked="{Binding SelectedPeriod, Converter={StaticResource EqualityConverter}, ConverterParameter=7}"
                                         Command="{Binding ChangePeriodCommand}" CommandParameter="7"/>
                            <RadioButton Content="30 jours" Style="{StaticResource DateFilterButtonStyle}"
                                         IsChecked="{Binding SelectedPeriod, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                                         Command="{Binding ChangePeriodCommand}" CommandParameter="30"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- KPI Cards Grid - Row 1 -->
            <UniformGrid Columns="5" Margin="-8,0,-8,0">
                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#F1F5F9">
                            <fa:IconImage Icon="Box" Width="20" Height="20" Foreground="#071B3A"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Total Articles" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.TotalArticles}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Background="#ECFDF5">
                            <fa:IconImage Icon="CheckCircle" Width="24" Height="24" Foreground="#10B981"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Stock normal" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.StockNormalCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#FFFBEB">
                            <fa:IconImage Icon="TriangleExclamation" Width="24" Height="24" Foreground="#F59E0B"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Sous minimum" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.StockSousMinimumCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Background="#FEF2F2">
                            <fa:IconImage Icon="CircleXmark" Width="24" Height="24" Foreground="#EF4444"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="En rupture" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.StockEnRuptureCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#F1F5F9">
                            <fa:IconImage Icon="FileInvoice" Width="20" Height="20" Foreground="#F59E0B"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BL en attente" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.BlEnAttenteCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- KPI Cards Grid - Row 2 -->
            <UniformGrid Columns="5" Margin="-8,0,-8,24">
                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#ECFDF5">
                            <fa:IconImage Icon="FileCircleCheck" Width="20" Height="20" Foreground="#10B981"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BL validés" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.BlValidesCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#EFF6FF">
                            <fa:IconImage Icon="ClipboardList" Width="20" Height="20" Foreground="#2563EB"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Besoins en cours" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.BesoinsEnCoursCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#F5F3FF">
                            <fa:IconImage Icon="PaperPlane" Width="20" Height="20" Foreground="#8B5CF6"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Besoins transmis" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.BesoinsTransmisCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#FFF7ED">
                            <fa:IconImage Icon="CartArrowDown" Width="20" Height="20" Foreground="#F97316"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BC en attente" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.BcEnAttenteCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="#F0FDF4">
                            <fa:IconImage Icon="CartShopping" Width="20" Height="20" Foreground="#22C55E"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BC validés" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Stats.BcValidesCount}" Foreground="#071B3A" FontSize="28" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Charts Section -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Stock Status Donut -->
        <Border Grid.Column="0" Margin="0,0,0,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="État du stock" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource MainTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Donut Chart with Center Text -->
                    <Grid Grid.Column="0">
                        <lvc:PieChart Series="{Binding StockStatusSeries}" />
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalArticles}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Legend -->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="12" Height="12" Background="#10B981" CornerRadius="6"/>
                            <TextBlock Grid.Column="1" Text="Normal" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="12" Height="12" Background="#F59E0B" CornerRadius="6"/>
                            <TextBlock Grid.Column="1" Text="Sous minimum" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="12" Height="12" Background="#EF4444" CornerRadius="6"/>
                            <TextBlock Grid.Column="1" Text="En rupture" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

                <!-- BC Status Bar Chart -->
        <Border Grid.Column="1" Margin="0,0,18,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Bons de commande (7 derniers jours)" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource MainTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <components:PurchaseOrderChartControl Grid.Row="1"
                    DataContext="{Binding PurchaseOrderChartViewModel}"
                    ChartData="{Binding ChartData}"/>
            </Grid>
        </Border>

                <!-- Stock Movements Line Chart -->
        <Border Grid.Column="2" Margin="0,0,0,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Mouvement stock (7 derniers jours)" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource MainTextBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <lvc:CartesianChart Grid.Row="1" 
                                    Series="{Binding StockMovementSeries}" 
                                    XAxes="{Binding StockMovementXAxes}" 
                                    Height="200" Margin="0,12,0,0" LegendPosition="Top"/>
            </Grid>
        </Border>
            </Grid>

            <!-- Tables Section -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.6*"/>
                </Grid.ColumnDefinitions>

                <!-- Critical Products Table -->
                <Border Grid.Column="0" Style="{StaticResource KpiCard}" Margin="8,0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Bell" Width="16" Height="16" Foreground="#EF4444" Margin="0,0,8,0"/>
                                <TextBlock Text="Articles critiques" Foreground="#071B3A" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="(Alerte)" Foreground="#EF4444" FontWeight="Bold" FontSize="16" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        


                        <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding Stats.CriticalProducts}" MaxHeight="250" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Article" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Stock actuel" Binding="{Binding CurrentStock, StringFormat={}{0:N2}}" Width="1*"/>
                                <DataGridTextColumn Header="Seuil min" Binding="{Binding MinimumStock, StringFormat={}{0:N2}}" Width="1*"/>
                                <DataGridTextColumn Header="Unité" Binding="{Binding Unit}" Width="0.8*"/>
                                <DataGridTemplateColumn Header="Statut de stock" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="En rupture">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Sous minimum">
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#F97316"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Latest Operations Table -->
                <Border Grid.Column="1" Style="{StaticResource KpiCard}" Margin="8,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Dernière opération" Foreground="#071B3A" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                        


                        <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding Stats.RecentOperations}" MaxHeight="280" VerticalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="1*"/>
                                <DataGridTextColumn Header="Référence" Binding="{Binding Reference}" Width="1.5*"/>
                                <DataGridTemplateColumn Header="Type" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconImage Icon="{Binding TypeIcon}" Width="16" Height="16" Foreground="{Binding TypeColor}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding TypeText}" VerticalAlignment="Center" FontSize="13"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Statut" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="10,4" Background="{Binding StatusColor}" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>