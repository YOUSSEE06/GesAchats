<Page x:Class="GesAchats.WPF.Views.Admin.Orders.OrderManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Gestion des Bons de Commande">

    <Page.Resources>
        <converters:EmptyToPlaceholderConverter x:Key="EmptyToPlaceholderConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Page.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Header -->
            <RowDefinition Height="Auto"/> <!-- Page Title -->
            <RowDefinition Height="Auto"/> <!-- Form / Filters -->
            <RowDefinition Height="*"/>    <!-- Table -->
        </Grid.RowDefinitions>

        <!-- 1. En-tête global -->
        <Grid Grid.Row="0" Margin="25,25,25,10">
            <TextBlock Text="ESPACE ADMIN" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- 3. Zone principale - Titre de la page -->
        <TextBlock Grid.Row="1" Text="Gestion des Bons de Commande" FontSize="20" FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="25,15,25,10"/>

        <!-- 3.1 Formulaire de saisie / filtres -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="25,10">
            <StackPanel Margin="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="Recherche (N° BC / Réf. Devis)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Fournisseur" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" Style="{StaticResource ModernComboBox}" IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EmptyToPlaceholderConverter}, ConverterParameter='Tous les fournisseurs'}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10">
                        <TextBlock Text="Statut" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Style="{StaticResource ModernComboBox}" IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EmptyToPlaceholderConverter}, ConverterParameter='Tous les statuts'}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="10">
                        <TextBlock Text="Date" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker SelectedDate="{Binding SearchDate}" Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="10" VerticalAlignment="Bottom">
                        <Button Content="Réinitialiser" 
                                Command="{Binding ResetFiltersCommand}"
                                Style="{StaticResource ModernPrimaryButton}"
                                Background="#94A3B8"
                                Width="120"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>



        <!-- 3.3 Tableau des BC -->
        <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="25,10,25,25">
            <DataGrid ItemsSource="{Binding Orders}" 
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                    <DataGridTextColumn Header="N° BC" Binding="{Binding OrderNumber}" Width="150" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Fournisseur" Binding="{Binding SupplierName}" Width="*"/>
                    <DataGridTextColumn Header="Réf. Devis" Binding="{Binding QuotationRef}" Width="180"/>
                    <DataGridTemplateColumn Header="Statut" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" 
                                        CornerRadius="12" Padding="10,4" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}" 
                                              Foreground="White" 
                                              FontWeight="SemiBold" 
                                              FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Total TTC" Binding="{Binding TotalTTC}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTemplateColumn Header="Actions" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🔍" 
                                            ToolTip="Inspector"
                                            Command="{Binding DataContext.InspectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ModernIconButton}"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            Margin="0,0,5,0"/>
                                    
                                    <Button Content="📄" 
                                            ToolTip="PD (PDF)"
                                            Command="{Binding DataContext.PrintPdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ModernIconButton}"
                                            Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
