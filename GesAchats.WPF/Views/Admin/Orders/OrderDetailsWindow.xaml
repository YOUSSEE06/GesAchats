<Window x:Class="GesAchats.WPF.Views.Admin.Orders.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding TitleText}" Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Info Cards -->
            <RowDefinition Height="*"/>    <!-- Items Grid -->
            <RowDefinition Height="Auto"/> <!-- Summary & Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="DÉTAILS BON DE COMMANDE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="{Binding PurchaseOrder.OrderNumber}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Info Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,25">
            <Border Style="{StaticResource ModernCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Fournisseur" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SupplierName}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource ModernCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Date Commande" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding OrderDate}" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Réf. Devis" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding QuotationRef}" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCard}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Statut" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Status}" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Items Grid -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Details}" 
                      Style="{StaticResource ModernDataGrid}"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Produit" Binding="{Binding Product.Designation}" Width="*"/>
                    <DataGridTextColumn Header="Quantité" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="P.U. HT" Binding="{Binding UnitPriceHT, StringFormat='N2'}" Width="120"/>
                    <DataGridTextColumn Header="Total HT" Binding="{Binding TotalHT, StringFormat='N2'}" Width="120"/>
                    <DataGridTextColumn Header="TVA" Binding="{Binding Path=., Converter={StaticResource StaticValueConverter}, ConverterParameter='20%'}" Width="80"/>
                    <DataGridTextColumn Header="P.U. TTC" Binding="{Binding UnitPriceTTC, StringFormat='N2'}" Width="120"/>
                    <DataGridTextColumn Header="Total TTC" Binding="{Binding TotalTTC, StringFormat='N2'}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Summary & Footer -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Width="250">
                <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Total HT" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalHT}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="TVA (20%)" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalVAT}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Separator Margin="0,10" Background="#EEEEEE"/>
                        <Grid>
                            <TextBlock Text="TOTAL TTC" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding TotalTTC}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <Button Content="Fermer" Click="Close_Click" 
                        Style="{StaticResource ModernPrimaryButton}" 
                        Background="#94A3B8" Width="120" HorizontalAlignment="Right" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
