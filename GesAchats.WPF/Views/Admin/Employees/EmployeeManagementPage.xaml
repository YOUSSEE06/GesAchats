<Page x:Class="GesAchats.WPF.Views.Admin.Employees.EmployeeManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="1200" d:DesignWidth="1200"
      Title="Gestion des Employés">

    <Page.Resources>
        <ResourceDictionary>
            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <conv:BooleanToBrushConverter x:Key="CheckToBrush" TrueBrush="#10B981" FalseBrush="#64748B"/>
            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Resources>
                    <DropShadowEffect x:Key="Shadow" BlurRadius="10" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                </Style.Resources>
            </Style>

            <Style x:Key="ModernDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="AlternationCount" Value="2"/>
                <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            </Style>

            <Style x:Key="ModernDataGridHeader" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="Foreground" Value="#64748B"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#0F172A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#0D9488"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#0F766E"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#0D9488"/>
                <Setter Property="BorderBrush" Value="#0D9488"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#CCFBF1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#DC2626"/>
                <Setter Property="BorderBrush" Value="#DC2626"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#0D9488"/>
                <Setter Property="BorderBrush" Value="#0D9488"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#CCFBF1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TextBoxStyle" TargetType="TextBox">
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#0D9488"/>
                                    <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="border" 
                                        Background="White" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8"
                                        Padding="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter x:Name="ContentSite" 
                                                          Grid.Column="0"
                                                          Margin="12,10,0,10"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"/>
                                        <fa:IconImage Grid.Column="1" 
                                                      Icon="ChevronDown"
                                                      Width="12" Height="12"
                                                      Foreground="#64748B"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                    </Grid>
                                </Border>
                                <Popup x:Name="PART_Popup" 
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <ScrollViewer Margin="4,6">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#0D9488"/>
                                    <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Page Header -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Gestion des Employés" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Gérez les comptes utilisateurs et les accès au système" Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Top Row: Left Admin Card + Right Add Button -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Card: Mon compte administrateur -->
                    <Border Grid.Column="0" Margin="0,0,24,0" Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Background="#0D9488" Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                                        <fa:IconImage Icon="User" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Mon compte administrateur" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Session Error Message -->
                                <TextBlock Text="{Binding AdminSessionError}" 
                                           DockPanel.Dock="Top" 
                                           FontSize="13" 
                                           Foreground="#DC2626" 
                                           Margin="0,0,0,12"/>

                                <!-- Admin Info -->
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.4*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nom complet" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AdminFullName}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.4*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Email professionnel" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AdminEmail}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.4*"/>
                                            <ColumnDefinition Width="0.6*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Rôle" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AdminRoleDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Admin Action Buttons -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Command="{Binding ShowAdminEmailEditCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage Icon="Envelope" Width="14" Height="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="Modifier email"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding ShowAdminPasswordChangeCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage Icon="Key" Width="14" Height="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="Changer mot de passe"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Session Error Message -->
                                <TextBlock Text="{Binding AdminEmailEditMessage}" 
                                           DockPanel.Dock="Top" 
                                           FontSize="13" 
                                           Foreground="#DC2626" 
                                           Margin="0,0,0,12"
                                           Visibility="{Binding AdminEmailEditMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                                <!-- Sub-section: Secure Email Modification (Hidden by default) -->
                                <Border DockPanel.Dock="Top" 
                                        Background="#F0FDFA" 
                                        Padding="16" 
                                        CornerRadius="10"
                                        Visibility="{Binding IsAdminEmailEditVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Modifier mon email professionnel (sécurisé)" FontSize="14" FontWeight="SemiBold" Foreground="#0D9488" Margin="0,0,0,12"/>
                                        
                                        <!-- Step 1: Verify Password -->
                                        <StackPanel Visibility="{Binding IsPasswordStep, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Mot de passe actuel" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <PasswordBox x:Name="AdminPasswordBox" Padding="12,10" BorderBrush="#E2E8F0" BorderThickness="1" FontSize="13" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="14,8" Command="{Binding VerifyAdminPasswordCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Shield" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Vérifier le mot de passe"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DangerButton}" Padding="14,8" Command="{Binding CancelAdminEmailEditCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Xmark" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Annuler"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Step 2: Enter New Email -->
                                        <StackPanel Visibility="{Binding IsNewEmailStep, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Nouveau email professionnel" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewAdminEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="14,8" Command="{Binding SendAdminEmailChangeCodeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="PaperPlane" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Envoyer code"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DangerButton}" Padding="14,8" Command="{Binding CancelAdminEmailEditCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Xmark" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Annuler"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Step 3: Verify Code -->
                                        <StackPanel Visibility="{Binding IsCodeStep, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Nouveau email professionnel" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewAdminEmail}" IsEnabled="False"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Code de validation" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminEmailVerificationCode, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Padding="14,8" Command="{Binding ConfirmAdminEmailChangeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Check" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Valider et modifier email"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DangerButton}" Padding="14,8" Command="{Binding CancelAdminEmailEditCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Xmark" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Annuler"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Password Change Message -->
                                <TextBlock Text="{Binding AdminPasswordChangeMessage}" 
                                           DockPanel.Dock="Top" 
                                           FontSize="13" 
                                           Foreground="#DC2626" 
                                           Margin="0,0,0,12"
                                           Visibility="{Binding AdminPasswordChangeMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                                <!-- Sub-section: Secure Password Modification (Hidden by default) -->
                                <Border DockPanel.Dock="Top" 
                                        Background="#F0FDFA" 
                                        Padding="16" 
                                        CornerRadius="10"
                                        Visibility="{Binding IsAdminPasswordChangeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Changer mon mot de passe (sécurisé)" FontSize="14" FontWeight="SemiBold" Foreground="#0D9488" Margin="0,0,0,12"/>
                                        
                                        <!-- Step 1: Send Code -->
                                        <StackPanel Visibility="{Binding IsPasswordChangeSendCodeStep, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Email administrateur" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminEmail}" IsEnabled="False"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="14,8" Command="{Binding SendAdminPasswordCodeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="PaperPlane" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Envoyer code de vérification"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DangerButton}" Padding="14,8" Command="{Binding CancelAdminPasswordChangeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Xmark" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Annuler"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Step 2: Verify Code -->
                                        <StackPanel Visibility="{Binding IsPasswordChangeVerifyCodeStep, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Email administrateur" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminEmail}" IsEnabled="False"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Code de vérification" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding AdminPasswordVerificationCode, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="14,8" Command="{Binding VerifyAdminPasswordCodeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Shield" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Vérifier le code"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DangerButton}" Padding="14,8" Command="{Binding CancelAdminPasswordChangeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Xmark" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Annuler"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Step 3: New Password -->
                                        <StackPanel Visibility="{Binding IsPasswordChangeNewPasswordStep, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Nouveau mot de passe" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <PasswordBox x:Name="AdminNewPasswordBox" Padding="12,10" BorderBrush="#E2E8F0" BorderThickness="1" FontSize="13" VerticalContentAlignment="Center"/>
                                                <!-- Password Strength UI -->
                                                <StackPanel Margin="12,10,0,0">
                                                    <!-- Strength Bar -->
                                                    <Grid Height="8" Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Margin="0,0,2,0" CornerRadius="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AdminPasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=1}" Value="True">
                                                                            <Setter Property="Background" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <Border Grid.Column="1" Margin="2,0,2,0" CornerRadius="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AdminPasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=2}" Value="True">
                                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <Border Grid.Column="2" Margin="2,0,2,0" CornerRadius="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AdminPasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=3}" Value="True">
                                                                            <Setter Property="Background" Value="#F59E0B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <Border Grid.Column="3" Margin="2,0,2,0" CornerRadius="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AdminPasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                                            <Setter Property="Background" Value="#0D9488"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <Border Grid.Column="4" Margin="2,0,0,0" CornerRadius="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AdminPasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                                            <Setter Property="Background" Value="#10B981"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </Grid>
                                                    <!-- Strength Label -->
                                                    <TextBlock Text="{Binding AdminPasswordStrengthLabel}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AdminPasswordStrengthLabel}" Value="Moyen">
                                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AdminPasswordStrengthLabel}" Value="Bon">
                                                                        <Setter Property="Foreground" Value="#0D9488"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AdminPasswordStrengthLabel}" Value="Fort">
                                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Checklist -->
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                            <TextBlock Text="✓ " Foreground="{Binding HasAdminMinLength, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                            <TextBlock Text="Au moins 8 caractères" Foreground="{Binding HasAdminMinLength, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                            <TextBlock Text="✓ " Foreground="{Binding HasAdminLowercase, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                            <TextBlock Text="Une lettre minuscule" Foreground="{Binding HasAdminLowercase, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                            <TextBlock Text="✓ " Foreground="{Binding HasAdminUppercase, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                            <TextBlock Text="Une lettre majuscule" Foreground="{Binding HasAdminUppercase, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                            <TextBlock Text="✓ " Foreground="{Binding HasAdminDigit, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                            <TextBlock Text="Un chiffre" Foreground="{Binding HasAdminDigit, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                            <TextBlock Text="✓ " Foreground="{Binding HasAdminSpecialCharacter, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                            <TextBlock Text="Un caractère spécial" Foreground="{Binding HasAdminSpecialCharacter, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Confirmer le mot de passe" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <PasswordBox x:Name="AdminConfirmPasswordBox" Padding="12,10" BorderBrush="#E2E8F0" BorderThickness="1" FontSize="13" VerticalContentAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" Margin="12,5,0,0">
                                                    <TextBlock Text="✓ " Foreground="{Binding DoAdminPasswordsMatch, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                    <TextBlock Text="Les mots de passe correspondent" Foreground="{Binding DoAdminPasswordsMatch, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Padding="14,8" Command="{Binding ConfirmAdminPasswordChangeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Check" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Valider et changer le mot de passe"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DangerButton}" Padding="14,8" Command="{Binding CancelAdminPasswordChangeCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconImage Icon="Xmark" Width="12" Height="12" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Annuler"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Add Employee Form Card (Hidden by default) -->
                <Border Style="{StaticResource MetricCardStyle}" 
                        Margin="0,0,0,24"
                        Visibility="{Binding IsAddEmployeeFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#0D9488" Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                                    <fa:IconImage Icon="UserPlus" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Ajouter un employé" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Step 1: Employee Info -->
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12" Visibility="{Binding IsAddEmployeeInfoStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Nom complet" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewEmployeeFullName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Email professionnel" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewEmployeeEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Rôle" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding AvailableEmployeeRoles}"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedEmployeeRoleId, Mode=TwoWay}"
                                              Padding="12,10"
                                              BorderBrush="#E2E8F0"
                                              BorderThickness="1"
                                              FontSize="13">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" FontSize="13" Foreground="#1E293B" Padding="4,2"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Step 2: Code Validation -->
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12" Visibility="{Binding IsAddEmployeeCodeStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Nom complet" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewEmployeeFullName}" IsReadOnly="True" Background="#F1F5F9"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Email professionnel" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewEmployeeEmail}" IsReadOnly="True" Background="#F1F5F9"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Rôle" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding AvailableEmployeeRoles}"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedEmployeeRoleId, Mode=TwoWay}"
                                              Padding="12,10"
                                              BorderBrush="#E2E8F0"
                                              BorderThickness="1"
                                              FontSize="13"
                                              IsEnabled="False"
                                              Background="#F1F5F9">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" FontSize="13" Foreground="#1E293B" Padding="4,2"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Code de validation" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource TextBoxStyle}" Text="{Binding NewEmployeeVerificationCode, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Message -->
                            <TextBlock DockPanel.Dock="Top" Text="{Binding AddEmployeeMessage}" FontSize="13" Foreground="#DC2626" Margin="0,0,0,16"/>

                            <!-- Action Buttons -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
                                <!-- Send Code Button (Step 1 Only) -->
                                <Button Style="{StaticResource PrimaryButton}" 
                                        Margin="0,0,8,0" 
                                        Command="{Binding SendEmployeeCodeCommand}"
                                        Visibility="{Binding IsAddEmployeeInfoStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="PaperPlane" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Envoyer code de validation"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Create Account Button (Step 2 Only) -->
                                <Button Style="{StaticResource PrimaryButton}" 
                                        Margin="0,0,8,0" 
                                        Command="{Binding CreateEmployeeCommand}"
                                        Visibility="{Binding IsAddEmployeeCodeStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="UserPlus" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Valider et créer le compte"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Cancel Button -->
                                <Button Style="{StaticResource DangerButton}" Command="{Binding HideAddEmployeeFormCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="Xmark" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Annuler"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Employees List Card -->
                <Border Style="{StaticResource MetricCardStyle}">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,16">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Border Background="#0D9488" Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                                    <fa:IconImage Icon="Users" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Liste des employés" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBox Style="{StaticResource TextBoxStyle}" Width="220" Padding="10,8" Margin="0,0,8,0">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <fa:IconImage Grid.Column="0" Icon="Search" Width="14" Height="14" Foreground="#64748B" Margin="0,0,8,0"/>
                                                    <ScrollViewer Grid.Column="1" x:Name="PART_ContentHost"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="12,8" Command="{Binding LoadEmployeesCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="Sync" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Actualiser"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Padding="12,8" Command="{Binding ShowAddEmployeeFormCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="Plus" Width="14" Height="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="Ajouter un employé"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>

                        <!-- DataGrid -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <DataGrid Style="{StaticResource ModernDataGrid}"
                                      ItemsSource="{Binding Employees}"
                                      IsReadOnly="True" 
                                      RowHeight="56" 
                                      HorizontalAlignment="Left"
                                      MinWidth="1200"
                                      ClipToBounds="True"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nom complet" 
                                                        Binding="{Binding FullName}" 
                                                        Width="Auto"
                                                        MinWidth="180"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Email" 
                                                        Binding="{Binding Email}" 
                                                        Width="Auto"
                                                        MinWidth="280"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Rôle" 
                                                        Width="Auto"
                                                        MinWidth="140"
                                                        Binding="{Binding RoleLabel}" 
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Statut compte" 
                                                        Width="Auto"
                                                        MinWidth="140"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="20" 
                                                        Padding="12,6" 
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Left"
                                                        SnapsToDevicePixels="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="" 
                                                              FontSize="12" 
                                                              FontWeight="SemiBold"
                                                              TextWrapping="NoWrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Désactivé"/>
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Actif"/>
                                                                        <Setter Property="Foreground" Value="#047857"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Date de création" 
                                                        Width="Auto"
                                                        MinWidth="170"
                                                        Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" 
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Dernière connexion" 
                                                        Width="Auto"
                                                        MinWidth="180"
                                                        Binding="{Binding DerniereConnexionDisplay}" 
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Actions" 
                                                        Width="Auto"
                                                        MinWidth="260"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="ToggleStatusBtn"
                                                            Style="{StaticResource ActionButton}"
                                                            Margin="0,0,8,0" 
                                                            Padding="10,6" 
                                                            Command="{Binding DataContext.ToggleEmployeeStatusCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding Id}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconImage x:Name="ToggleIcon" Width="12" Height="12" Margin="0,0,4,0"/>
                                                            <TextBlock x:Name="ToggleText" TextWrapping="NoWrap"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button x:Name="DeleteBtn"
                                                            Style="{StaticResource ActionButton}"
                                                            Margin="0,0,0,0" 
                                                            Padding="10,6" 
                                                            Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding Id}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconImage x:Name="DeleteIcon" Width="12" Height="12" Margin="0,0,4,0"/>
                                                            <TextBlock x:Name="DeleteText" Text="Supprimer" TextWrapping="NoWrap"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter TargetName="ToggleStatusBtn" Property="Foreground" Value="#DC2626"/>
                                                        <Setter TargetName="ToggleStatusBtn" Property="BorderBrush" Value="#DC2626"/>
                                                        <Setter TargetName="ToggleIcon" Property="Icon" Value="Ban"/>
                                                        <Setter TargetName="ToggleText" Property="Text" Value="Désactiver"/>
                                                        <Setter TargetName="DeleteBtn" Property="IsEnabled" Value="False"/>
                                                        <Setter TargetName="DeleteBtn" Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter TargetName="ToggleIcon" Property="Icon" Value="Check"/>
                                                        <Setter TargetName="ToggleText" Property="Text" Value="Activer"/>
                                                        <Setter TargetName="DeleteBtn" Property="IsEnabled" Value="True"/>
                                                        <Setter TargetName="DeleteBtn" Property="Opacity" Value="1"/>
                                                        <Setter TargetName="DeleteBtn" Property="Foreground" Value="#DC2626"/>
                                                        <Setter TargetName="DeleteBtn" Property="BorderBrush" Value="#DC2626"/>
                                                        <Setter TargetName="DeleteIcon" Property="Icon" Value="Trash"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
