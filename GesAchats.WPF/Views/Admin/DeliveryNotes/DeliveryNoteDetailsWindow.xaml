<Window x:Class="GesAchats.WPF.Views.Admin.DeliveryNotes.DeliveryNoteDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding TitleText}" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Info Cards -->
            <RowDefinition Height="*"/>    <!-- Items Grid -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="DÉTAILS BON DE LIVRAISON" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="{Binding DeliveryNote.DeliveryNumber}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Info Cards -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,25">
            <Border Style="{StaticResource ModernCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Fournisseur" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SupplierName}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource ModernCard}" Margin="0,0,10,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Date Réception" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding DateReception}" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCard}" Padding="15">
                <StackPanel>
                    <TextBlock Text="BC Associé" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding BCNumber}" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Items Grid -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Details}" 
                      Style="{StaticResource ModernDataGrid}"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Produit" Binding="{Binding Product.Designation}" Width="*"/>
                    <DataGridTextColumn Header="Qté Commandée" Binding="{Binding QuantityOrdered}" Width="120"/>
                    <DataGridTextColumn Header="Qté Reçue" Binding="{Binding QuantityReceived}" Width="120"/>
                    <DataGridTemplateColumn Header="Statut" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsValidated, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter='SuccessBrush|DangerBrush'}" 
                                        CornerRadius="10" Padding="8,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding IsValidated, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='Validé|En attente'}" 
                                               Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Fermer" Click="Close_Click" 
                    Style="{StaticResource ModernPrimaryButton}" 
                    Background="#94A3B8" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
