<Page x:Class="GesAchats.WPF.Views.Admin.DeliveryNotes.AdminDeliveryNotesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Réception des Bons de Livraison (BL)">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Header -->
            <RowDefinition Height="Auto"/> <!-- Page Title -->
            <RowDefinition Height="Auto"/> <!-- Form -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
            <RowDefinition Height="*"/>    <!-- Table -->
        </Grid.RowDefinitions>

        <!-- 1. En-tête global -->
        <Grid Grid.Row="0" Margin="25,25,25,10">
            <TextBlock Text="ESPACE ADMIN" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- 3. Zone principale - Titre de la page -->
        <TextBlock Grid.Row="1" Text="Réception des Bons de Livraison (BL)" FontSize="20" FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="25,15,25,10"/>

        <!-- 3.1 Formulaire de saisie -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="25,10">
            <StackPanel Margin="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="N° Bon de Livraison" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding DeliveryNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Fournisseur" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" 
                                  SelectedItem="{Binding SelectedSupplier}"
                                  DisplayMemberPath="CompanyName"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10">
                        <TextBlock Text="N° Bon de Commande" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding PurchaseOrderNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="10">
                        <TextBlock Text="Date de réception" Margin="0,0,0,5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker SelectedDate="{Binding ReceptionDate}" Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 3.3 Boutons globaux -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="25,10" HorizontalAlignment="Right">
            <Button Content="Actualiser" 
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource ModernPrimaryButton}"
                    Background="#94A3B8"
                    Width="120" Margin="0,0,15,0"/>
            
            <Button Content="Ajouter un Bon de Livraison" 
                    Command="{Binding AddDeliveryNoteCommand}"
                    Style="{StaticResource ModernPrimaryButton}" 
                    Background="#3B82F6" Width="220"/>
        </StackPanel>

        <!-- 3.2 Tableau des BL -->
        <Border Grid.Row="4" Style="{StaticResource ModernCard}" Margin="25,10,25,25">
            <DataGrid ItemsSource="{Binding DeliveryNotes}" 
                      Style="{StaticResource ModernDataGrid}"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date de réception" Binding="{Binding DateReception}" Width="150"/>
                    <DataGridTextColumn Header="N° Bon de Livraison" Binding="{Binding NumeroBL}" Width="180" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Fournisseur (Société)" Binding="{Binding Fournisseur}" Width="*"/>
                    <DataGridTextColumn Header="BC correspondant" Binding="{Binding BCCorrespondant}" Width="180"/>
                    
                    <DataGridTemplateColumn Header="Actions" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Détails" 
                                            Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ModernIconButton}"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            FontWeight="SemiBold"
                                            Margin="0,0,10,0"/>
                                    
                                    <Button Content="Justificatif" 
                                            Command="{Binding DataContext.ViewJustificatifCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ModernIconButton}"
                                            Foreground="{StaticResource SuccessBrush}"
                                            FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
