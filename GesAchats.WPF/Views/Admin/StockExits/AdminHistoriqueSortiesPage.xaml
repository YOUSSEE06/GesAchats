<Page x:Class="GesAchats.WPF.Views.Admin.StockExits.AdminHistoriqueSortiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Admin.StockExits"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Historique des sorties">

    <Grid Background="#F5F6F7" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="📊 Historique des sorties de stock" FontSize="18" FontWeight="Bold" Foreground="#1A3A52" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Statistics Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:KpiCard Grid.Column="0"
                Title="Total des Sorties"
                Value="{Binding TotalExits}"
                TrendText="{Binding TotalExitsTrendText}"
                Icon="Box"
                IconColor="#3B82F6"
                Margin="0,0,7,0"/>

            <controls:KpiCard Grid.Column="1"
                Title="Quantité Totale Sortie"
                Value="{Binding TotalQuantityExited}"
                TrendText="{Binding TotalQuantityExitedTrendText}"
                Unit=""
                Icon="ArrowDown"
                IconColor="#F44336"
                Margin="7,0,0,0"/>
        </Grid>

        <!-- Filters Bar -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Recherche Article" Foreground="#757575" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Width="300" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="4" Height="28"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Filtrer par Date" Foreground="#757575" FontSize="11" Margin="0,0,0,3"/>
                        <DatePicker Width="180" SelectedDate="{Binding FilterDate}" Padding="4" Height="28"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="🔄 Réinitialiser" 
                        Command="{Binding ResetFiltersCommand}"
                        Background="#FFC107" 
                        Foreground="#1A3A52" FontWeight="Bold" 
                        Padding="20,10" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Historique Table -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#F8FAFC" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <TextBlock Text="HISTORIQUE DES SORTIES DE STOCK" FontWeight="SemiBold" Foreground="#1A3A52"/>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding StockExits}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          RowHeight="40" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding ExitDate, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Article" Binding="{Binding Product.Designation}" Width="*"/>
                        <DataGridTemplateColumn Header="Quantité" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Quantity}" Foreground="#F44336" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Motif" Binding="{Binding Reason}" Width="*"/>
                        <DataGridTextColumn Header="Stock Restant" Binding="{Binding StockAfterExit}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
