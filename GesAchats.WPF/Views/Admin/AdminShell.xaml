<Window x:Class="GesAchats.WPF.Views.Admin.AdminShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GesAchats.WPF;component/Resources/Admin/AdminStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1E293B">
            <DockPanel>
                <!-- Logo/Header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30">
                    <TextBlock Text="ESPACE" Foreground="#3B82F6" 
                               FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="ADMIN" Foreground="White" FontSize="24" 
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Separator Margin="0,20,0,0" Background="#334155"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="10,0">
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="StockGlobal">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" Margin="0,0,10,0"/>
                            <TextBlock Text="Stock Global"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="NeedsHistory">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" Margin="0,0,10,0"/>
                            <TextBlock Text="Historique Besoins"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="HistoriqueSorties">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,10,0"/>
                            <TextBlock Text="Historique des sorties"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="DeliveryNotes">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚚" Margin="0,0,10,0"/>
                            <TextBlock Text="Bons de Livraison"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="PriceAnalysis">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" Margin="0,0,10,0"/>
                            <TextBlock Text="Prix &amp; Achats"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Orders">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock Text="Gestion Bons Commande"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Invoices">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📑" Margin="0,0,10,0"/>
                            <TextBlock Text="Factures Fournisseurs"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Payments">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" Margin="0,0,10,0"/>
                            <TextBlock Text="Suivi Règlements"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Employees">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" Margin="0,0,10,0"/>
                            <TextBlock Text="Gestion Employés"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="InvoicesAdmin">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" Margin="0,0,10,0"/>
                            <TextBlock Text="Gestion des Factures"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer (User info & Logout) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,20">
                    <Separator Margin="0,0,0,15" Background="#334155"/>
                    <TextBlock Text="Administrateur Système" Foreground="White" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"
                               FontSize="12" Opacity="0.8"/>
                    <Button Content="Déconnexion" 
                            Style="{StaticResource LogoutButtonStyle}"
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>

                <Grid/> <!-- Spacer -->
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Direction="-90" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid Margin="20,0">
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" 
                               FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
