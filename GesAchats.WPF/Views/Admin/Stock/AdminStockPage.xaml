<Page x:Class="GesAchats.WPF.Views.Admin.Stock.AdminStockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Admin.Stock"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:entities="clr-namespace:GesAchats.Core.Entities"
      xmlns:controls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d"
      Title="Stock global">
    <Page.Resources>
        <converters:StockStateToColorConverter x:Key="StockStateToColorConverter"/>
        <converters:StockStateToStringConverter x:Key="StockStateToStringConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Statistics Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:KpiCard Grid.Column="0" 
                              Title="Total Produits" 
                              Value="{Binding TotalProducts}"
                              TrendText="{Binding TotalProductsTrendText}"
                              Icon="Box"
                              IconColor="#3B82F6"
                              Margin="0,0,8,0"/>

            <controls:KpiCard Grid.Column="1" 
                              Title="Total Stock" 
                              Value="{Binding TotalStock}"
                              TrendText="{Binding TotalStockTrendText}"
                              Icon="Database"
                              IconColor="#3B82F6"
                              Margin="4,0,4,0"/>

            <controls:KpiCard Grid.Column="2" 
                              Title="État OK" 
                              Value="{Binding ProductsOk}"
                              TrendText="{Binding ProductsOkTrendText}"
                              Icon="CheckCircle"
                              IconColor="#4CAF50"
                              Margin="4,0,4,0"/>

            <controls:KpiCard Grid.Column="3" 
                              Title="Alerte" 
                              Value="{Binding ProductsAlert}"
                              TrendText="{Binding ProductsAlertTrendText}"
                              Icon="ExclamationTriangle"
                              IconColor="#FFC107"
                              Margin="4,0,4,0"/>

            <controls:KpiCard Grid.Column="4" 
                              Title="Rupture" 
                              Value="{Binding ProductsOutOfStock}"
                              TrendText="{Binding ProductsOutOfStockTrendText}"
                              Icon="TimesCircle"
                              IconColor="#F44336"
                              Margin="8,0,0,0"/>
        </Grid>

        <!-- Header Actions -->
        <DockPanel Grid.Row="1" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="250" Padding="8" Margin="0,0,10,0"
                         Tag="🔍 Recherche article..."
                         VerticalContentAlignment="Center"/>
                
                <ComboBox ItemsSource="{Binding StatusOptions}" 
                          SelectedItem="{Binding SelectedStatus}"
                          Width="150" Padding="8"/>
            </StackPanel>
        </DockPanel>

        <!-- Stock Table -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredProducts}" 
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="#E0E0E0"
                  RowHeight="40" SelectionMode="Single" GridLinesVisibility="None"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N°" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Désignation" Binding="{Binding Designation}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stock Actuel" Binding="{Binding CurrentStock}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Seuil Min" Binding="{Binding MinimumStock}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Unité" Binding="{Binding Unit}" Width="80" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="État" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="12" Height="12" Fill="{Binding Etat, Converter={StaticResource StockStateToColorConverter}}" 
                                         Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Etat, Converter={StaticResource StockStateToStringConverter}}" 
                                                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer Info -->
        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total: "/>
                    <TextBlock Text="{Binding FilteredProducts.Count}" FontWeight="Bold"/>
                    <TextBlock Text=" articles affichés" Margin="0,0,20,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Page>
