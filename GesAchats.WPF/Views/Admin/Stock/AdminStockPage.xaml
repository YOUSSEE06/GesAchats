<Page x:Class="GesAchats.WPF.Views.Admin.Stock.AdminStockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Admin.Stock"
      xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
      xmlns:entities="clr-namespace:GesAchats.Core.Entities"
      mc:Ignorable="d"
      Title="Stock global">
    <Page.Resources>
        <converters:StockStateToColorConverter x:Key="StockStateToColorConverter"/>
        <converters:StockStateToStringConverter x:Key="StockStateToStringConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dashboard Cards -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,20" Orientation="Horizontal">
            <!-- Total Products -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Total Produits" FontSize="14" Foreground="#757575"/>
                    <TextBlock Text="{Binding TotalProducts}" FontSize="36" FontWeight="Bold" Foreground="#2196F3" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Total Stock -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Total Stock" FontSize="14" Foreground="#757575"/>
                    <TextBlock Text="{Binding TotalStock}" FontSize="36" FontWeight="Bold" Foreground="#2196F3" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- OK -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="État OK" FontSize="14" Foreground="#757575"/>
                    <TextBlock Text="{Binding ProductsOk}" FontSize="36" FontWeight="Bold" Foreground="#4CAF50" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Alert -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" Width="180" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Alerte" FontSize="14" Foreground="#757575"/>
                    <TextBlock Text="{Binding ProductsAlert}" FontSize="36" FontWeight="Bold" Foreground="#FF9800" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Out of Stock -->
            <Border Background="White" CornerRadius="8" Padding="20" Width="180" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Rupture" FontSize="14" Foreground="#757575"/>
                    <TextBlock Text="{Binding ProductsOutOfStock}" FontSize="36" FontWeight="Bold" Foreground="#F44336" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Header Actions -->
        <DockPanel Grid.Row="1" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="250" Padding="8" Margin="0,0,10,0"
                         Tag="🔍 Recherche article..."
                         VerticalContentAlignment="Center"/>
                
                <ComboBox ItemsSource="{Binding StatusOptions}" 
                          SelectedItem="{Binding SelectedStatus}"
                          Width="150" Padding="8"/>
            </StackPanel>
        </DockPanel>

        <!-- Stock Table -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredProducts}" 
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="#E0E0E0"
                  RowHeight="40" SelectionMode="Single" GridLinesVisibility="None"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N°" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Désignation" Binding="{Binding Designation}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stock Actuel" Binding="{Binding CurrentStock}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Seuil Min" Binding="{Binding MinimumStock}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Unité" Binding="{Binding Unit}" Width="80" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="État" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="12" Height="12" Fill="{Binding Etat, Converter={StaticResource StockStateToColorConverter}}" 
                                         Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Etat, Converter={StaticResource StockStateToStringConverter}}" 
                                                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer Info -->
        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total: "/>
                    <TextBlock Text="{Binding FilteredProducts.Count}" FontWeight="Bold"/>
                    <TextBlock Text=" articles affichés" Margin="0,0,20,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Page>
