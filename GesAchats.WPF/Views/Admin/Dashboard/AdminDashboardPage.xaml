<Page x:Class="GesAchats.WPF.Views.Admin.Dashboard.AdminDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Tableau de bord Administrateur">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KPI Cards Section -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="25,25,25,10">
            <!-- Montant Total -->
            <Border Style="{StaticResource ModernCard}" Margin="0,0,15,0" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="💰" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Montant Total" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalAmount}" FontSize="20" FontWeight="Bold" Foreground="#22C55E"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Paiements -->
            <Border Style="{StaticResource ModernCard}" Margin="0,0,15,0" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🛒" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Paiements" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PaymentCount}" FontSize="20" FontWeight="Bold" Foreground="#3B82F6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Fournisseurs -->
            <Border Style="{StaticResource ModernCard}" Margin="0,0,15,0" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🏢" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Fournisseurs" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SupplierCount}" FontSize="20" FontWeight="Bold" Foreground="#F59E0B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Moyenne -->
            <Border Style="{StaticResource ModernCard}" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="💳" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Moyenne" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding AverageAmount}" FontSize="20" FontWeight="Bold" Foreground="#8B5CF6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Toggle Button -->
        <Button Grid.Row="1" 
                Command="{Binding ToggleChartsCommand}" 
                HorizontalAlignment="Left" 
                Margin="25,10,25,10"
                Style="{StaticResource ModernPrimaryButton}"
                Background="#3B82F6">
            <TextBlock Text="{Binding ShowCharts, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='Masquer les graphes|Afficher les graphes'}" 
                       Foreground="White"/>
        </Button>

        <!-- Charts Section -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Visibility="{Binding ShowCharts, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="25,10,25,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="400"/>
                    <RowDefinition Height="400"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 1: Distribution & Modes -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ModernCard}" Margin="0,0,15,15">
                    <DockPanel>
                        <TextBlock Text="Distribution par Fournisseur" DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding SupplierDistribution}" LegendPosition="Right" />
                    </DockPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                    <DockPanel>
                        <TextBlock Text="Modes de Paiement" DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding PaymentMethods}" XAxes="{Binding XAxesMethods}" />
                    </DockPanel>
                </Border>

                <!-- Row 2: Paiements par Date -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource ModernCard}">
                    <DockPanel>
                        <TextBlock Text="Paiements par Date" DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding PaymentsByDate}" XAxes="{Binding XAxesPayments}" />
                    </DockPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
