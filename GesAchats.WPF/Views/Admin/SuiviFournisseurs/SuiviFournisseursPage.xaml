<Page x:Class="GesAchats.WPF.Views.Admin.SuiviFournisseurs.SuiviFournisseursPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      mc:Ignorable="d"
      d:DesignHeight="1200" d:DesignWidth="1200"
      Title="Suivi Fournisseurs">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../../Resources/Comptable/ComptableStyles.xaml"/>
                <ResourceDictionary Source="../../../Resources/Shared/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="ModernDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="AlternationCount" Value="2"/>
                <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
            </Style>

            <Style x:Key="ModernDataGridHeader" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#F8FAFC"/>
                <Setter Property="Foreground" Value="#64748B"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="#0F172A"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#0F172A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FilterInputStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#D0CDE8"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="40,0"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <fa:IconImage Grid.Column="0" Icon="Search" Width="18" Height="18" Foreground="#6C5CE7" Margin="12,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Focusable="False"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  VerticalAlignment="Center"
                                                  Margin="36,0"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnPrimaryStyle" TargetType="Button">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#6C5CE7"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Foreground" Value="#6C5CE7"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#6C5CE7"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#6C5CE7"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#5A4BD1"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#5A4BD1"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PaginationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="#64748B"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Width" Value="36"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#6C5CE7"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#6C5CE7"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Suivi Fournisseurs" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Consultez et suivez tous vos fournisseurs." Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 1. KPI Cards -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ctrls:KpiCard Grid.Column="0" Margin="0,0,8,0"
                                   Title="Total Fournisseurs"
                                   Value="{Binding TotalFournisseurs}"
                                   Icon="Users"
                                   IconColor="#3B82F6"/>
                    <ctrls:KpiCard Grid.Column="1" Margin="4,0,8,0"
                                   Title="Commandes en Cours"
                                   Value="{Binding CommandesEnCours}"
                                   Icon="CartShopping"
                                   IconColor="#F59E0B"/>
                    <ctrls:KpiCard Grid.Column="2" Margin="4,0,8,0"
                                   Title="Total Commandé"
                                   Value="{Binding TotalCommande}"
                                   Unit="MAD"
                                   Icon="ChartBar"
                                   IconColor="#22C55E"/>
                    <ctrls:KpiCard Grid.Column="3" Margin="4,0,0,0"
                                   Title="Solde Total"
                                   Value="{Binding SoldeTotal}"
                                   Unit="MAD"
                                   Icon="CreditCard"
                                   IconColor="#EF4444"/>
                </Grid>

                <!-- 2. Search & Reset -->
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FilterInputStyle}"
                                 Margin="0,0,16,0"/>

                        <Button Grid.Column="1"
                                Command="{Binding ResetSearchCommand}"
                                Style="{StaticResource BtnPrimaryStyle}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="RotateRight" Width="16" Height="16" Foreground="#6C5CE7" Margin="0,0,8,0"/>
                                <TextBlock Text="Réinitialiser"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- 3. DataGrid -->
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,24">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Liste des fournisseurs" Foreground="#0F172A" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>

                        <DataGrid Style="{StaticResource ModernDataGrid}"
                                  ItemsSource="{Binding Fournisseurs}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  RowHeight="56"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ClipToBounds="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fournisseur"
                                                    Binding="{Binding NomFournisseur}"
                                                    Width="2*"
                                                    HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                    CellStyle="{StaticResource ModernDataGridCell}"/>

                                <DataGridTextColumn Header="Nom du contact"
                                                    Binding="{Binding NomContact}"
                                                    Width="1.5*"
                                                    HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                    CellStyle="{StaticResource ModernDataGridCell}"/>

                                <DataGridTemplateColumn Header="Téléphone" Width="1.5*"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconImage Icon="Phone" Width="16" Height="16" Foreground="#64748B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Telephone}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="E-mail" Width="2*"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconImage Icon="Envelope" Width="16" Height="16" Foreground="#64748B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Email}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Ville"
                                                    Binding="{Binding Ville}"
                                                    Width="1.2*"
                                                    HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                    CellStyle="{StaticResource ModernDataGridCell}"/>

                                <DataGridTemplateColumn Header="Action" Width="1.5*"
                                                        HeaderStyle="{StaticResource ModernDataGridHeader}"
                                                        CellStyle="{StaticResource ModernDataGridCell}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.VoirSituationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding Id}"
                                                    Style="{StaticResource BtnPrimaryStyle}"
                                                    Padding="12,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <fa:IconImage Icon="Eye" Width="14" Height="14" Foreground="#6C5CE7" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Voir la situation"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- 4. Pagination -->
                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding PaginationInfo}"
                                   Foreground="#64748B"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding PageFirstCommand}"
                                    Style="{StaticResource PaginationButtonStyle}"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding CanGoFirst}">
                                <fa:IconImage Icon="AngleDoubleLeft" Width="14" Height="14"/>
                            </Button>
                            <Button Command="{Binding PagePreviousCommand}"
                                    Style="{StaticResource PaginationButtonStyle}"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding CanGoPrevious}">
                                <fa:IconImage Icon="AngleLeft" Width="14" Height="14"/>
                            </Button>
                            <Button Command="{Binding PageNextCommand}"
                                    Style="{StaticResource PaginationButtonStyle}"
                                    Margin="6,0,6,0"
                                    IsEnabled="{Binding CanGoNext}">
                                <fa:IconImage Icon="AngleRight" Width="14" Height="14"/>
                            </Button>
                            <Button Command="{Binding PageLastCommand}"
                                    Style="{StaticResource PaginationButtonStyle}"
                                    IsEnabled="{Binding CanGoLast}">
                                <fa:IconImage Icon="AngleDoubleRight" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>