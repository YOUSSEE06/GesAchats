<Page x:Class="GesAchats.WPF.Views.Admin.NeedsHistory.AdminNeedsHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Admin.NeedsHistory"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Historique des Besoins - Admin">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Header -->
            <RowDefinition Height="Auto"/> <!-- Page Title -->
            <RowDefinition Height="*"/>    <!-- Data Table -->
        </Grid.RowDefinitions>

        <!-- 1. En-tête global (identique au dashboard) -->
        <Grid Grid.Row="0" Margin="25,25,25,10">
            <TextBlock Text="ESPACE ADMIN" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- 3. Zone principale - Titre de la page -->
        <TextBlock Grid.Row="1" Text="HISTORIQUE DES BESOINS" FontSize="20" FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="25,15,25,10"/>

        <!-- 3. Zone principale - Tableau -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="25,10,25,25">
            <DataGrid ItemsSource="{Binding Needs}" 
                      Style="{StaticResource ModernDataGrid}"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Demande" Binding="{Binding NumeroBesoin}" Width="180" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                    <DataGridTextColumn Header="Demandeur" Binding="{Binding Demandeur}" Width="180"/>
                    <DataGridTextColumn Header="Nb Articles" Binding="{Binding ArticleCount}" Width="100"/>
                    
                    <DataGridTemplateColumn Header="Statut" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Details" 
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ModernIconButton}"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
