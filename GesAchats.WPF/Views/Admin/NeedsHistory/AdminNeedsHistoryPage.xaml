<Page x:Class="GesAchats.WPF.Views.Admin.NeedsHistory.AdminNeedsHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Admin.NeedsHistory"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Historique des Besoins - Admin">

    <Page.Resources>
        <Style x:Key="FilterInputStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"
                                          Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" 
                                              Grid.Column="2" 
                                              Focusable="False" 
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Margin="12,0,30,0" 
                                                  VerticalAlignment="Center" 
                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                <TextBox x:Name="PART_EditableTextBox" 
                                         Style="{x:Null}" 
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         Padding="12,0" 
                                         VerticalAlignment="Center" 
                                         Focusable="True" 
                                         IsReadOnly="{TemplateBinding IsReadOnly}" 
                                         Visibility="Hidden"/>
                                <Path x:Name="Arrow" 
                                      Grid.Column="2" 
                                      Data="M0,0 L4,4 L8,0 Z" 
                                      Fill="#6C5CE7" 
                                      HorizontalAlignment="Right" 
                                      Margin="10,0" 
                                      VerticalAlignment="Center"/>
                                <Popup x:Name="Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       StaysOpen="False" 
                                       Focusable="False" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder" 
                                            Background="White" 
                                            BorderBrush="#D0CDE8" 
                                            BorderThickness="1" 
                                            CornerRadius="8" 
                                            Padding="0">
                                        <ScrollViewer Margin="0" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                            KeyboardNavigation.DirectionalNavigation="Continue"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterDateStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox 
                                    x:Name="PART_TextBox" 
                                    Grid.Column="0" 
                                    Foreground="{TemplateBinding Foreground}" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    VerticalContentAlignment="Center" 
                                    Padding="12,0" 
                                    FontSize="{TemplateBinding FontSize}"/>
                                <Button x:Name="PART_Button" 
                                        Grid.Column="1" 
                                        Width="32" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Cursor="Hand" 
                                        Focusable="False">
                                    <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                          Stroke="#6C5CE7" StrokeThickness="1.5" 
                                          StrokeLineJoin="Round" 
                                          StrokeStartLineCap="Round" 
                                          StrokeEndLineCap="Round" 
                                          Width="16" Height="16" 
                                          Stretch="Uniform"/>
                                </Button>
                                <Popup x:Name="PART_Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Calendar x:Name="PART_Calendar"/>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnResetStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                CornerRadius="19" 
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#5A4BD1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#4A3BBF"/>
                                <Setter TargetName="Bd" 
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E8E0F8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#F0EBFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="MinHeight" Value="44"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAF8FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F0EBFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BlueCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnVoirStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="BorderBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A4BD1"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6C5CE7"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Header -->
            <RowDefinition Height="Auto"/> <!-- Page Title -->
            <RowDefinition Height="Auto"/> <!-- KPIs -->
            <RowDefinition Height="Auto"/> <!-- Filters Bar -->
            <RowDefinition Height="*"/>    <!-- Data Table -->
            <RowDefinition Height="Auto"/> <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- 1. En-tête global (identique au dashboard) -->
        <Grid Grid.Row="0" Margin="25,25,25,10">
            <TextBlock Text="ESPACE ADMIN" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- 3. Zone principale - Titre de la page -->
        <TextBlock Grid.Row="1" Text="HISTORIQUE DES BESOINS" FontSize="20" FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="25,15,25,10"/>

        <!-- 3.0 Zone des KPIs -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="5" Margin="25,10">
            <ctrls:KpiCard Title="Total Besoins" 
                           Value="{Binding TotalBesoins}" 
                           TrendText="{Binding TotalBesoinsTrendText}"
                           Icon="ClipboardList" 
                           IconColor="#2563EB" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Besoins En Cours" 
                           Value="{Binding BesoinsEnCours}" 
                           TrendText="{Binding BesoinsEnCoursTrendText}"
                           Icon="Clock" 
                           IconColor="#F59E0B" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Besoins Transmis" 
                           Value="{Binding BesoinsTransmis}" 
                           TrendText="{Binding BesoinsTransmisTrendText}"
                           Icon="Share" 
                           IconColor="#10B981" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Articles Demandés" 
                           Value="{Binding TotalArticlesDemandes}" 
                           TrendText="{Binding TotalArticlesDemandesTrendText}"
                           Icon="BoxesStacked" 
                           IconColor="#8B5CF6" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Demandeurs Actifs" 
                           Value="{Binding DemandeursActifs}" 
                           TrendText="{Binding DemandeursActifsTrendText}"
                           Icon="Users" 
                           IconColor="#6366F1" 
                           Margin="0,0,0,0"/>
        </UniformGrid>

        <!-- 3.1 Filtres -->
        <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="25,5,25,10" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🔍" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="N° Demande" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding SearchNumero, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FilterInputStyle}"
                             HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Date" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DatePicker SelectedDate="{Binding SearchDate}" 
                                Style="{StaticResource FilterDateStyle}"
                                HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🎛️" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Style="{StaticResource FilterComboStyle}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Réinitialiser" 
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource BtnResetStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3.2 Zone principale - Tableau -->
        <Border Grid.Row="4" Style="{StaticResource ModernCard}" Margin="25,10,25,10">
            <DataGrid ItemsSource="{Binding Needs}" 
                      GridLinesVisibility="None" 
                      BorderThickness="1" 
                      BorderBrush="#E8E0F8" 
                      RowHeight="44" 
                      Background="White" 
                      AlternatingRowBackground="#FDFCFF" 
                      HeadersVisibility="Column"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.IsDeferredScrollingEnabled="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Demande" Binding="{Binding NumeroBesoin}" Width="180" CellStyle="{StaticResource BlueCellStyle}"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="150" CellStyle="{StaticResource BlueCellStyle}"/>
                    <DataGridTextColumn Header="Demandeur" Binding="{Binding Demandeur}" Width="*"/>
                    <DataGridTextColumn Header="Nb Articles" Binding="{Binding ArticleCount}" Width="120"/>

                    <DataGridTemplateColumn Header="Statut" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBorder" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                    <TextBlock x:Name="StatusText" Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding StatusText}" Value="En cours">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#3B82F6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="Transmis">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#10B981"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="Validé">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#22C55E"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="Annulé">
                                        <Setter TargetName="StatusBorder" Property="Background" Value="#EF4444"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Details" 
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource BtnVoirStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 4. Pagination -->
        <Border Grid.Row="5" Style="{StaticResource ModernCard}" Margin="25,0,25,25" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding PaginationInfo}"
                           Foreground="#64748B"
                           FontSize="14"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding FirstPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding CanGoToFirstPage}">
                        <TextBlock Text="«" FontSize="16" FontWeight="Bold"/>
                    </Button>
                    <Button Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding CanGoToPreviousPage}">
                        <TextBlock Text="‹" FontSize="16" FontWeight="Bold"/>
                    </Button>
                    <Button Command="{Binding NextPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            Margin="6,0,6,0"
                            IsEnabled="{Binding CanGoToNextPage}">
                        <TextBlock Text="›" FontSize="16" FontWeight="Bold"/>
                    </Button>
                    <Button Command="{Binding LastPageCommand}"
                            Style="{StaticResource PaginationButtonStyle}"
                            IsEnabled="{Binding CanGoToLastPage}">
                        <TextBlock Text="»" FontSize="16" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
