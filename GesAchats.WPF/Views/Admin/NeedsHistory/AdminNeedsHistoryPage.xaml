<Page x:Class="GesAchats.WPF.Views.Admin.NeedsHistory.AdminNeedsHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Admin.NeedsHistory"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Historique des Besoins - Admin">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Header -->
            <RowDefinition Height="Auto"/> <!-- Page Title -->
            <RowDefinition Height="Auto"/> <!-- KPIs -->
            <RowDefinition Height="Auto"/> <!-- Filters Bar -->
            <RowDefinition Height="*"/>    <!-- Data Table -->
        </Grid.RowDefinitions>

        <!-- 1. En-tête global (identique au dashboard) -->
        <Grid Grid.Row="0" Margin="25,25,25,10">
            <TextBlock Text="ESPACE ADMIN" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- 3. Zone principale - Titre de la page -->
        <TextBlock Grid.Row="1" Text="HISTORIQUE DES BESOINS" FontSize="20" FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="25,15,25,10"/>

        <!-- 3.0 Zone des KPIs -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="5" Margin="25,10">
            <ctrls:KpiCard Title="Total Besoins" 
                           Value="{Binding TotalBesoins}" 
                           TrendText="{Binding TotalBesoinsTrendText}"
                           Icon="ClipboardList" 
                           IconColor="#2563EB" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Besoins En Cours" 
                           Value="{Binding BesoinsEnCours}" 
                           TrendText="{Binding BesoinsEnCoursTrendText}"
                           Icon="Clock" 
                           IconColor="#F59E0B" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Besoins Transmis" 
                           Value="{Binding BesoinsTransmis}" 
                           TrendText="{Binding BesoinsTransmisTrendText}"
                           Icon="Share" 
                           IconColor="#10B981" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Articles Demandés" 
                           Value="{Binding TotalArticlesDemandes}" 
                           TrendText="{Binding TotalArticlesDemandesTrendText}"
                           Icon="BoxesStacked" 
                           IconColor="#8B5CF6" 
                           Margin="0,0,14,0"/>

            <ctrls:KpiCard Title="Demandeurs Actifs" 
                           Value="{Binding DemandeursActifs}" 
                           TrendText="{Binding DemandeursActifsTrendText}"
                           Icon="Users" 
                           IconColor="#6366F1" 
                           Margin="0,0,0,0"/>
        </UniformGrid>

        <!-- 3.1 Filtres -->
        <Border Grid.Row="3" Style="{StaticResource ModernCard}" Margin="25,5,25,10" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search Icon -->
                    <ColumnDefinition Width="Auto"/> <!-- Numero Filter -->
                    <ColumnDefinition Width="Auto"/> <!-- Date Filter -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Buttons -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,25,0">
                    <TextBlock Text="N° Demande:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SearchNumero, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" 
                             Width="200"
                             Tag="Rechercher par numéro..."/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,25,0">
                    <TextBlock Text="Filtrer par Date:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <DatePicker SelectedDate="{Binding SearchDate}" 
                                Style="{StaticResource ModernDatePicker}" 
                                Width="160"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,25,0">
                    <TextBlock Text="Statut:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Style="{StaticResource ModernComboBox}"
                              Width="150"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="Réinitialiser" 
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource ModernIconButton}"
                            Foreground="{StaticResource DangerBrush}"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3.2 Zone principale - Tableau -->
        <Border Grid.Row="4" Style="{StaticResource ModernCard}" Margin="25,10,25,25">
            <DataGrid ItemsSource="{Binding Needs}" 
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Demande" Binding="{Binding NumeroBesoin}" Width="180" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="150"/>
                    <DataGridTextColumn Header="Demandeur" Binding="{Binding Demandeur}" Width="*"/>
                    <DataGridTextColumn Header="Nb Articles" Binding="{Binding ArticleCount}" Width="120"/>

                    <DataGridTemplateColumn Header="Statut" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Details" 
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ModernIconButton}"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
