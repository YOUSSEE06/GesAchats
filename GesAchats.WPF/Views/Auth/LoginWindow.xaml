<Window x:Class="GesAchats.WPF.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        WindowState="Maximized"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        MinWidth="1200"
        MinHeight="700"
        Background="#F5F7FF">
    
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="White" CornerRadius="20" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="1200" MaxHeight="700"
                MinWidth="1000" MinHeight="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.1" Color="#000000"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Panel (Blue) -->
                <Border Grid.Column="0" CornerRadius="20,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D47A1" Offset="0"/>
                            <GradientStop Color="#1565C0" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <!-- Decorative shapes -->
                        <Path Data="M0,0 L200,0 L0,200 Z" Fill="#1976D2" Opacity="0.4" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Path Data="M250,400 L450,400 L450,600 L250,600 Z" Fill="#0D47A1" Opacity="0.3" Stretch="None" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="50" VerticalAlignment="Center">
                                <!-- Logo -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Background="White" CornerRadius="15" Padding="12">
                                        <TextBlock Text="🔷" FontSize="30"/>
                                    </Border>
                                    <TextBlock Text="GesAchats" FontSize="32" FontWeight="Bold" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="Gestion intelligente des achats" FontSize="14" Foreground="#90CAF9" Margin="0,0,0,40"/>
                                
                                <!-- Features -->
                                <StackPanel Margin="0,0,0,30">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                        <Border Background="#1565C0" CornerRadius="12" Padding="12" Width="50" Height="50">
                                            <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="15,0,0,0">
                                            <TextBlock Text="Achats optimisés" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="Gerez vos achats, fournisseurs et commandes efficacement." FontSize="13" Foreground="#90CAF9" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                        <Border Background="#1565C0" CornerRadius="12" Padding="12" Width="50" Height="50">
                                            <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="15,0,0,0">
                                            <TextBlock Text="Fournisseurs centralisés" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="Collaborez avec vos fournisseurs en toute transparence." FontSize="13" Foreground="#90CAF9" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#1565C0" CornerRadius="12" Padding="12" Width="50" Height="50">
                                            <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="15,0,0,0">
                                            <TextBlock Text="Analyses puissantes" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="Prenez des décisions basées sur des données fiables." FontSize="13" Foreground="#90CAF9" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Version -->
                                <Border Background="#0D47A1" CornerRadius="15" Padding="15,8" HorizontalAlignment="Left">
                                    <TextBlock Text="Version 1.0.0" FontSize="12" Foreground="White" Opacity="0.7"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
                <!-- Right Panel (White) -->
                <Border Grid.Column="1" Padding="60">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel VerticalAlignment="Center">
                            <!-- User Icon -->
                            <Border Background="White" HorizontalAlignment="Center" Width="80" Height="80" CornerRadius="40">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.15" Color="#000000"/>
                                </Border.Effect>
                                <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="Bienvenue !" FontSize="30" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,25,0,5"/>
                            <TextBlock Text="Connectez-vous à votre compte" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                            
                            <!-- Email Field -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Email / Identifiant" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                                <Border x:Name="EmailBorder" BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="👤" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="EmailTextBox" 
                                                     Text="{Binding LoginOrEmail, UpdateSourceTrigger=PropertyChanged}" 
                                                     BorderThickness="0" Padding="0" 
                                                     FontSize="14" Foreground="#1E293B"
                                                     VerticalContentAlignment="Center"/>
                                            <TextBlock Text="Entrez votre email ou identifiant" 
                                                       FontSize="14" Foreground="#94A3B8" 
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            
                            <!-- Password Field -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="Mot de passe" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                                <Border x:Name="PasswordBorder" BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🔒" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Grid Grid.Column="1">
                                            <PasswordBox x:Name="TxtPassword" BorderThickness="0" Padding="0" FontSize="14" Visibility="{Binding PasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="TxtVisiblePassword" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="0" FontSize="14" Visibility="{Binding PasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}" VerticalContentAlignment="Center"/>
                                            <TextBlock x:Name="PasswordPlaceholder" 
                                                       Text="Entrez votre mot de passe" 
                                                       FontSize="14" Foreground="#94A3B8" 
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                        <Button x:Name="TogglePasswordBtn" Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0" Margin="5,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand" Width="40" Height="40">
                                            <TextBlock Text="{Binding PasswordToggleIcon}" FontSize="18" Foreground="#94A3B8"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            
                            <!-- Forgot Password Button -->
                            <Button Content="Mot de passe oublié ?"
                                    Command="{Binding ForgotPasswordCommand}"
                                    Background="Transparent"
                                    Foreground="#4F46E5"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,25"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            
                            <!-- Error Message -->
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" 
                                       TextWrapping="Wrap" Margin="0,0,0,20" MinHeight="20" FontSize="13"
                                       HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <!-- Login Button -->
                            <Button Command="{Binding LoginCommand}" 
                                    CommandParameter="{Binding ElementName=TxtPassword}"
                                    HorizontalAlignment="Stretch"
                                    IsDefault="True">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ButtonBorder" Background="#1565C0" CornerRadius="10" Padding="20,14">
                                                        <Grid>
                                                            <TextBlock Text="➔" FontSize="14" Foreground="White" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                                                            <TextBlock Text="Se connecter" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ButtonBorder" Property="Background" Value="#0D47A1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Progress Bar -->
                            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,25,0,0"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Foreground="#1565C0" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
