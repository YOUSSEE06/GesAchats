<Window x:Class="GesAchats.WPF.Views.Auth.ResetPasswordWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
             mc:Ignorable="d"
             Title="{Binding Title}"
             WindowState="Maximized"
             ResizeMode="CanResize"
             SizeToContent="Manual"
             WindowStartupLocation="CenterScreen"
             MinWidth="1200"
             MinHeight="700"
             Background="#F5F7FF">
    <Window.Resources>
        <converters:BooleanToBrushConverter x:Key="CheckToBrush" TrueBrush="{StaticResource SuccessBrush}" FalseBrush="{StaticResource TextSecondaryBrush}"/>
    </Window.Resources>
    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Border Background="White" CornerRadius="20" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="1200" MaxHeight="700"
                MinWidth="1000" MinHeight="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.1" Color="#000000"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Panel (Blue) -->
                <Border Grid.Column="0" CornerRadius="20,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D47A1" Offset="0"/>
                            <GradientStop Color="#1565C0" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <!-- Decorative shapes -->
                        <Path Data="M0,0 L200,0 L0,200 Z" Fill="#1976D2" Opacity="0.4" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Path Data="M250,400 L450,400 L450,600 L250,600 Z" Fill="#0D47A1" Opacity="0.3" Stretch="None" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="50" VerticalAlignment="Center">
                            <!-- Logo -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="White" CornerRadius="15" Padding="12">
                                    <TextBlock Text="🔷" FontSize="30"/>
                                </Border>
                                <TextBlock Text="GesAchats" FontSize="32" FontWeight="Bold" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Text="Gestion intelligente des achats" FontSize="14" Foreground="#90CAF9" Margin="0,0,0,50"/>
                            
                            <!-- Features -->
                            <StackPanel Margin="0,0,0,30">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <Border Background="#1565C0" CornerRadius="12" Padding="12" Width="50" Height="50">
                                        <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="15,0,0,0">
                                        <TextBlock Text="Achats optimisés" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Gerez vos achats, fournisseurs et commandes efficacement." FontSize="13" Foreground="#90CAF9" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <Border Background="#1565C0" CornerRadius="12" Padding="12" Width="50" Height="50">
                                        <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="15,0,0,0">
                                        <TextBlock Text="Fournisseurs centralisés" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Collaborez avec vos fournisseurs en toute transparence." FontSize="13" Foreground="#90CAF9" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1565C0" CornerRadius="12" Padding="12" Width="50" Height="50">
                                        <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="15,0,0,0">
                                        <TextBlock Text="Analyses puissantes" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Prenez des décisions basées sur des données fiables." FontSize="13" Foreground="#90CAF9" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Version -->
                            <Border Background="#0D47A1" CornerRadius="15" Padding="15,8" HorizontalAlignment="Left">
                                <TextBlock Text="Version 1.0.0" FontSize="12" Foreground="White" Opacity="0.7"/>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
                <!-- Right Panel (White) -->
                <Border Grid.Column="1" Padding="60">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel VerticalAlignment="Center">
                            <!-- User Icon -->
                            <Border Background="White" HorizontalAlignment="Center" Width="80" Height="80" CornerRadius="40">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.15" Color="#000000"/>
                                </Border.Effect>
                                <TextBlock Text="🔑" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="Réinitialiser le mot de passe" FontSize="24" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,25,0,5"/>
                            <TextBlock Text="Suivez les étapes pour réinitialiser votre mot de passe" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                            
                            <!-- Step 1: Email -->
                            <StackPanel Visibility="{Binding IsEmailStepVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Email professionnel" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📧" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Grid Grid.Column="1">
                                                <TextBox x:Name="Step1EmailTextBox"
                                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         BorderThickness="0" Padding="0" 
                                                         FontSize="14" Foreground="#1E293B"
                                                         VerticalContentAlignment="Center"/>
                                                <TextBlock Text="Entrez votre email professionnel"
                                                           FontSize="14" Foreground="#94A3B8" 
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <Button Command="{Binding SendCodeCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="ButtonBorder" Background="#1565C0" CornerRadius="10" Padding="20,14">
                                                            <TextBlock Text="Envoyer le code" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0D47A1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                            
                            <!-- Step 2: Code -->
                            <StackPanel Visibility="{Binding IsCodeStepVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Email professionnel" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0" Background="#F8FAFC">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📧" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBox Text="{Binding Email}" IsEnabled="False"
                                                     Grid.Column="1"
                                                     BorderThickness="0" Padding="0" 
                                                     FontSize="14" Foreground="#64748B"
                                                     VerticalContentAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Code de validation" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔐" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Grid Grid.Column="1">
                                                <TextBox x:Name="Step2CodeTextBox"
                                                         Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         BorderThickness="0" Padding="0" 
                                                         FontSize="14" Foreground="#1E293B"
                                                         VerticalContentAlignment="Center" MaxLength="6"/>
                                                <TextBlock Text="Entrez le code de 6 chiffres"
                                                           FontSize="14" Foreground="#94A3B8" 
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <Button Command="{Binding VerifyCodeCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="ButtonBorder" Background="#1565C0" CornerRadius="10" Padding="20,14">
                                                            <TextBlock Text="Vérifier le code" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0D47A1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                            
                            <!-- Step 3: New Password -->
                            <StackPanel Visibility="{Binding IsPasswordStepVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Email professionnel" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0" Background="#F8FAFC">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📧" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBox Text="{Binding Email}" IsEnabled="False"
                                                     Grid.Column="1"
                                                     BorderThickness="0" Padding="0" 
                                                     FontSize="14" Foreground="#64748B"
                                                     VerticalContentAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Code de validation" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0" Background="#F8FAFC">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔐" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBox Text="{Binding VerificationCode}" IsEnabled="False"
                                                     Grid.Column="1"
                                                     BorderThickness="0" Padding="0" 
                                                     FontSize="14" Foreground="#64748B"
                                                     VerticalContentAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Nouveau mot de passe" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔒" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Grid Grid.Column="1">
                                                <PasswordBox x:Name="TxtNewPassword" BorderThickness="0" Padding="0" FontSize="14" VerticalContentAlignment="Center"/>
                                                <TextBlock x:Name="NewPasswordPlaceholder"
                                                           Text="Entrez votre nouveau mot de passe"
                                                           FontSize="14" Foreground="#94A3B8" 
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <!-- Password Strength UI -->
                                    <StackPanel Margin="15,10,0,0">
                                        <!-- Strength Bar -->
                                        <Grid Height="8" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Margin="0,0,2,0" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=1}" Value="True">
                                                                <Setter Property="Background" Value="#DC2626"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=2}" Value="True">
                                                                <Setter Property="Background" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                                <Setter Property="Background" Value="#1565C0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <Border Grid.Column="1" Margin="2,0,2,0" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=2}" Value="True">
                                                                <Setter Property="Background" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                                <Setter Property="Background" Value="#1565C0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <Border Grid.Column="2" Margin="2,0,2,0" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=3}" Value="True">
                                                                <Setter Property="Background" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                                <Setter Property="Background" Value="#1565C0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <Border Grid.Column="3" Margin="2,0,2,0" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                                <Setter Property="Background" Value="#1565C0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <Border Grid.Column="4" Margin="2,0,0,0" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                                <Setter Property="Background" Value="#10B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                        <!-- Strength Label -->
                                        <TextBlock Text="{Binding PasswordStrengthLabel}" FontWeight="Bold" FontSize="13" Margin="0,0,0,10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PasswordStrengthLabel}" Value="Moyen">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PasswordStrengthLabel}" Value="Bon">
                                                            <Setter Property="Foreground" Value="#1565C0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PasswordStrengthLabel}" Value="Fort">
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Checklist -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                <TextBlock Text="✓ " Foreground="{Binding HasMinLength, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="Au moins 8 caractères" Foreground="{Binding HasMinLength, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                <TextBlock Text="✓ " Foreground="{Binding HasLowercase, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="Une lettre minuscule" Foreground="{Binding HasLowercase, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                <TextBlock Text="✓ " Foreground="{Binding HasUppercase, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="Une lettre majuscule" Foreground="{Binding HasUppercase, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                <TextBlock Text="✓ " Foreground="{Binding HasDigit, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="Un chiffre" Foreground="{Binding HasDigit, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                                <TextBlock Text="✓ " Foreground="{Binding HasSpecialCharacter, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="Un caractère spécial" Foreground="{Binding HasSpecialCharacter, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Confirmer le mot de passe" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#475569"/>
                                    <Border BorderBrush="#DDE3EE" BorderThickness="1" CornerRadius="12" Height="48" Padding="14,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔒" FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Grid Grid.Column="1">
                                                <PasswordBox x:Name="TxtConfirmPassword" BorderThickness="0" Padding="0" FontSize="14" VerticalContentAlignment="Center"/>
                                                <TextBlock x:Name="ConfirmPasswordPlaceholder"
                                                           Text="Confirmez votre nouveau mot de passe"
                                                           FontSize="14" Foreground="#94A3B8" 
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="15,5,0,0">
                                        <TextBlock Text="✓ " Foreground="{Binding DoPasswordsMatch, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="Les mots de passe correspondent" Foreground="{Binding DoPasswordsMatch, Converter={StaticResource CheckToBrush}}" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <Button Command="{Binding ResetPasswordCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,15">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="ButtonBorder" Background="#1565C0" CornerRadius="10" Padding="20,14">
                                                            <TextBlock Text="Réinitialiser le mot de passe" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0D47A1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                            
                            <!-- Message -->
                            <TextBlock Text="{Binding Message}"
                                       TextWrapping="Wrap" Margin="0,0,0,20" MinHeight="20" FontSize="13"
                                       HorizontalAlignment="Center" TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- Back Button -->
                            <Button Content="Retour à la connexion"
                                    Command="{Binding GoBackCommand}"
                                    Background="Transparent"
                                    Foreground="#4F46E5"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center"
                                    BorderThickness="0"
                                    Cursor="Hand"/>
                            
                            <!-- Progress Bar -->
                            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,25,0,0"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Foreground="#1565C0" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
