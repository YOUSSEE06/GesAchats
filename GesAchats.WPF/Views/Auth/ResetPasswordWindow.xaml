<Window x:Class="GesAchats.WPF.Views.Auth.ResetPasswordWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:GesAchats.WPF.Converters"
             mc:Ignorable="d"
             Title="{Binding Title}"
             WindowState="Maximized"
             ResizeMode="CanResize"
             SizeToContent="Manual"
             WindowStartupLocation="CenterScreen"
             MinWidth="900"
             MinHeight="600"
             Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <converters:BooleanToBrushConverter x:Key="CheckToBrush" TrueBrush="{StaticResource SuccessBrush}" FalseBrush="{StaticResource TextSecondaryBrush}"/>
    </Window.Resources>
    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Border Width="600" Background="{StaticResource SurfaceBrush}" CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Direction="-90" RenderingBias="Quality" ShadowDepth="5" Opacity="0.15"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="40">
                    <TextBlock Text="Réinitialisation du mot de passe" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Suivez les étapes ci-dessous" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,40"/>

                    <!-- Step 1: Email -->
                    <StackPanel Visibility="{Binding IsEmailStepVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Email professionnel" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"/>
                        </StackPanel>
                        <Button Content="Envoyer le code"
                                Command="{Binding SendCodeCommand}"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White" FontWeight="Bold"
                                Padding="20" FontSize="16" Cursor="Hand"
                                Margin="0,0,0,25">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Step 2: Code -->
                    <StackPanel Visibility="{Binding IsCodeStepVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Email professionnel" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox Text="{Binding Email}" IsEnabled="False"
                                     Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Code de validation" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     MaxLength="6"/>
                        </StackPanel>
                        <Button Content="Vérifier le code"
                                Command="{Binding VerifyCodeCommand}"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White" FontWeight="Bold"
                                Padding="20" FontSize="16" Cursor="Hand"
                                Margin="0,0,0,25">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Step 3: New Password -->
                    <StackPanel Visibility="{Binding IsPasswordStepVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Email professionnel" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox Text="{Binding Email}" IsEnabled="False"
                                     Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Code de validation" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox Text="{Binding VerificationCode}" IsEnabled="False"
                                     Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Nouveau mot de passe" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <PasswordBox x:Name="TxtNewPassword" Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"/>
                            <!-- Password Strength UI -->
                            <StackPanel Margin="15,10,0,0">
                                <!-- Strength Bar -->
                                <Grid Height="8" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Margin="0,0,2,0" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=1}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=2}" Value="True">
                                                        <Setter Property="Background" Value="#FFD4BE00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Grid.Column="1" Margin="2,0,2,0" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=2}" Value="True">
                                                        <Setter Property="Background" Value="#FFD4BE00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Grid.Column="2" Margin="2,0,2,0" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=3}" Value="True">
                                                        <Setter Property="Background" Value="#FFD4BE00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Grid.Column="3" Margin="2,0,2,0" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=4}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border Grid.Column="4" Margin="2,0,0,0" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PasswordScore, Converter={StaticResource GreaterOrEqualConverter}, ConverterParameter=5}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>
                                <!-- Strength Label -->
                                <TextBlock Text="{Binding PasswordStrengthLabel}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PasswordStrengthLabel}" Value="Moyen">
                                                    <Setter Property="Foreground" Value="#FFD4BE00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PasswordStrengthLabel}" Value="Bon">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PasswordStrengthLabel}" Value="Fort">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Checklist -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                        <TextBlock Text="✓ " Foreground="{Binding HasMinLength, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="Au moins 8 caractères" Foreground="{Binding HasMinLength, Converter={StaticResource CheckToBrush}}" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                        <TextBlock Text="✓ " Foreground="{Binding HasLowercase, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="Une lettre minuscule" Foreground="{Binding HasLowercase, Converter={StaticResource CheckToBrush}}" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                        <TextBlock Text="✓ " Foreground="{Binding HasUppercase, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="Une lettre majuscule" Foreground="{Binding HasUppercase, Converter={StaticResource CheckToBrush}}" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                        <TextBlock Text="✓ " Foreground="{Binding HasDigit, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="Un chiffre" Foreground="{Binding HasDigit, Converter={StaticResource CheckToBrush}}" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                        <TextBlock Text="✓ " Foreground="{Binding HasSpecialCharacter, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="Un caractère spécial" Foreground="{Binding HasSpecialCharacter, Converter={StaticResource CheckToBrush}}" FontSize="14"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Confirmer le mot de passe" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <PasswordBox x:Name="TxtConfirmPassword" Padding="15,12" FontSize="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="15,5,0,0">
                                <TextBlock Text="✓ " Foreground="{Binding DoPasswordsMatch, Converter={StaticResource CheckToBrush}}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Les mots de passe correspondent" Foreground="{Binding DoPasswordsMatch, Converter={StaticResource CheckToBrush}}" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="Réinitialiser le mot de passe"
                                Command="{Binding ResetPasswordCommand}"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White" FontWeight="Bold"
                                Padding="20" FontSize="16" Cursor="Hand"
                                Margin="0,0,0,15">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding Message}"
                               TextWrapping="Wrap" Margin="0,10,0,20" MinHeight="40" FontSize="14"
                               HorizontalAlignment="Center" TextAlignment="Center" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Content="Retour à la connexion"
                            Command="{Binding GoBackCommand}"
                            Background="Transparent"
                            Foreground="{StaticResource PrimaryBrush}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,30,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Foreground="{StaticResource PrimaryBrush}" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
