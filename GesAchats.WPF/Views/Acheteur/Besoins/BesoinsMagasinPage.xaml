<Page x:Class="GesAchats.WPF.Views.Acheteur.Besoins.BesoinsMagasinPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Besoins Magasin">

    <Page.Resources>
        <Style x:Key="TextCenterStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="DEMANDES DE RÉAPPROVISIONNEMENT" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="&#x21bb; Actualiser" Command="{Binding RefreshCommand}" HorizontalAlignment="Right" Padding="15,8" Background="Transparent"/>
        </DockPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Needs}" AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                  RowHeight="60" GridLinesVisibility="None" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N° Demande" Binding="{Binding Need.NumeroBesoin}" Width="150" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Need.DateTransmission, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Demandeur" Binding="{Binding Need.RequestedBy.FullName}" Width="*"/>
                <DataGridTextColumn Header="Nb Articles" Binding="{Binding ArticleCount}" Width="120" ElementStyle="{StaticResource TextCenterStyle}"/>
                <DataGridTemplateColumn Header="Statut" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Need.Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Détails" 
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Margin="5"/>
                                <Button Content="Créer un devis" 
                                        Command="{Binding DataContext.CreateQuoteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#4CAF50"
                                        Margin="5"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
