<Page x:Class="GesAchats.WPF.Views.Acheteur.Besoins.BesoinsMagasinPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d"
      Title="Besoins Magasin">

    <Page.Resources>
        <Style x:Key="RoundedActionButton" TargetType="Button">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="BtnResetStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                CornerRadius="19" 
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#5A4BD1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#4A3BBF"/>
                                <Setter TargetName="Bd" 
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterInputStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"
                                          Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" 
                                              Grid.Column="2" 
                                              Focusable="False" 
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Margin="12,0,30,0" 
                                                  VerticalAlignment="Center" 
                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                <TextBox x:Name="PART_EditableTextBox" 
                                         Style="{x:Null}" 
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         Padding="12,0" 
                                         VerticalAlignment="Center" 
                                         Focusable="True" 
                                         IsReadOnly="{TemplateBinding IsReadOnly}" 
                                         Visibility="Hidden"/>
                                <Path x:Name="Arrow" 
                                      Grid.Column="2" 
                                      Data="M0,0 L4,4 L8,0 Z" 
                                      Fill="#6C5CE7" 
                                      HorizontalAlignment="Right" 
                                      Margin="10,0" 
                                      VerticalAlignment="Center"/>
                                <Popup x:Name="Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       StaysOpen="False" 
                                       Focusable="False" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder" 
                                            Background="White" 
                                            BorderBrush="#D0CDE8" 
                                            BorderThickness="1" 
                                            CornerRadius="8" 
                                            Padding="0">
                                        <ScrollViewer Margin="0" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                            KeyboardNavigation.DirectionalNavigation="Continue"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterDateStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox 
                                    x:Name="PART_TextBox" 
                                    Grid.Column="0" 
                                    Foreground="{TemplateBinding Foreground}" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    VerticalContentAlignment="Center" 
                                    Padding="12,0" 
                                    FontSize="{TemplateBinding FontSize}"/>
                                <Button x:Name="PART_Button" 
                                        Grid.Column="1" 
                                        Width="32" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Cursor="Hand" 
                                        Focusable="False">
                                    <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                          Stroke="#6C5CE7" StrokeThickness="1.5" 
                                          StrokeLineJoin="Round" 
                                          StrokeStartLineCap="Round" 
                                          StrokeEndLineCap="Round" 
                                          Width="16" Height="16" 
                                          Stretch="Uniform"/>
                                </Button>
                                <Popup x:Name="PART_Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Calendar x:Name="PART_Calendar"/>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <DockPanel Grid.Row="0" Margin="20,20,20,0">
            <TextBlock Text="DEMANDES DE RÉAPPROVISIONNEMENT" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
        </DockPanel>

        <!-- KPI Section -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ctrls:KpiCard Grid.Column="0"
                Title="Total des Besoins"
                Value="{Binding TotalNeeds}"
                TrendText="{Binding TotalNeedsTrendText}"
                Icon="Box"
                IconColor="#3B82F6"
                Margin="0,0,10,0"/>

            <ctrls:KpiCard Grid.Column="1"
                Title="Besoins Transmis"
                Value="{Binding TransmittedNeeds}"
                TrendText="{Binding TransmittedNeedsTrendText}"
                Icon="PaperPlane"
                IconColor="#2196F3"
                Margin="5,0,5,0"/>

            <ctrls:KpiCard Grid.Column="2"
                Title="Besoins En cours"
                Value="{Binding InProgressNeeds}"
                TrendText="{Binding InProgressNeedsTrendText}"
                Icon="Clock"
                IconColor="#FFC107"
                Margin="5,0,5,0"/>

            <ctrls:KpiCard Grid.Column="3"
                Title="Besoins Annulés"
                Value="{Binding CancelledNeeds}"
                TrendText="{Binding CancelledNeedsTrendText}"
                Icon="TimesCircle"
                IconColor="#F44336"
                Margin="10,0,0,0"/>
        </Grid>
        
        <!-- Filters -->
        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="20" Margin="20,0,20,20">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="📋" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="N° Demande" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding SearchNumeroDemande, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource FilterInputStyle}"
                             HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Date" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DatePicker SelectedDate="{Binding SearchDate}" 
                                Style="{StaticResource FilterDateStyle}"
                                HorizontalAlignment="Stretch"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="🎛️" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding StatusOptions}" 
                              SelectedItem="{Binding SelectedStatus}" 
                              Style="{StaticResource FilterComboStyle}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
                
                <Button Grid.Column="3" Command="{Binding ResetFiltersCommand}" 
                        Style="{StaticResource BtnResetStyle}"
                        VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Réinitialiser"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Table Section -->
        <Border Grid.Row="3" Margin="20,0,20,20" Padding="0">
            <Border Style="{StaticResource ModernCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="24,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <TextBlock Text="Liste des demandes" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                    </Border>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Needs}" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              Style="{StaticResource ModernDataGrid}"
                              MinWidth="1100"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="16,14"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#4F46E5"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N° DEMANDE" Binding="{Binding Need.NumeroBesoin}" Width="180" MinWidth="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="16,12"/>
                                        <Setter Property="Foreground" Value="#4F46E5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DATE" Binding="{Binding Need.DateTransmission, StringFormat='dd/MM/yyyy'}" Width="140" MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="16,12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DEMANDEUR" Binding="{Binding Need.RequestedBy.FullName}" Width="*" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="16,12"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="NB ARTICLES" Binding="{Binding ArticleCount}" Width="140" MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="16,12"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTemplateColumn Header="STATUT" Width="180" MinWidth="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,5" CornerRadius="20" HorizontalAlignment="Left" Margin="16,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="transmit">
                                                            <Setter Property="Background" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="encours">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="À valider">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Validé">
                                                            <Setter Property="Background" Value="#D1FAE5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Brouillon">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Relancé">
                                                            <Setter Property="Background" Value="#FCE7F3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="transmit">
                                                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="encours">
                                                                <Setter Property="Foreground" Value="#EA580C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="À valider">
                                                                <Setter Property="Foreground" Value="#EA580C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Validé">
                                                                <Setter Property="Foreground" Value="#059669"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Brouillon">
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Relancé">
                                                                <Setter Property="Foreground" Value="#BE185D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ACTIONS" Width="Auto" MinWidth="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="16,12">
                                            <Button Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource RoundedActionButton}"
                                                    Background="#EFF6FF"
                                                    Foreground="#3B82F6"
                                                    Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="👁" FontSize="11" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Détails" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.CreateQuoteCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource RoundedActionButton}"
                                                    Background="#F0FDF4"
                                                    Foreground="#10B981">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📄" FontSize="11" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Créer devis" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
