<Page x:Class="GesAchats.WPF.Views.Acheteur.Besoins.BesoinsMagasinPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d"
      Title="Besoins Magasin">

    <Page.Resources>
        <Style x:Key="TextCenterStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="DEMANDES DE RÉAPPROVISIONNEMENT" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- KPI Section -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ctrls:KpiCard Grid.Column="0"
                Title="Total des Besoins"
                Value="{Binding TotalNeeds}"
                TrendText="{Binding TotalNeedsTrendText}"
                Icon="Box"
                IconColor="#3B82F6"
                Margin="0,0,10,0"/>

            <ctrls:KpiCard Grid.Column="1"
                Title="Besoins Transmis"
                Value="{Binding TransmittedNeeds}"
                TrendText="{Binding TransmittedNeedsTrendText}"
                Icon="PaperPlane"
                IconColor="#2196F3"
                Margin="5,0,5,0"/>

            <ctrls:KpiCard Grid.Column="2"
                Title="Besoins En cours"
                Value="{Binding InProgressNeeds}"
                TrendText="{Binding InProgressNeedsTrendText}"
                Icon="Clock"
                IconColor="#FFC107"
                Margin="5,0,5,0"/>

            <ctrls:KpiCard Grid.Column="3"
                Title="Besoins Annulés"
                Value="{Binding CancelledNeeds}"
                TrendText="{Binding CancelledNeedsTrendText}"
                Icon="TimesCircle"
                IconColor="#F44336"
                Margin="10,0,0,0"/>
        </Grid>
        
        <!-- Filters -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="N° Demande" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                    <TextBox Width="200" Text="{Binding SearchNumeroDemande, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Date" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                    <DatePicker SelectedDate="{Binding SearchDate}" Width="150"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Statut" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Width="150" Style="{StaticResource ModernComboBox}"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                    <Button Command="{Binding ResetFiltersCommand}" Content="Réinitialiser" Padding="15,5" Background="#757575" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Needs}" AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                  RowHeight="60" GridLinesVisibility="None" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N° Demande" Binding="{Binding Need.NumeroBesoin}" Width="150" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Need.DateTransmission, StringFormat=d}" Width="120"/>
                <DataGridTextColumn Header="Demandeur" Binding="{Binding Need.RequestedBy.FullName}" Width="*"/>
                <DataGridTextColumn Header="Nb Articles" Binding="{Binding ArticleCount}" Width="120" ElementStyle="{StaticResource TextCenterStyle}"/>
                
                <DataGridTemplateColumn Header="Statut" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusColor}"
                                    CornerRadius="8"
                                    Padding="10,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Actions" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Détails" 
                                        Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Margin="5"/>
                                <Button Content="Créer un devis" 
                                        Command="{Binding DataContext.CreateQuoteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#4CAF50"
                                        Margin="5"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
