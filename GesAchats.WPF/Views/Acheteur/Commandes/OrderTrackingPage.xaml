<Page x:Class="GesAchats.WPF.Views.Acheteur.Commandes.OrderTrackingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Commandes"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Suivi des Commandes">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1f6e2; Suivi des Commandes" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}" 
                              SelectedItem="{Binding StatusFilter}"
                              Width="150" Margin="20,0,0,0" Padding="5"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Content="&#x21bb; Actualiser" Padding="15,8" Background="White" BorderBrush="#2196F3" BorderThickness="1" Foreground="#2196F3"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Orders Table -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,10,0">
                <DataGrid ItemsSource="{Binding Orders}" 
                          SelectedItem="{Binding SelectedOrder}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          Background="Transparent" 
                          BorderThickness="0"
                          RowHeight="45">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Commande" Binding="{Binding OrderNumber}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat=d}" Width="Auto"/>
                        <DataGridTextColumn Header="Fournisseur" Binding="{Binding Supplier.CompanyName}" Width="*"/>
                        <DataGridTextColumn Header="Total TTC" Binding="{Binding TotalAmountTTC, StringFormat={}{0:C}}" Width="Auto"/>
                        <DataGridTemplateColumn Header="Statut" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="10,4" CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Issued">
                                                        <Setter Property="Background" Value="#BBDEFB"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                        <Setter Property="Background" Value="#C8E6C9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="PartiallyDelivered">
                                                        <Setter Property="Background" Value="#FFF9C4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Details Panel -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="DÉTAILS DE LA COMMANDE" FontSize="14" FontWeight="Bold" Foreground="#666" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="{Binding SelectedOrder.OrderNumber}" FontSize="24" FontWeight="Bold"/>
                            <Button Content="&#x1f5a8; Imprimer le Bon de Commande" Command="{Binding PrintPdfCommand}" 
                                    Margin="0,5,0,10" Padding="10,5" Background="#2196F3" Foreground="White" BorderThickness="0"/>
                            <TextBlock Text="{Binding SelectedOrder.Supplier.CompanyName}" FontSize="16" Foreground="#2196F3" Margin="0,5,0,20"/>

                            <TextBlock Text="Articles :" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding SelectedOrder.Details}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Product.Designation}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontWeight="Bold" Margin="10,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Margin="0,20"/>
                            
                            <TextBlock Text="Changer le statut :" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Livré" Command="{Binding UpdateStatusCommand}" CommandParameter="Delivered" 
                                        Background="#4CAF50" Foreground="White" Padding="15,8" Margin="0,0,5,0" BorderThickness="0"/>
                                <Button Content="Partiel" Command="{Binding UpdateStatusCommand}" CommandParameter="PartiallyDelivered" 
                                        Background="#FFC107" Foreground="Black" Padding="15,8" Margin="0,0,5,0" BorderThickness="0"/>
                                <Button Content="Fermé" Command="{Binding UpdateStatusCommand}" CommandParameter="Closed" 
                                        Background="#607D8B" Foreground="White" Padding="15,8" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock Text="Sélectionnez une commande pour voir les détails" 
                               Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"
                               Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
