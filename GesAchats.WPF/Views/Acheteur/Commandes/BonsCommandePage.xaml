<Page x:Class="GesAchats.WPF.Views.Acheteur.Commandes.BonsCommandePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Commandes"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="BonsCommandePage">

    <Page.Resources>
        <Style x:Key="BtnResetStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                CornerRadius="19" 
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#5A4BD1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#4A3BBF"/>
                                <Setter TargetName="Bd" 
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterInputStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"
                                          Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" 
                                              Grid.Column="2" 
                                              Focusable="False" 
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Margin="12,0,30,0" 
                                                  VerticalAlignment="Center" 
                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                <TextBox x:Name="PART_EditableTextBox" 
                                         Style="{x:Null}" 
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         Padding="12,0" 
                                         VerticalAlignment="Center" 
                                         Focusable="True" 
                                         IsReadOnly="{TemplateBinding IsReadOnly}" 
                                         Visibility="Hidden"/>
                                <Path x:Name="Arrow" 
                                      Grid.Column="2" 
                                      Data="M0,0 L4,4 L8,0 Z" 
                                      Fill="#6C5CE7" 
                                      HorizontalAlignment="Right" 
                                      Margin="10,0" 
                                      VerticalAlignment="Center"/>
                                <Popup x:Name="Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       StaysOpen="False" 
                                       Focusable="False" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder" 
                                            Background="White" 
                                            BorderBrush="#D0CDE8" 
                                            BorderThickness="1" 
                                            CornerRadius="8" 
                                            Padding="0">
                                        <ScrollViewer Margin="0" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                            KeyboardNavigation.DirectionalNavigation="Continue"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterDateStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox 
                                    x:Name="PART_TextBox" 
                                    Grid.Column="0" 
                                    Foreground="{TemplateBinding Foreground}" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    VerticalContentAlignment="Center" 
                                    Padding="12,0" 
                                    FontSize="{TemplateBinding FontSize}"/>
                                <Button x:Name="PART_Button" 
                                        Grid.Column="1" 
                                        Width="32" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Cursor="Hand" 
                                        Focusable="False">
                                    <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                          Stroke="#6C5CE7" StrokeThickness="1.5" 
                                          StrokeLineJoin="Round" 
                                          StrokeStartLineCap="Round" 
                                          StrokeEndLineCap="Round" 
                                          Width="16" Height="16" 
                                          Stretch="Uniform"/>
                                </Button>
                                <Popup x:Name="PART_Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Calendar x:Name="PART_Calendar"/>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1f4e6; Gestion des Bons de Commande" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ShowAddFormCommand}" Content="&#x2795; Ajouter un Bon de Commande" 
                            Padding="15,8" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"
                            Visibility="{Binding IsHistoryView, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Command="{Binding BackToHistoryCommand}" Content="&#x2b05; Retour à l'historique" 
                            Padding="15,8" Background="#757575" Foreground="White" FontWeight="Bold" BorderThickness="0"
                            Visibility="{Binding IsHistoryView, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            
            <!-- 1. HISTORY VIEW -->
            <Grid Visibility="{Binding IsHistoryView, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- KPI Section -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ctrls:KpiCard Grid.Column="0"
                                   Title="Total des Bons"
                                   Value="{Binding TotalOrders}"
                                   TrendText="{Binding TotalOrdersTrendText}"
                                   Icon="FileInvoice"
                                   IconColor="#071B3A"
                                   Margin="0,0,10,0"/>

                    <ctrls:KpiCard Grid.Column="1"
                                   Title="En Attente"
                                   Value="{Binding PendingOrders}"
                                   TrendText="{Binding PendingOrdersTrendText}"
                                   Icon="Clock"
                                   IconColor="#FFC107"
                                   Margin="5,0,5,0"/>

                    <ctrls:KpiCard Grid.Column="2"
                                   Title="Validés"
                                   Value="{Binding ValidatedOrders}"
                                   TrendText="{Binding ValidatedOrdersTrendText}"
                                   Icon="CheckCircle"
                                   IconColor="#4CAF50"
                                   Margin="5,0,5,0"/>

                    <ctrls:KpiCard Grid.Column="3"
                                   Title="Annulés"
                                   Value="{Binding CancelledOrders}"
                                   TrendText="{Binding CancelledOrdersTrendText}"
                                   Icon="TimesCircle"
                                   IconColor="#F44336"
                                   Margin="10,0,0,0"/>
                </Grid>

                <!-- Filters -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="🔍" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Recherche" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource FilterInputStyle}"
                                     HorizontalAlignment="Stretch"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="🏢" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Fournisseur" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding Suppliers}" 
                                      DisplayMemberPath="CompanyName" 
                                      SelectedItem="{Binding SelectedSupplierFilter, UpdateSourceTrigger=PropertyChanged}" 
                                      Style="{StaticResource FilterComboStyle}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Date" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DatePicker SelectedDate="{Binding SearchDate}" 
                                        Style="{StaticResource FilterDateStyle}"
                                        HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="🎛️" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding StatusFilters}" 
                                      SelectedItem="{Binding SelectedStatusFilter, UpdateSourceTrigger=PropertyChanged}" 
                                      Style="{StaticResource FilterComboStyle}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        
                        <Button Grid.Column="4" Command="{Binding ResetFiltersCommand}" 
                                Style="{StaticResource BtnResetStyle}"
                                VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Réinitialiser"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- History Table -->
                <Border Grid.Row="2" Style="{StaticResource ModernCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="24,20" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                            <TextBlock Text="Liste des Bons de Commande" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrdersHistory}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  MinWidth="1300"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE" Binding="{Binding OrderDate, StringFormat=d}" Width="Auto" MinWidth="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="N° BC" Binding="{Binding OrderNumber}" Width="*" MinWidth="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="Foreground" Value="#4F46E5"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding Supplier.CompanyName}" Width="1.5*" MinWidth="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="RÉF. DEVIS" Binding="{Binding Quotation.ReferenceNumber}" Width="*" MinWidth="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="STATUT" Width="130" MinWidth="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,4" CornerRadius="20" HorizontalAlignment="Left" Margin="12,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="En attente">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Annulé">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="En attente">
                                                                    <Setter Property="Foreground" Value="#F57C00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                    <Setter Property="Foreground" Value="#059669"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Annulé">
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="TOTAL TTC" Binding="{Binding TotalAmountTTC, StringFormat={}{0:N2} MAD}" Width="Auto" MinWidth="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="ACTIONS" Width="Auto" MinWidth="320">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="12,8">
                                                <Button Command="{Binding DataContext.InspectCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Inspecter"
                                                        Padding="10,4"
                                                        Margin="0,0,6,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                            <Setter Property="Foreground" Value="#F57C00"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FFE0B2"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔍" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Inspecter" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding DataContext.PrintPdfCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="PDF"
                                                        Padding="10,4"
                                                        Margin="0,0,6,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                            <Setter Property="Foreground" Value="#3B82F6"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📄" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="PDF" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Annuler"
                                                        Padding="10,4"
                                                        Margin="0,0,6,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FECACA"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="En attente">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Annulé">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="❌" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Annuler" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding DataContext.ReactivateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Réactiver"
                                                        Padding="10,4"
                                                        Margin="0,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#D1FAE5"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" 
                                                                                CornerRadius="20"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#A7F3D0"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="En attente">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Annulé">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✅" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Réactiver" FontSize="11"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. ADD/INSPECT FORM VIEW -->
            <Grid Visibility="{Binding IsHistoryView, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Form Left -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0" BorderBrush="#E0E0E0" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInspectView}" Value="True">
                                            <Setter Property="Text" Value="INSPECTION DU BON DE COMMANDE"/>
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditView}" Value="True">
                                            <Setter Property="Text" Value="NOUVEAU BON DE COMMANDE"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Actions for new BC -->
                        <StackPanel DockPanel.Dock="Top" Visibility="{Binding IsEditView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Fournisseur *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" 
                                              DisplayMemberPath="CompanyName" Padding="10"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Créer à partir du devis" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding AvailableQuotations}" SelectedItem="{Binding SelectedQuotation}" Padding="10">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding ReferenceNumber}" FontWeight="Bold"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding Supplier.CompanyName}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Info for Inspection -->
                        <StackPanel DockPanel.Dock="Top" Visibility="{Binding IsInspectView, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="N° BC:" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedOrder.OrderNumber}" Foreground="#2196F3" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="Date:" FontWeight="Bold" Margin="20,0,10,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding SelectedOrder.OrderDate, StringFormat=d}"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <TextBlock Text="Fournisseur:" FontWeight="Bold" Margin="0,0,10,0"/>
                                <TextBlock Margin="85,0,0,0" Text="{Binding SelectedOrder.Supplier.CompanyName}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Articles Grid -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,10">
                        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False" 
                                  Background="Transparent" BorderThickness="0" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Incl." Binding="{Binding IsIncluded, UpdateSourceTrigger=PropertyChanged}" Width="Auto">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding DataContext.IsInspectView, RelativeSource={RelativeSource AncestorType=Page}}" Value="True"/>
                                                        <Condition Binding="{Binding DataContext.IsOrderEditable, RelativeSource={RelativeSource AncestorType=Page}}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Header="Désignation" Binding="{Binding Detail.Product.Designation}" IsReadOnly="True" Width="*"/>
                                <DataGridTemplateColumn Header="Qté" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                     IsReadOnly="{Binding DataContext.IsOrderEditable, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanInverterConverter}, FallbackValue=True}"
                                                     Padding="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="PU HT" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding UnitPriceHT, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                                     IsReadOnly="{Binding DataContext.IsOrderEditable, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanInverterConverter}, FallbackValue=True}"
                                                     Padding="2" HorizontalContentAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="PU TTC" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding UnitPriceTTC, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                                     IsReadOnly="{Binding DataContext.IsOrderEditable, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanInverterConverter}, FallbackValue=True}"
                                                     Padding="2" HorizontalContentAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Total HT" Binding="{Binding TotalHT, StringFormat={}{0:N2} MAD}" IsReadOnly="True" Width="Auto">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="5,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    </DockPanel>
                </Border>

                <!-- Totals & Actions Right -->
                <StackPanel Grid.Column="1">
                    <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="CALCULS ET TOTAL" FontWeight="Bold" Margin="0,0,0,15" Foreground="#666"/>
                            
                            <TextBlock Text="TVA (%)" FontSize="11" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding VatRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                     IsReadOnly="{Binding IsInspectView}"
                                     Padding="10" Margin="0,0,0,20" FontSize="16" FontWeight="Bold"/>

                            <Separator Margin="0,0,0,20"/>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Total HT:" Foreground="#666"/>
                                <TextBlock Text="{Binding TotalHT, StringFormat={}{0:N2} MAD}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Montant TVA:" Foreground="#666"/>
                                <TextBlock Text="{Binding TotalVAT, StringFormat={}{0:N2} MAD}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,10,0,0">
                                <Grid>
                                    <TextBlock Text="TOTAL TTC:" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Text="{Binding TotalTTC, StringFormat={}{0:N2} MAD}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="18" Foreground="#4CAF50"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="OBSERVATIONS" FontWeight="Bold" Margin="0,0,0,10" Foreground="#666"/>
                            <TextBox Text="{Binding Observations}" AcceptsReturn="True" Height="100" 
                                     IsReadOnly="{Binding IsOrderEditable, Converter={StaticResource BooleanInverterConverter}, FallbackValue=True}"
                                     VerticalContentAlignment="Top" Padding="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding CreateOrderCommand}" 
                            Visibility="{Binding IsEditView, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Content="&#x1f4be; Enregistrer le BC" 
                            Padding="20,15" Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
