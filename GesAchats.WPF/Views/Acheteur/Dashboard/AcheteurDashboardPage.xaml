<Page x:Class="GesAchats.WPF.Views.Acheteur.Dashboard.AcheteurDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:ctrls="clr-namespace:GesAchats.WPF.Controls"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Title="Tableau de bord Acheteur"
      Background="{StaticResource PageBackgroundBrush}"
      FontFamily="Segoe UI">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Vertical" Margin="32">

            <!-- ===================== HEADER ===================== -->
            <StackPanel Margin="0,0,0,22" VerticalAlignment="Center">
                <TextBlock Text="Tableau de bord" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource MainTextBrush}"/>
                <TextBlock Text="Vue globale des achats, stocks et fournisseurs" FontSize="14" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Loading Indicator -->
            <ProgressBar IsIndeterminate="{Binding IsBusy}" 
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Height="3" 
                         Foreground="{StaticResource PrimaryBrush}"
                         Background="Transparent"
                         Margin="0,0,0,22"/>

            <!-- ===================== SECTION KPIs ===================== -->
            <UniformGrid Rows="1" Columns="6" Margin="0,0,0,22">
                <!-- KPI Card 1: BES en cours -->
                <ctrls:KpiCard Margin="0,0,14,0" 
                               Title="BES en cours" 
                               Value="{Binding DemandesEnCours}"
                               Unit="BES"
                               Icon="ClipboardList"
                               IconColor="#2563EB"
                               TrendText="{Binding DemandesTrendText}"
                               IsPositiveTrend="{Binding DemandesIsPositiveTrend}"/>

                <!-- KPI Card 2: BES transmis -->
                <ctrls:KpiCard Margin="7,0,7,0" 
                               Title="BES transmis" 
                               Value="{Binding DevisEnAttente}"
                               Unit="BES"
                               Icon="Share"
                               IconColor="#10B981"
                               TrendText="{Binding DevisAttentTrendText}"
                               IsPositiveTrend="{Binding DevisAttentIsPositiveTrend}"/>

                <!-- KPI Card 3: DEV en attente -->
                <ctrls:KpiCard Margin="7,0,7,0" 
                               Title="DEV en attente" 
                               Value="{Binding DevisEnAttente}"
                               Unit="DEV"
                               Icon="Clock"
                               IconColor="#EF4444"
                               TrendText="{Binding DevisAttentTrendText}"
                               IsPositiveTrend="{Binding DevisAttentIsPositiveTrend}"/>

                <!-- KPI Card 4: DEV validé -->
                <ctrls:KpiCard Margin="7,0,7,0" 
                               Title="DEV validé" 
                               Value="{Binding DevisValides}"
                               Unit="DEV"
                               Icon="CheckCircle"
                               IconColor="#22C55E"
                               TrendText="{Binding DevisValidesTrendText}"
                               IsPositiveTrend="{Binding DevisValidesIsPositiveTrend}"/>

                <!-- KPI Card 5: Fourn. actifs -->
                <ctrls:KpiCard Margin="7,0,7,0" 
                               Title="Fourn. actifs" 
                               Value="{Binding FournisseursActifs}"
                               Unit="fournisseurs"
                               Icon="Users"
                               IconColor="#2563EB"
                               TrendText="{Binding FournisseursTrendText}"
                               IsPositiveTrend="{Binding FournisseursIsPositiveTrend}"/>

                <!-- KPI Card 6: Total BC -->
                <ctrls:KpiCard Margin="7,0,0,0" 
                               Title="Total BC" 
                               Value="{Binding TotalPurchaseOrders}"
                               Unit="BC"
                               Icon="CartShopping"
                               IconColor="#EF4444"
                               TrendText="{Binding BonsCommandeTrendText}"
                               IsPositiveTrend="{Binding BonsCommandeIsPositiveTrend}"/>
            </UniformGrid>

            <!-- ===================== SECTION ANALYSES ===================== -->
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Graphique 1: Évolution des achats -->
                <Border Grid.Column="0" Margin="0,0,18,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" 
                                   Text="Évolution des commandes (MAD)" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource MainTextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        
                        <lvc:CartesianChart Grid.Row="1" 
                                            Series="{Binding PurchaseOrdersSeries}" 
                                            XAxes="{Binding PurchaseOrdersXAxes}" 
                                            Height="200" Margin="0,12,0,0"/>
                    </Grid>
                </Border>

                <!-- Graphique 2: Répartition des bons (Donut) -->
                <Border Grid.Column="1" Margin="0,0,0,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" 
                                   Text="Répartition des bons de commande" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource MainTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Donut Chart with Center Text -->
                            <Grid Grid.Column="0">
                                <lvc:PieChart Series="{Binding OrderStatusSeries}" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalPurchaseOrders}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Total" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Legend -->
                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="12" Height="12" Background="#F59E0B" CornerRadius="6"/>
                                    <TextBlock Grid.Column="1" Text="En attente" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{Binding OrderStatusData[0].DisplayText}" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="12" Height="12" Background="#22C55E" CornerRadius="6"/>
                                    <TextBlock Grid.Column="1" Text="Validé" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{Binding OrderStatusData[1].DisplayText}" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="12" Height="12" Background="#EF4444" CornerRadius="6"/>
                                    <TextBlock Grid.Column="1" Text="Annulé" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{Binding OrderStatusData[2].DisplayText}" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================== SECTION BAS (Tables + Alerts) ===================== -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Table: Dernières opérations -->
                <Border Grid.Column="0" Margin="0,0,18,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Dernières opérations" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource MainTextBrush}" Margin="0,0,0,16"/>
                        <DataGrid ItemsSource="{Binding LatestOperations}" 
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="White"
                                  GridLinesVisibility="None"
                                  ColumnHeaderHeight="42"
                                  RowHeight="42"
                                  AlternatingRowBackground="#FAFAFA"
                                  HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="8,10"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Référence" Binding="{Binding Reference}" Width="1.3*"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.6*"/>
                                <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur}" Width="1.6*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="1*"/>
                                <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="0.9*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Alerts Section -->
                <Border Grid.Column="1" Margin="0,0,0,0" Background="{StaticResource CardBackgroundBrush}" Padding="18" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.05" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Alertes &amp; points d'attention" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource MainTextBrush}" Margin="0,0,0,16"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                            <ItemsControl ItemsSource="{Binding AlertsData}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Height="44" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="32" Height="32" Background="#FFECD0" CornerRadius="8" Margin="0,0,12,0">
                                                    <fa:IconImage Icon="ExclamationTriangle" Width="16" Height="16" Foreground="#C47F00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                            <Border Height="1" Background="#E5E7EB" Margin="0,8,0,8"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AlertsData.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ItemsControl">
                                                            <TextBlock Text="Aucune alerte en attente" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,40,0,0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
