<Page x:Class="GesAchats.WPF.Views.Acheteur.Dashboard.AcheteurDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      Title="Tableau de Bord Acheteur"
      Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== HEADER ===================== -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="20" Background="{StaticResource BackgroundBrush}">
            
            <!-- Titre et Boutons -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Titre -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Tableau de bord" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Vue globale des achats, stocks et fournisseurs" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Sélecteur de Période -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Période :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <ComboBox Width="150" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                        <ComboBoxItem Content="30 derniers jours" Tag="30"/>
                        <ComboBoxItem Content="60 derniers jours" Tag="60"/>
                        <ComboBoxItem Content="90 derniers jours" Tag="90"/>
                        <ComboBoxItem Content="6 derniers mois" Tag="180"/>
                    </ComboBox>
                </StackPanel>

                <!-- Bouton Actualiser -->
                <Button Grid.Column="2" 
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource ModernPrimaryButton}"
                        Padding="20,10"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↻" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="16"/>
                        <TextBlock Text="Actualiser"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Loading Indicator -->
            <ProgressBar IsIndeterminate="{Binding IsBusy}" 
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Height="2" 
                         Foreground="{StaticResource PrimaryBrush}"
                         Background="Transparent"
                         Margin="0,0,0,10"/>
        </StackPanel>

        <!-- ===================== CONTENU PRINCIPAL ===================== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical" Margin="20,0,20,20">

                <!-- ===================== SECTION KPIs ===================== -->
                <TextBlock Text="Indicateurs clés" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- KPI Card 1: Demandes en cours -->
                    <Border Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Demandes en cours" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="📄" Foreground="{StaticResource PrimaryBrush}" FontSize="20"/>
                            </Grid>
                            <TextBlock Text="{Binding DemandesEnCours}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="demandes" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11">
                                <Run Text="▲" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding DemandesProgression, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="vs période précédente" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- KPI Card 2: Devis en attente -->
                    <Border Grid.Column="1" Margin="5,0,5,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Devis en attente" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="⏰" Foreground="{StaticResource WarningBrush}" FontSize="20"/>
                            </Grid>
                            <TextBlock Text="{Binding DevisEnAttente}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="devis" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11">
                                <Run Text="▲" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding DevisAttentProgression, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="vs période précédente" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- KPI Card 3: Devis valides -->
                    <Border Grid.Column="2" Margin="5,0,5,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Devis valides" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="✅" Foreground="{StaticResource SuccessBrush}" FontSize="20"/>
                            </Grid>
                            <TextBlock Text="{Binding DevisValides}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="devis" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11">
                                <Run Text="▲" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding DevisValidesProgression, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="vs période précédente" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- KPI Card 4: Bons de commande en attente -->
                    <Border Grid.Column="3" Margin="5,0,5,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bons de commande" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="🛒" Foreground="{StaticResource WarningBrush}" FontSize="20"/>
                            </Grid>
                            <TextBlock Text="{Binding BonsCommandeEnAttente}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="bons" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11">
                                <Run Text="▲" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding BonsCommandeProgression, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="vs période précédente" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- KPI Card 5: Fournisseurs actifs -->
                    <Border Grid.Column="4" Margin="5,0,5,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fournisseurs actifs" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="👥" Foreground="{StaticResource NewProductBrush}" FontSize="20"/>
                            </Grid>
                            <TextBlock Text="{Binding FournisseursActifs}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="fournisseurs" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11">
                                <Run Text="▲" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding FournisseursProgression, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="vs période précédente" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- KPI Card 6: Articles suivis -->
                    <Border Grid.Column="5" Margin="5,0,0,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Articles suivis" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="📦" Foreground="{StaticResource PrimaryBrush}" FontSize="20"/>
                            </Grid>
                            <TextBlock Text="{Binding ArticlesSuivis}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="articles" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            <TextBlock Margin="0,8,0,0" FontSize="11">
                                <Run Text="▲" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="{Binding ArticlesSuivisProgression, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text="vs période précédente" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===================== SECTION GRAPHIQUES ===================== -->
                <TextBlock Text="Analyses" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Graphique 1: Évolution des achats -->
                    <Border Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Évolution des achats (MAD)" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <ComboBox Height="32" Margin="0,0,0,10" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                <ComboBoxItem Content="6 derniers mois"/>
                                <ComboBoxItem Content="12 derniers mois"/>
                            </ComboBox>
                            <Rectangle Height="200" Fill="{StaticResource BorderBrush}" RadiusX="4" RadiusY="4"/>
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Total période" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="1,872,540 MAD" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Moyenne mensuelle" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="312,090 MAD" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Graphique 2: Dépenses par fournisseur -->
                    <Border Grid.Column="1" Margin="5,0,5,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Dépenses par fournisseur (MAD)" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <ComboBox Height="32" Margin="0,0,0,10" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                                <ComboBoxItem Content="Top 5"/>
                                <ComboBoxItem Content="Top 10"/>
                            </ComboBox>
                            <Rectangle Height="200" Fill="{StaticResource BorderBrush}" RadiusX="4" RadiusY="4"/>
                            <TextBlock Text="Total dépenses" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,15,0,3"/>
                            <TextBlock Text="1,554,250 MAD" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Graphique 3: Répartition des bons -->
                    <Border Grid.Column="2" Margin="5,0,0,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Répartition des bons de commande" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Rectangle Height="200" Fill="{StaticResource BorderBrush}" RadiusX="4" RadiusY="4"/>
                            <Grid Margin="0,15,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{StaticResource PrimaryBrush}" RadiusX="2" RadiusY="2"/>
                                    <TextBlock Grid.Column="1" Text="En attente" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="7 (18%)" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{StaticResource SuccessBrush}" RadiusX="2" RadiusY="2"/>
                                    <TextBlock Grid.Column="1" Text="Validé" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="23 (61%)" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{StaticResource WarningBrush}" RadiusX="2" RadiusY="2"/>
                                    <TextBlock Grid.Column="1" Text="Transmis" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="8 (21%)" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===================== SECTION TABLES ===================== -->
                <TextBlock Text="Détails" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Table 1: Analyse des prix -->
                    <Border Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Analyse des prix - Top Articles" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid ItemsSource="{Binding PriceAnalysisData}" 
                                      Style="{StaticResource ModernDataGrid}"
                                      Height="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Article" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Qté Achats" Binding="{Binding Quantity}" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Prix Moy. (MAD)" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Évolution" Binding="{Binding EvolutionText}" Width="80" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Content="Voir l'historique complet →" Style="{StaticResource ModernIconButton}" Foreground="{StaticResource PrimaryBrush}" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Table 2: Dernières opérations -->
                    <Border Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Dernières opérations" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid ItemsSource="{Binding RecentOperations}"
                                      Style="{StaticResource ModernDataGrid}"
                                      Height="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Référence" Binding="{Binding Reference}" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="50" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Fournisseur" Binding="{Binding Supplier}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Montant (MAD)" Binding="{Binding Amount, StringFormat=N2}" Width="80" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Content="Voir toutes les opérations →" Style="{StaticResource ModernIconButton}" Foreground="{StaticResource PrimaryBrush}" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===================== SECTION ALERTES ===================== -->
                <TextBlock Text="Alertes &amp; points d'attention" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.ColumnSpan="4" ItemsSource="{Binding AlertsData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModernCard}" Padding="16" Margin="0,0,10,0">
                                    <StackPanel Orientation="Vertical">
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Background="#FFF3E0" Padding="8,4" CornerRadius="4">
                                            <TextBlock Text="{Binding Count, StringFormat='{}{0} élément(s)'}" FontSize="12" FontWeight="Bold" Foreground="#FF9800"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Bouton "Voir toutes les alertes" -->
                <Button Content="Voir toutes les alertes →" 
                        Style="{StaticResource ModernIconButton}" 
                        Foreground="{StaticResource PrimaryBrush}" 
                        HorizontalAlignment="Left"
                        Padding="0,8"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>