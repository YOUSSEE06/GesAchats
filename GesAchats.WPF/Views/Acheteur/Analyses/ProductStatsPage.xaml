<Page x:Class="GesAchats.WPF.Views.Acheteur.Analyses.ProductStatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Analyses"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Statistiques du Produit">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding BackCommand}" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Padding="10,0"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#x2190;" FontSize="24" FontWeight="Bold" Foreground="#666"/>
                </Button>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="&#x1f4ca; Statistiques et Évolution des Prix" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Product.Designation}" FontSize="16" Foreground="#2196F3" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <!-- Filters -->
                <Border Background="White" Margin="0,0,0,20" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Période" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding Periods}" 
                                      SelectedItem="{Binding SelectedPeriod}" 
                                      Width="180" Height="32" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0" Visibility="{Binding IsCustomDateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Du" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding StartDate}" Width="150" Height="32"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsCustomDateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Au" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Width="150" Height="32"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stats Cards -->
                <UniformGrid Columns="5" Margin="0,0,0,20">
                    <Border Background="White" Margin="5" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Prix Moyen" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding AveragePrice, StringFormat={}{0:N2} MAD}" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" Margin="5" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Prix Min" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding MinPrice, StringFormat={}{0:N2} MAD}" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" Margin="5" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Prix Max" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding MaxPrice, StringFormat={}{0:N2} MAD}" FontSize="18" FontWeight="Bold" Foreground="#D32F2F" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" Margin="5" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Quantité Totale" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding TotalQuantity, StringFormat={}{0:N0}}" FontSize="18" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" Margin="5" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Nb. Achats" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding PurchaseCount}" FontSize="18" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Chart -->
                <Border Background="White" Padding="20" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="ÉVOLUTION DU PRIX UNITAIRE" FontWeight="Bold" Foreground="#666" Margin="0,0,0,20"/>
                        <Grid Height="400">
                            <lvc:CartesianChart Series="{Binding Series}"
                                               XAxes="{Binding XAxes}"
                                               YAxes="{Binding YAxes}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
