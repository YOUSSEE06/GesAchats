<Page x:Class="GesAchats.WPF.Views.Acheteur.Analyses.AnalyseComparativePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Analyses"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Analyse Comparative">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1f4ca; Analyse Comparative des Devis" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Separator Width="20" Background="Transparent"/>
                <ComboBox ItemsSource="{Binding PendingNeeds}" 
                          SelectedItem="{Binding SelectedNeed}"
                          Width="250" Padding="8" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ReferenceNumber}" FontWeight="Bold"/>
                                <TextBlock Text=" - "/>
                                <TextBlock Text="{Binding DateTransmission, StringFormat=d}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Comparison by Quotation (Summary) -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Récapitulatif des Devis Reçus" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding Quotations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,10" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel>
                                            <TextBlock Text="{Binding Quotation.Supplier.CompanyName}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Quotation.ReferenceNumber}" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBlock Text="Total TTC: " FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Quotation.TotalAmountTTC, StringFormat={}{0:C}}" Foreground="#2196F3" FontWeight="Bold"/>
                                            </StackPanel>
                                            
                                            <ItemsControl ItemsSource="{Binding Quotation.Details}" Margin="0,5,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Product.Designation, StringFormat=• {0}}" FontSize="11" Foreground="#666"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border Background="{Binding ScoreColor}" CornerRadius="15" Padding="10,5">
                                                <TextBlock Text="{Binding Score, StringFormat={}{0:N1}/10}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <Button Content="Générer Bon de Commande" 
                                                    Command="{Binding GeneratePurchaseOrderCommand}"
                                                    Margin="0,10,0,0" Padding="10,5"
                                                    Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Aucun devis trouvé pour ce besoin" 
                               Visibility="{Binding Quotations.Count, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                               HorizontalAlignment="Center" Margin="0,50" Foreground="Gray"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Right side: Selected Need Details -->
            <Border Grid.Column="1" Margin="20,0,0,0" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Détails du Besoin" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Visibility="{Binding SelectedNeed, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedNeed.ReferenceNumber}" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="{Binding SelectedNeed.DateTransmission, StringFormat=Date: {0:d}}" Margin="0,5"/>
                            <TextBlock Text="{Binding SelectedNeed.RequestedBy.FullName, StringFormat=Par: {0}}" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Articles demandés:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <StackPanel Margin="0,5">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedNeed.Product.Designation}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedNeed.Quantity, StringFormat={}{0} {1}}" FontWeight="SemiBold" Margin="10,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Veuillez sélectionner un besoin" 
                               Visibility="{Binding SelectedNeed, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"
                               HorizontalAlignment="Center" Margin="0,50" Foreground="Gray"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
