<Page x:Class="GesAchats.WPF.Views.Acheteur.Analyses.AdvancedComparativeAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Analyses"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="Analyse Comparative Avancée">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1f4ca;" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Analyse Comparative Avancée" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Selection Panel -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <!-- Step 1: Devis Selection -->
                <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="1. SÉLECTIONNER LES DEVIS" FontSize="12" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>
                        <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AvailableQuotations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Quotation.Supplier.CompanyName}" FontWeight="Bold" FontSize="13"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Quotation.ReferenceNumber}" FontSize="11" Foreground="#2196F3"/>
                                                    <TextBlock Text=" - " FontSize="11" Foreground="Gray"/>
                                                    <TextBlock Text="{Binding Quotation.Date, StringFormat=dd/MM/yyyy}" FontSize="11" Foreground="Gray"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
                <!-- Summary Card -->
                <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,0" Visibility="{Binding SelectedSuppliers.Count, Converter={StaticResource EnhancedBooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="RÉSUMÉ DES OFFRES" FontSize="12" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding SelectedSuppliers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Supplier.CompanyName}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalAmountHT, StringFormat={}{0:N2} DH}" FontWeight="Bold" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Comparison Table -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="TABLEAU COMPARATIF DES PRIX" FontSize="14" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Text=" (Prix Unitaires HT)" FontSize="12" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <DataGrid x:Name="ComparisonGrid" Grid.Row="1" 
                              ItemsSource="{Binding ComparisonData}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              Background="Transparent" 
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              AlternatingRowBackground="#FAFAFA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produit" Binding="{Binding ProductName}" Width="2*"/>
                            <DataGridTextColumn Header="Qté" Binding="{Binding Quantity}" Width="Auto">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Unité" Binding="{Binding Unit}" Width="Auto"/>
                            <!-- Dynamic Columns will be added here via code-behind -->
                            <DataGridTextColumn Header="Meilleur Prix" Binding="{Binding BestPrice}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>


                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
