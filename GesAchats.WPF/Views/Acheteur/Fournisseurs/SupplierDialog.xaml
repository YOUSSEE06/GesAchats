<Window x:Class="GesAchats.WPF.Views.Acheteur.Fournisseurs.SupplierDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
        Title="Ajouter/Modifier un Fournisseur"
        Height="750"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <ControlTemplate x:Key="ValidationTemplate">
            <StackPanel>
                <Border BorderBrush="#EF4444"
                        BorderThickness="2"
                        CornerRadius="8">
                    <AdornedElementPlaceholder/>
                </Border>
                <TextBlock Margin="6,4,0,0"
                           Foreground="#EF4444"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="{Binding [0].ErrorContent}"/>
            </StackPanel>
        </ControlTemplate>
        
        <Style x:Key="ModernValidationTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DesignLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Padding" Value="35,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Padding" Value="35,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F5F7FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">
                <TextBlock Text="{Binding Title}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,35"/>
                
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Nom de la société *" Style="{StaticResource DesignLabel}"/>
                    <TextBox Style="{StaticResource ModernValidationTextBoxStyle}"
                             Validation.ErrorTemplate="{StaticResource ValidationTemplate}">
                        <TextBox.Text>
                            <Binding Path="CompanyName"
                                     UpdateSourceTrigger="PropertyChanged"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <conv:RequiredFieldValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Nom du contact" Style="{StaticResource DesignLabel}"/>
                    <TextBox Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernValidationTextBoxStyle}"/>
                </StackPanel>
                
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Email" Style="{StaticResource DesignLabel}"/>
                        <TextBox Style="{StaticResource ModernValidationTextBoxStyle}"
                                 Validation.ErrorTemplate="{StaticResource ValidationTemplate}">
                            <TextBox.Text>
                                <Binding Path="Email"
                                         UpdateSourceTrigger="PropertyChanged"
                                         NotifyOnValidationError="True">
                                    <Binding.ValidationRules>
                                        <conv:EmailValidationRule/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Téléphone" Style="{StaticResource DesignLabel}"/>
                        <TextBox Style="{StaticResource ModernValidationTextBoxStyle}"
                                 Validation.ErrorTemplate="{StaticResource ValidationTemplate}">
                            <TextBox.Text>
                                <Binding Path="Phone"
                                         UpdateSourceTrigger="PropertyChanged"
                                         NotifyOnValidationError="True">
                                    <Binding.ValidationRules>
                                        <conv:PhoneValidationRule/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>
                </Grid>
                
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Adresse" Style="{StaticResource DesignLabel}"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernValidationTextBoxStyle}"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Ville" Style="{StaticResource DesignLabel}"/>
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernValidationTextBoxStyle}"/>
                </StackPanel>
                
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#DC2626"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Annuler"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Style="{StaticResource CancelButton}"
                            Margin="0,0,15,0"/>
                    <Button x:Name="SaveButton"
                            Command="{Binding SaveCommand}"
                            IsDefault="True"
                            Style="{StaticResource SaveButton}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
