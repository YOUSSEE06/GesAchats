<Page x:Class="GesAchats.WPF.Views.Acheteur.Devis.QuotesManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Devis"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Gestion des Devis">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#x1f4dd; Création &amp; Gestion des Devis" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Content="&#x21bb; Actualiser" Padding="15,8" Background="White" BorderBrush="#2196F3" BorderThickness="1" Foreground="#2196F3"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Creation Form -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="CRÉER UNE DEMANDE DE DEVIS" FontSize="14" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,20"/>

                        <!-- Step 1: Need Selection -->
                        <TextBlock Text="1. Sélectionner un besoin" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding PendingNeeds}" 
                                  SelectedItem="{Binding SelectedNeed}"
                                  Padding="10" Margin="0,0,0,20">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding NumeroBesoin}" FontWeight="Bold"/>
                                        <TextBlock Text=" - "/>
                                        <TextBlock Text="{Binding DateTransmission, StringFormat=dd/MM/yyyy}"/>
                                        <TextBlock Text=" ("/>
                                        <TextBlock Text="{Binding Details.Count}"/>
                                        <TextBlock Text=" articles)"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Step 2: Articles Selection -->
                        <TextBlock Text="2. Articles à inclure" FontWeight="SemiBold" Margin="0,0,0,5" Visibility="{Binding ArticlesToQuote.Count, Converter={StaticResource EnhancedBooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding ArticlesToQuote}" Margin="0,0,0,20" Visibility="{Binding ArticlesToQuote.Count, Converter={StaticResource EnhancedBooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                            <TextBlock Text=" ("/>
                                            <TextBlock Text="{Binding Quantity}"/>
                                            <TextBlock Text=" "/>
                                            <TextBlock Text="{Binding Unit}"/>
                                            <TextBlock Text=")"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Step 3: Suppliers Selection -->
                        <TextBlock Text="3. Choisir les fournisseurs" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" MaxHeight="200" Margin="0,0,0,20">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AvailableSuppliers}" Padding="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,5" IsEnabled="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource EnhancedBooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Supplier.CompanyName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" - " Foreground="Gray"/>
                                                    <TextBlock Text="{Binding Supplier.City}" Foreground="Gray" FontSize="11"/>
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <Button Command="{Binding CreateQuotesCommand}" 
                                Padding="20,12" 
                                Background="#2196F3" 
                                Foreground="White" 
                                FontWeight="Bold" 
                                BorderThickness="0"
                                HorizontalAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="&#x2709; Créer un Devis"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Content" Value="&#x1f4be; Mettre à jour le Devis"/>
                                            <Setter Property="Background" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Command="{Binding CancelEditCommand}" 
                                Content="Annuler la modification" 
                                Margin="0,10,0,0"
                                Padding="10,5" 
                                Background="Transparent" 
                                Foreground="Gray" 
                                BorderThickness="0"
                                HorizontalAlignment="Center"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right side: Existing Quotes -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="DEMANDES RÉCENTES" FontSize="14" FontWeight="Bold" Foreground="#666" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ExistingQuotations}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              Background="Transparent" 
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              GridLinesVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Référence" Binding="{Binding ReferenceNumber}" Width="*"/>
                            <DataGridTextColumn Header="Fournisseur" Binding="{Binding Supplier.CompanyName}" Width="*"/>
                            <DataGridTemplateColumn Header="Actions" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="&#x270f;" 
                                                    Command="{Binding DataContext.EditQuotationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Modifier"
                                                    Padding="5,2" Margin="0,0,5,0" Background="Transparent" BorderThickness="0"/>
                                            <Button Content="&#x1f5a8;" 
                                                    Command="{Binding DataContext.PrintPdfCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Générer PDF"
                                                    Padding="5,2" Background="Transparent" BorderThickness="0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Statut" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" CornerRadius="10" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Sent">
                                                            <Setter Property="Background" Value="#BBDEFB"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Received">
                                                            <Setter Property="Background" Value="#C8E6C9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
