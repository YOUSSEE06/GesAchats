<Page x:Class="GesAchats.WPF.Views.Acheteur.Devis.QuotesManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GesAchats.WPF.Views.Acheteur.Devis"
      xmlns:conv="clr-namespace:GesAchats.WPF.Converters"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="Gestion des Devis">

    <Page.Resources>
        <Style x:Key="BtnResetStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                CornerRadius="19" 
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#5A4BD1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" 
                                        Property="Background" 
                                        Value="#4A3BBF"/>
                                <Setter TargetName="Bd" 
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterInputStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="False" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"
                                          Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton" 
                                              Grid.Column="2" 
                                              Focusable="False" 
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite" 
                                                  IsHitTestVisible="False" 
                                                  Margin="12,0,30,0" 
                                                  VerticalAlignment="Center" 
                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                <TextBox x:Name="PART_EditableTextBox" 
                                         Style="{x:Null}" 
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         Padding="12,0" 
                                         VerticalAlignment="Center" 
                                         Focusable="True" 
                                         IsReadOnly="{TemplateBinding IsReadOnly}" 
                                         Visibility="Hidden"/>
                                <Path x:Name="Arrow" 
                                      Grid.Column="2" 
                                      Data="M0,0 L4,4 L8,0 Z" 
                                      Fill="#6C5CE7" 
                                      HorizontalAlignment="Right" 
                                      Margin="10,0" 
                                      VerticalAlignment="Center"/>
                                <Popup x:Name="Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       StaysOpen="False" 
                                       Focusable="False" 
                                       IsOpen="{TemplateBinding IsDropDownOpen}" 
                                       PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder" 
                                            Background="White" 
                                            BorderBrush="#D0CDE8" 
                                            BorderThickness="1" 
                                            CornerRadius="8" 
                                            Padding="0">
                                        <ScrollViewer Margin="0" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                            KeyboardNavigation.DirectionalNavigation="Continue"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#A9A3D7"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterDateStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0CDE8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox 
                                    x:Name="PART_TextBox" 
                                    Grid.Column="0" 
                                    Foreground="{TemplateBinding Foreground}" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    VerticalContentAlignment="Center" 
                                    Padding="12,0" 
                                    FontSize="{TemplateBinding FontSize}"/>
                                <Button x:Name="PART_Button" 
                                        Grid.Column="1" 
                                        Width="32" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Cursor="Hand" 
                                        Focusable="False">
                                    <Path Data="M6 2v2M18 2v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" 
                                          Stroke="#6C5CE7" StrokeThickness="1.5" 
                                          StrokeLineJoin="Round" 
                                          StrokeStartLineCap="Round" 
                                          StrokeEndLineCap="Round" 
                                          Width="16" Height="16" 
                                          Stretch="Uniform"/>
                                </Button>
                                <Popup x:Name="PART_Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Calendar x:Name="PART_Calendar"/>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Background="{StaticResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Background="White" Padding="24" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Gestion des Devis" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding OpenCreateDialogCommand}" 
                                    Style="{StaticResource ModernPrimaryButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Créer un Devis"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Statistics Cards -->
                <Border Grid.Row="1" Padding="24,20">
                    <UniformGrid Columns="3" Rows="2">
                        <Border Style="{StaticResource ModernCard}" Padding="20" Margin="0,0,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#E3F2FD" CornerRadius="10" Padding="10" Width="48" Height="48">
                                    <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding TotalDevis}" Grid.Row="1" FontSize="32" FontWeight="Bold" Foreground="#1565C0" Margin="0,16,0,4"/>
                                <TextBlock Text="Total Devis" Grid.Row="2" FontSize="14" Foreground="#616161" FontWeight="Medium"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ModernCard}" Padding="20" Margin="0,0,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#FFF3E0" CornerRadius="10" Padding="10" Width="48" Height="48">
                                    <TextBlock Text="⏳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding DevisEnAttente}" Grid.Row="1" FontSize="32" FontWeight="Bold" Foreground="#F57C00" Margin="0,16,0,4"/>
                                <TextBlock Text="Devis en attente" Grid.Row="2" FontSize="14" Foreground="#616161" FontWeight="Medium"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ModernCard}" Padding="20" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#E8F5E9" CornerRadius="10" Padding="10" Width="48" Height="48">
                                    <TextBlock Text="✓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding DevisValides}" Grid.Row="1" FontSize="32" FontWeight="Bold" Foreground="#2E7D32" Margin="0,16,0,4"/>
                                <TextBlock Text="Devis validés" Grid.Row="2" FontSize="14" Foreground="#616161" FontWeight="Medium"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ModernCard}" Padding="20" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#E8F5E9" CornerRadius="10" Padding="10" Width="48" Height="48">
                                    <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding MontantTotal, StringFormat={}{0:N2} MAD}" Grid.Row="1" FontSize="26" FontWeight="Bold" Foreground="#2E7D32" Margin="0,16,0,4"/>
                                <TextBlock Text="Montant total (MAD)" Grid.Row="2" FontSize="14" Foreground="#616161" FontWeight="Medium"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ModernCard}" Padding="20" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#F3E5F5" CornerRadius="10" Padding="10" Width="48" Height="48">
                                    <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding MoyenneParDevis, StringFormat={}{0:N2} MAD}" Grid.Row="1" FontSize="26" FontWeight="Bold" Foreground="#7B1FA2" Margin="0,16,0,4"/>
                                <TextBlock Text="Moyenne par devis (MAD)" Grid.Row="2" FontSize="14" Foreground="#616161" FontWeight="Medium"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ModernCard}" Padding="20" Margin="0,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#FFF8E1" CornerRadius="10" Padding="10" Width="48" Height="48">
                                    <TextBlock Text="🏢" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding FournisseurPlusSollicite}" Grid.Row="1" FontSize="18" FontWeight="Bold" Foreground="#F57C00" Margin="0,16,0,4" TextWrapping="Wrap"/>
                                <TextBlock Text="Fournisseur le plus sollicité" Grid.Row="2" FontSize="14" Foreground="#616161" FontWeight="Medium"/>
                            </Grid>
                        </Border>
                    </UniformGrid>
                </Border>

                <!-- Filter Section -->
                <Border Grid.Row="2" Background="White" Padding="24" Margin="0,0,24,0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="🔍" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Rechercher" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox Text="{Binding FilterSearch, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource FilterInputStyle}"
                                     HorizontalAlignment="Stretch"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="🏢" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Fournisseur (sélection)" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding FilterSuppliers}"
                                      SelectedItem="{Binding SelectedFilterSupplier}"
                                      Style="{StaticResource FilterComboStyle}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Padding" Value="12,8"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding CompanyName}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="Tous">
                                                            <Setter Property="Text" Value="Tous"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="📅" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Date" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DatePicker SelectedDate="{Binding FilterDate, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource FilterDateStyle}"
                                        HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="3" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="🎛️" FontSize="14" Foreground="#6C5CE7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Statut" FontSize="12" Foreground="#888780" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding}"
                                      SelectedItem="{Binding FilterStatus}"
                                      Style="{StaticResource FilterComboStyle}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Padding" Value="12,8"/>
                                    </Style>
                                </ComboBox.Resources>
                                <sys:String>Tous</sys:String>
                                <sys:String>En attente</sys:String>
                                <sys:String>Validé</sys:String>
                            </ComboBox>
                        </StackPanel>
                        
                        <Button Grid.Column="4" Command="{Binding ClearFiltersCommand}" 
                                Style="{StaticResource BtnResetStyle}"
                                VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Réinitialiser"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main Content: DataGrid -->
                <Border Grid.Row="3" Margin="24" Padding="0">
                    <Border Style="{StaticResource ModernCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Padding="24,20" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                <TextBlock Text="Liste des devis" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>

                            <DataGrid Grid.Row="1" 
                                      ItemsSource="{Binding FilteredQuotations}" 
                                      SelectedItem="{Binding SelectedQuotation}"
                                      Style="{StaticResource ModernDataGrid}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      MinWidth="1100"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="Foreground" Value="#4F46E5"/>
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                <Setter Property="Foreground" Value="#1E293B"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="RÉFÉRENCE" Binding="{Binding ReferenceNumber}" Width="180" MinWidth="150">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="Foreground" Value="#4F46E5"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="FOURNISSEUR" Binding="{Binding Supplier.CompanyName}" Width="220" MinWidth="180">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,8"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat='dd/MM/yyyy'}" Width="130" MinWidth="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,8"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="MONTANT (MAD)" Binding="{Binding TotalAmountTTC, StringFormat={}{0:N2}}" Width="160" MinWidth="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="12,8"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="STATUT" Width="140" MinWidth="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,4" CornerRadius="20" HorizontalAlignment="Left" Margin="12,8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                        <Setter Property="Foreground" Value="#059669"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="ACTIONS" Width="Auto" MinWidth="350">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="12,8">
                                                    <Button Command="{Binding DataContext.ViewQuotationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Inspecter"
                                                            Padding="10,4"
                                                            Margin="0,0,6,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" 
                                                                                    CornerRadius="20"
                                                                                    Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="👁" FontSize="12" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Inspecter" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteQuotationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Supprimer"
                                                            Padding="10,4"
                                                            Margin="0,0,6,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" 
                                                                                    CornerRadius="20"
                                                                                    Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Setter Property="Opacity" Value="0.3"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🗑" FontSize="12" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Supprimer" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.PrintPdfCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="PDF"
                                                            Padding="10,4"
                                                            Margin="0,0,6,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" 
                                                                                    CornerRadius="20"
                                                                                    Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🖨" FontSize="12" Margin="0,0,4,0"/>
                                                            <TextBlock Text="PDF" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.ChiffrerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Chiffrer"
                                                            Padding="10,4">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                                <Setter Property="Foreground" Value="#10B981"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" 
                                                                                    CornerRadius="20"
                                                                                    Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Validé">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="💰" FontSize="12" Margin="0,0,4,0"/>
                                                            <TextBlock Text="Chiffrer" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Details Modal Popup (Outside ScrollViewer to stay fixed) -->
        <Grid Background="#00000040" Visibility="{Binding IsDetailsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Top" Width="700" MaxHeight="750" Margin="0,20,0,0" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Modal Header -->
                    <Border Padding="24,20" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="Détails du Devis" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button HorizontalAlignment="Right"
                                    Command="{Binding CloseDetailsModalCommand}"
                                    Style="{StaticResource ModernIconButton}">
                                <TextBlock Text="✕" FontSize="18"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Modal Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <!-- Status Badge -->
                            <Border Padding="10,5" CornerRadius="20" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#EEE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="En attente">
                                                <Setter Property="Background" Value="#FFF3E0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="Validé">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding DetailsNormalizedStatus}" FontSize="13" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#757575"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="En attente">
                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="Validé">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- General Info Section -->
                            <Border Background="#F8F9FA" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Référence" FontWeight="SemiBold" Foreground="#757575" FontSize="13" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedQuotationDetails.ReferenceNumber}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Text="Fournisseur" FontWeight="SemiBold" Foreground="#757575" FontSize="13" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedQuotationDetails.Supplier.CompanyName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2" Text="Date" FontWeight="SemiBold" Foreground="#757575" FontSize="13" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedQuotationDetails.Date, StringFormat=dd/MM/yyyy}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="3" Text="Besoin lié" FontWeight="SemiBold" Foreground="#757575" FontSize="13" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedQuotationDetails.Need.NumeroBesoin}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="4" Text="Statut" FontWeight="SemiBold" Foreground="#757575" FontSize="13"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DetailsNormalizedStatus}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                </Grid>
                            </Border>

                            <!-- Pending Status: No prices message -->
                            <Border Background="#FFF8E1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="Validé">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Les prix ne sont pas encore saisis pour ce devis."
                                           Foreground="#E65100" FontSize="13" FontWeight="Medium"/>
                            </Border>

                            <!-- Articles Table: En attente (no prices) -->
                            <TextBlock Text="Articles" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="Validé">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DataGrid ItemsSource="{Binding SelectedQuotationDetails.Details}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#F5F5F5"
                                          FontSize="13"
                                          Margin="4">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Désignation" Width="*" MinWidth="200" Binding="{Binding Product.Designation}"/>
                                        <DataGridTextColumn Header="Quantité" Width="100" Binding="{Binding Quantity, StringFormat=N2}"/>
                                        <DataGridTextColumn Header="Unité" Width="80" Binding="{Binding Product.Unit}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Articles Table: Validé (with prices) -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="Validé">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DataGrid ItemsSource="{Binding SelectedQuotationDetails.Details}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          BorderThickness="0"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#F5F5F5"
                                          FontSize="13"
                                          Margin="4">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Désignation" Width="*" MinWidth="200" Binding="{Binding Product.Designation}"/>
                                        <DataGridTextColumn Header="Quantité" Width="100" Binding="{Binding Quantity, StringFormat=N2}"/>
                                        <DataGridTextColumn Header="Unité" Width="80" Binding="{Binding Product.Unit}"/>
                                        <DataGridTextColumn Header="Prix unitaire HT" Width="130" Binding="{Binding UnitPriceHT, StringFormat=N2}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Total ligne HT" Width="130" Binding="{Binding TotalLigneHT, StringFormat=N2}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Padding" Value="6,4"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Price Summary (Validé only) -->
                            <Border Background="#F8F9FA" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DetailsNormalizedStatus}" Value="Validé">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Total HT" FontWeight="SemiBold" Foreground="#757575" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedQuotationDetails.TotalAmountHT, StringFormat={}{0:N2} MAD}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Padding="24" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="2"
                                    Command="{Binding CloseDetailsModalCommand}"
                                    Style="{StaticResource ModernPrimaryButton}"
                                    Background="#1a3a52"
                                    Foreground="White">
                                Fermer
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Create/Edit Dialog Popup (Outside ScrollViewer to stay fixed) -->
        <Grid Background="#00000040" Visibility="{Binding IsCreateDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1000">
            <Border HorizontalAlignment="Center" VerticalAlignment="Top" Width="600" MaxHeight="700" Margin="0,20,0,0" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Dialog Header -->
                    <Border Padding="24,20" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Créer un devis"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Text" Value="Modifier le devis"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button HorizontalAlignment="Right" 
                                    Command="{Binding CloseCreateDialogCommand}"
                                    Style="{StaticResource ModernIconButton}">
                                <TextBlock Text="✕" FontSize="18"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Dialog Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <!-- Step 1: Select Need -->
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="Étape 1 : Sélectionner un besoin" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding PendingNeeds}"
                                          SelectedItem="{Binding SelectedNeed}"
                                          Style="{StaticResource ModernComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding NumeroBesoin}" FontWeight="Bold"/>
                                                <TextBlock Text=" - "/>
                                                <TextBlock Text="{Binding DateTransmission, StringFormat=dd/MM/yyyy}"/>
                                                <TextBlock Text=" ("/>
                                                <TextBlock Text="{Binding Details.Count}"/>
                                                <TextBlock Text=" articles)"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Step 2: Select Articles -->
                            <StackPanel Margin="0,0,0,24" Visibility="{Binding ArticlesToQuote.Count, Converter={StaticResource EnhancedBooleanToVisibilityConverter}}">
                                <TextBlock Text="Articles à inclure" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ArticlesToQuote}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" Style="{StaticResource ModernCheckBox}" Margin="0,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" ("/>
                                                    <TextBlock Text="{Binding Quantity}"/>
                                                    <TextBlock Text=" "/>
                                                    <TextBlock Text="{Binding Unit}"/>
                                                    <TextBlock Text=")"/>
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Step 3: Select Suppliers -->
                            <StackPanel>
                                <TextBlock Text="Étape 2 : Choisir un ou plusieurs fournisseurs" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding AvailableSuppliers}" Padding="12">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected}" Style="{StaticResource ModernCheckBox}" Margin="0,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Supplier.CompanyName}" FontWeight="SemiBold"/>
                                                            <TextBlock Text=" - " Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding Supplier.City}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Dialog Footer -->
                    <Border Padding="24" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1" 
                                    Command="{Binding CloseCreateDialogCommand}"
                                    Style="{StaticResource ModernPrimaryButton}"
                                    Background="White"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Margin="0,0,12,0">
                                Annuler
                            </Button>
                            <Button Grid.Column="2" 
                                    Command="{Binding CreateQuotesCommand}"
                                    Style="{StaticResource ModernPrimaryButton}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Créer le devis"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Text" Value="Mettre à jour"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>