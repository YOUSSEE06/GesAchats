<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs personnalisées (adaptées à GesAchats) -->
    <SolidColorBrush x:Key="BarChartBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BarPending" Color="#FF9D5C"/>
    <SolidColorBrush x:Key="BarValidated" Color="#10B981"/>
    <SolidColorBrush x:Key="BarHover" Color="#FFB380"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#4B5563"/>
    <SolidColorBrush x:Key="GridLine" Color="#E5E7EB"/>
    
    <!-- Polices -->
    <FontFamily x:Key="FontFamilyDefault">Segoe UI</FontFamily>
    
    <!-- Style pour les barres -->
    <Style x:Key="ChartBarStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource BarPending}"/>
        <Setter Property="Margin" Value="8,0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Fill" Value="{StaticResource BarHover}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Style pour le conteneur du diagramme -->
    <Style x:Key="ChartPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BarChartBackground}"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style pour le titre -->
    <Style x:Key="ChartTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>

    <!-- Style pour la légende -->
    <Style x:Key="LegendItemStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="LegendColorStyle" TargetType="Rectangle">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="RadiusX" Value="2"/>
        <Setter Property="RadiusY" Value="2"/>
    </Style>

    <Style x:Key="LegendLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Style pour les labels du diagramme -->
    <Style x:Key="ChartLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <!-- Style pour les valeurs sur les barres -->
    <Style x:Key="ChartValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

</ResourceDictionary>
