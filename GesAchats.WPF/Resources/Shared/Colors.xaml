<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Design System Colors -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="MutedTextColor">#64748B</Color>
    <Color x:Key="MainTextColor">#0F172A</Color>
    <Color x:Key="PageBackgroundColor">#F8FAFC</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    
    <!-- Sidebar Colors -->
    <Color x:Key="SidebarBackgroundColor">#0F172A</Color>
    <Color x:Key="SidebarHoverColor">#1E293B</Color>
    <Color x:Key="SidebarActiveColor">#243B55</Color>
    <Color x:Key="SidebarTextColor">#FFFFFF</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="MainTextBrush" Color="{StaticResource MainTextColor}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>

    <!-- Backward compatibility -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PageBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource MainTextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="NewProductBrush" Color="{StaticResource SuccessColor}"/>
    
</ResourceDictionary>
