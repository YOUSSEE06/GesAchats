<UserControl x:Class="GesAchats.WPF.Controls.SidebarItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="230">
    <Border x:Name="MainBorder" 
            Background="Transparent" 
            Padding="12,10" 
            CornerRadius="8"
            Cursor="Hand">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <fa:IconImage x:Name="IconControl" 
                          Grid.Column="0" 
                          Width="20" Height="20" 
                          VerticalAlignment="Center"/>
            <TextBlock x:Name="TextControl" 
                       Grid.Column="1" 
                       Margin="12,0,0,0" 
                       VerticalAlignment="Center" 
                       FontSize="14"
                       FontWeight="Medium"/>
        </Grid>
    </Border>
</UserControl>